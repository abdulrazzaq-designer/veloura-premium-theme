      <span>{{ vmfm_categories_label }}</span>
    {% endif %}
  </button>
{% endif %}

      {% if vmfm_show_search %}
        <a href="{{ store.url|default('') }}/search" class="veloura-mobile-floating-menu__item" data-vmfm-match="search" data-vmfm-action="search" aria-label="{{ vmfm_search_label|e }}">
          <i class="sicon-search" aria-hidden="true"></i>
          {% if vmfm_show_labels %}<span>{{ vmfm_search_label }}</span>{% endif %}
        </a>
      {% endif %}

      {% if vmfm_show_cart %}
        <a href="{{ store.url|default('') }}/cart" class="veloura-mobile-floating-menu__item" data-vmfm-match="cart" aria-label="{{ vmfm_cart_label|e }}">
          <i class="sicon-shopping-bag" aria-hidden="true"></i>
          {% if vmfm_show_labels %}<span>{{ vmfm_cart_label }}</span>{% endif %}
        </a>
      {% endif %}

      {% if vmfm_show_account %}
        <button type="button" class="veloura-mobile-floating-menu__item" data-vmfm-match="account" data-vmfm-action="login" aria-label="{{ vmfm_account_label|e }}">
          <i class="sicon-user" aria-hidden="true"></i>
          {% if vmfm_show_labels %}<span>{{ vmfm_account_label }}</span>{% endif %}
        </button>
      {% endif %}

      {% for item in vmfm_custom_items %}
        {% set item_enabled_raw = item.enabled is defined ? item.enabled : true %}
        {% set item_enabled = item_enabled_raw == true or item_enabled_raw == 'true' or item_enabled_raw == 1 or item_enabled_raw == '1' or item_enabled_raw == 'on' %}
        {% if item_enabled %}
          {% set item_label = item.label|default('رابط') %}
          {% set item_url = item.url|default('') %}
          {% set item_new_tab_raw = item.open_new_tab is defined ? item.open_new_tab : false %}
          {% set item_new_tab = item_new_tab_raw == true or item_new_tab_raw == 'true' or item_new_tab_raw == 1 or item_new_tab_raw == '1' or item_new_tab_raw == 'on' %}
          {% set item_icon_raw = item.icon|default('sicon-shopping-bag') %}
          {% if item_icon_raw is iterable and item_icon_raw[0].value is defined %}
            {% set item_icon = item_icon_raw[0].value %}
          {% elseif item_icon_raw.value is defined %}
            {% set item_icon = item_icon_raw.value %}
          {% else %}
            {% set item_icon = item_icon_raw %}
          {% endif %}
          {% if item_url %}
            <a href="{{ item_url|e('html_attr') }}" class="veloura-mobile-floating-menu__item" aria-label="{{ item_label|e }}" {% if item_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
              <i class="{{ item_icon|e('html_attr') }}" aria-hidden="true"></i>
              {% if vmfm_show_labels %}<span>{{ item_label }}</span>{% endif %}
            </a>
          {% else %}
            <button type="button" class="veloura-mobile-floating-menu__item" aria-label="{{ item_label|e }}">
              <i class="{{ item_icon|e('html_attr') }}" aria-hidden="true"></i>
              {% if vmfm_show_labels %}<span>{{ item_label }}</span>{% endif %}
            </button>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </nav>

  <script data-cfasync="false">
  document.addEventListener('DOMContentLoaded', function () {
    var menu = document.querySelector('.veloura-mobile-floating-menu');

    if (!menu) {
      return;
    }

    var root = document.documentElement;
    var items = menu.querySelectorAll('.veloura-mobile-floating-menu__item');
    var syncTimers = [];
    var transientAction = '';
    var transientTimer = null;
    var transientWatcher = null;
    var transientSeenOpen = false;
    var transientStartedAt = 0;

    root.style.setProperty('--veloura-mobile-floating-menu-height', "{{ vmfm_height }}px");
    root.style.setProperty('--veloura-mobile-floating-menu-bottom', "{{ vmfm_bottom }}px");
    root.style.setProperty('--veloura-mobile-floating-menu-bg', "{{ vmfm_bg_color }}");
    root.style.setProperty('--veloura-mobile-floating-menu-text', "{{ vmfm_text_color }}");
    root.style.setProperty('--veloura-mobile-floating-menu-active', "{{ vmfm_active_color }}");
    root.style.setProperty('--veloura-mobile-floating-menu-radius', "{{ vmfm_radius_map[vmfm_radius]|default('999px') }}");
    root.style.setProperty('--veloura-mobile-floating-menu-icon-size', "{{ vmfm_icon_size }}px");
    root.style.setProperty('--veloura-mobile-floating-menu-font-size', "{{ vmfm_font_size }}px");
    root.style.setProperty('--veloura-mobile-floating-menu-active-scale', "{{ vmfm_active_scale }}");

    function normalizePath(value) {
      try {
        var url = new URL(value, window.location.origin);
        return url.pathname.replace(/\/+$/, '') || '/';
      } catch (error) {
        return String(value || '').replace(/\/+$/, '') || '/';
      }
    }

    function closestFromTarget(target, selector) {
      if (!target || target === document || target === window) {
        return null;
      }

      if (target.closest) {
        return target.closest(selector);
      }

      return null;
    }

    function nativeClick(el) {
      if (!el) {
        return false;
      }

      try {
        el.dispatchEvent(
          new MouseEvent('click', {
            bubbles: true,
            cancelable: true,
            view: window
          })
        );

        return true;
      } catch (error) {
        if (typeof el.click === 'function') {
          el.click();
          return true;
        }
      }

      return false;
    }

    function isVisibleElement(el) {
      if (!el) {
        return false;
      }

      try {
        var style = window.getComputedStyle(el);
        var rect = el.getBoundingClientRect();

        return (
          style.display !== 'none' &&
          style.visibility !== 'hidden' &&
          style.opacity !== '0' &&
          rect.width > 0 &&
          rect.height > 0
        );
      } catch (error) {
        return false;
      }
    }

    function anyVisible(selectors) {
      for (var i = 0; i < selectors.length; i++) {
        var nodes = document.querySelectorAll(selectors[i]);

        for (var j = 0; j < nodes.length; j++) {
          var node = nodes[j];

          if (
            node.hasAttribute('open') ||
            node.hasAttribute('opened') ||
            node.classList.contains('is-open') ||
            node.classList.contains('s-modal-is-open') ||
            node.classList.contains('active') ||
            isVisibleElement(node)
          ) {
            return true;
          }
        }
      }

      return false;
    }

    function clickFirst(selectors) {
      for (var i = 0; i < selectors.length; i++) {
        var el = document.querySelector(selectors[i]);

        if (!el || closestFromTarget(el, '.veloura-mobile-floating-menu')) {
          continue;
        }

        var clickable = el;

        if (
          !/^(A|BUTTON)$/i.test(el.tagName || '') &&
          closestFromTarget(el, 'button, a')
        ) {
          clickable = closestFromTarget(el, 'button, a');
        }

        if (nativeClick(clickable)) {
          return true;
        }
      }

      return false;
    }

    function openSearchFallback() {
      if (window.salla && window.salla.event && typeof window.salla.event.dispatch === 'function') {
        try {
          window.salla.event.dispatch('search::open');
        } catch (error) {}
      }

      return clickFirst([
        '[data-search-open]',
        '[data-open-search]',
        '[data-search]',
        '.s-search-modal-trigger',
        '.s-header-search',
        '.search-trigger',
        '.search-btn',
        '.veloura-header-search',
        '.veloura-header-search-trigger',
        '.header-search',
        'button[aria-label*="بحث"]',
        'button[aria-label*="search"]',
        'a[aria-label*="بحث"]',
        'a[aria-label*="search"]'
      ]);
    }

    function closeVisibleModalLikeThings() {
      var closed = clickFirst([
        'salla-login-modal button[aria-label*="إغلاق"]',
        'salla-login-modal button[aria-label*="close"]',
        'salla-login-modal .s-modal-close',
        'salla-login-modal .s-modal__close',
        'salla-login-modal .sicon-cancel',
        'salla-search button[aria-label*="إغلاق"]',
        'salla-search button[aria-label*="close"]',
        'salla-search .s-modal-close',
        'salla-search .s-modal__close',
        'salla-search .sicon-cancel',
        '.s-modal button[aria-label*="إغلاق"]',
        '.s-modal button[aria-label*="close"]',
        '.s-modal .s-modal-close',
        '.s-modal .s-modal__close',
        '.s-modal .sicon-cancel',
        '.modal button[aria-label*="إغلاق"]',
        '.modal button[aria-label*="close"]',
        '.modal .modal-close',
        '.modal .sicon-cancel'
      ]);

      document.body.classList.remove('overflow-hidden');

      return closed;
    }

    function clearFloatingMenuActive() {
      items.forEach(function (item) {
        item.classList.remove('is-active');
      });
    }

    function activateFloatingItem(item) {
      clearFloatingMenuActive();

      if (item) {
        item.classList.add('is-active');
      }
    }

    function stopTransientWatcher() {
      if (transientWatcher) {
        clearInterval(transientWatcher);
        transientWatcher = null;
      }

      if (transientTimer) {
        clearTimeout(transientTimer);
        transientTimer = null;
      }

      transientSeenOpen = false;
      transientStartedAt = 0;
    }

    function clearTransientAction() {
      stopTransientWatcher();
      transientAction = '';
      syncFloatingMenuActive();
    }

    function isSearchModalOpen() {
      if (
        document.body.classList.contains('search-open') ||
        document.body.classList.contains('s-search-open') ||
        document.body.classList.contains('salla-search-open')
      ) {
        return true;
      }

      return anyVisible([
        'salla-search[open]',
        'salla-search[opened]',
        'salla-search.is-open',
        'salla-search.active',
        '.s-search-modal',
        '.s-search-modal-open',
        '.s-search-container',
        '.s-search-results',
        '.s-modal-search',
        '.search-modal',
        '.search-modal.open',
        '.search-modal.active',
        '[class*="search"][class*="modal"]',
        '[class*="Search"][class*="modal"]'
      ]);
    }

    function isLoginModalOpen() {
      if (
        document.body.classList.contains('login-open') ||
        document.body.classList.contains('s-login-open') ||
        document.body.classList.contains('salla-login-open')
      ) {
        return true;
      }

      return anyVisible([
        'salla-login-modal[open]',
        'salla-login-modal[opened]',
        'salla-login-modal.is-open',
        'salla-login-modal.active',
        '.s-login-modal',
        '.s-auth-modal',
        '.s-user-modal',
        '.login-modal',
        '.login-modal.open',
        '.login-modal.active',
        '[class*="login"][class*="modal"]',
        '[class*="Login"][class*="modal"]',
        '[class*="auth"][class*="modal"]',
        '[class*="Auth"][class*="modal"]'
      ]);
    }

    function isTransientModalOpen(action) {
      if (action === 'search') {
        return isSearchModalOpen();
      }

      if (action === 'login') {
        return isLoginModalOpen();
      }

      return false;
    }

    function setTransientAction(action, item) {
      stopTransientWatcher();

      transientAction = action || '';
      transientStartedAt = Date.now();
      transientSeenOpen = false;

      if (item) {
        activateFloatingItem(item);
      }

      if (!transientAction) {
        syncFloatingMenuActive();
        return;
      }

      /*
       * يثبت البحث/حسابي طالما النافذة مفتوحة.
       * وإذا انقفلت النافذة يرجع النشط حسب رابط الصفحة.
       */
      transientWatcher = setInterval(function () {
        var elapsed = Date.now() - transientStartedAt;
        var isOpen = isTransientModalOpen(transientAction);

        if (isOpen) {
          transientSeenOpen = true;
          syncFloatingMenuActive();
          return;
        }

        if (transientSeenOpen && elapsed > 600) {
          clearTransientAction();
          return;
        }

        /*
         * حماية لو ما انفتحت النافذة أصلًا.
         */
        if (!transientSeenOpen && elapsed > 7000) {
          clearTransientAction();
        }
      }, 300);
    }

    function ensureCategoriesCloseStyles() {
      if (document.getElementById('veloura-native-categories-close-style')) {
        return;
      }

      var style = document.createElement('style');
      style.id = 'veloura-native-categories-close-style';

      style.textContent = [
        '@media (max-width: 767px) {',
        '  .mm-ocd.ocd-categs .close-mobile-menu,',
        '  .mm-ocd.ocd-categs.mm-ocd--open .close-mobile-menu {',
        '    display: inline-flex !important;',
        '    visibility: visible !important;',
        '    opacity: 1 !important;',
        '    position: fixed !important;',
        '    top: 14px !important;',
        '    left: 14px !important;',
        '    z-index: 999999 !important;',
        '    width: 38px !important;',
        '    height: 38px !important;',
        '    align-items: center !important;',
        '    justify-content: center !important;',
        '    border: 0 !important;',
        '    border-radius: 999px !important;',
        '    background: rgba(15, 23, 42, 0.10) !important;',
        '    color: #111827 !important;',
        '    font-size: 18px !important;',
        '    line-height: 1 !important;',
        '    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);',
        '  }',
        '  .mm-ocd.ocd-categs .close-mobile-menu::before,',
        '  .mm-ocd.ocd-categs.mm-ocd--open .close-mobile-menu::before {',
        '    font-size: 18px !important;',
        '    line-height: 1 !important;',
        '  }',
        '  body.veloura-mobile-floating-menu-enabled .veloura-mobile-floating-menu {',
        '    z-index: 99999 !important;',
        '  }',
        '}'
      ].join('\n');

      document.head.appendChild(style);
    }

    function getCategoriesDrawer() {
      return (
        document.querySelector('.mm-ocd.ocd-categs') ||
        document.querySelector('.mm-ocd--right.ocd-categs') ||
        document.querySelector('.mm-ocd')
      );
    }

    function isCategoriesMenuOpen() {
      var drawer = getCategoriesDrawer();

      return !!(
        drawer &&
        (
          drawer.classList.contains('mm-ocd--open') ||
          document.body.classList.contains('menu-opened') ||
          document.body.classList.contains('mm-ocd-opened')
        )
      );
    }

    function getCurrentPath() {
      return normalizePath(window.location.href);
    }

    function getItemPath(item) {
      var href = item ? item.getAttribute('href') : '';

      if (!href || href === '#' || href === '#mobile-menu') {
        return '';
      }

      try {
        return normalizePath(new URL(href, window.location.origin).href);
      } catch (error) {
        return '';
      }
    }

    function syncFloatingMenuActive() {
      var currentPath = getCurrentPath();
      var matchedItem = null;

      clearFloatingMenuActive();

      if (isCategoriesMenuOpen()) {
        matchedItem = menu.querySelector('[data-vmfm-action="categories"]');

        if (matchedItem) {
          matchedItem.classList.add('is-active');
        }

        return;
      }

      if (transientAction === 'search') {
        matchedItem = menu.querySelector('[data-vmfm-action="search"], [data-vmfm-match="search"]');

        if (matchedItem) {
          matchedItem.classList.add('is-active');
        }

        return;
      }

      if (transientAction === 'login') {
        matchedItem = menu.querySelector('[data-vmfm-action="login"], [data-vmfm-match="account"]');

        if (matchedItem) {
          matchedItem.classList.add('is-active');
        }

        return;
      }

      items.forEach(function (item) {
        if (matchedItem) {
          return;
        }

        var match = String(item.getAttribute('data-vmfm-match') || '').trim();
        var itemPath = getItemPath(item);

        if (match === 'home' && currentPath === '/') {
          matchedItem = item;
          return;
        }

        if (
          match === 'categories' &&
          (
            currentPath.indexOf('/categories') !== -1 ||
            currentPath.indexOf('/category') !== -1 ||
            currentPath.indexOf('/c/') !== -1
          )
        ) {
          matchedItem = item;
          return;
        }

        if (match === 'search' && currentPath.indexOf('/search') !== -1) {
          matchedItem = item;
          return;
        }

        if (match === 'cart' && currentPath.indexOf('/cart') !== -1) {
          matchedItem = item;
          return;
        }

        if (
          match === 'account' &&
          (
            currentPath.indexOf('/account') !== -1 ||
            currentPath.indexOf('/profile') !== -1 ||
            currentPath.indexOf('/login') !== -1
          )
        ) {
          matchedItem = item;
          return;
        }

        if (itemPath && itemPath === currentPath) {
          matchedItem = item;
        }
      });

      if (matchedItem) {
        matchedItem.classList.add('is-active');
        return;
      }

      if (currentPath === '/') {
        var homeItem = menu.querySelector('[data-vmfm-match="home"]');

        if (homeItem) {
          homeItem.classList.add('is-active');
        }
      }
    }

    function scheduleFloatingMenuSync() {
      var delays = [120, 350, 800, 1600, 3000];

      syncTimers.forEach(function (timer) {
        clearTimeout(timer);
      });

      syncTimers = delays.map(function (delay) {
        return setTimeout(syncFloatingMenuActive, delay);
      });
    }

    function closeCategoriesMenu() {
      var drawer = getCategoriesDrawer();
      var closeBtn = drawer ? drawer.querySelector('.close-mobile-menu') : null;
      var backdrop = drawer ? drawer.querySelector('.mm-ocd__backdrop') : null;

      if (closeBtn) {
        nativeClick(closeBtn);
      } else if (backdrop) {
        nativeClick(backdrop);
      } else if (drawer) {
        drawer.classList.remove('mm-ocd--open');
        document.body.classList.remove('menu-opened');
        document.body.classList.remove('mm-ocd-opened');
        document.body.classList.remove('overflow-hidden');
        document.body.classList.remove('mm-wrapper--opened');
        document.documentElement.classList.remove('mm-wrapper--opened');
      }

      clearTransientAction();

      return false;
    }

    function closeOpenOverlays(exceptAction) {
      if (exceptAction !== 'categories' && isCategoriesMenuOpen()) {
        closeCategoriesMenu();
      }

      if (exceptAction !== 'search' && exceptAction !== 'login') {
        closeVisibleModalLikeThings();
        clearTransientAction();
      }
    }

    function openCategoriesMenu() {
      ensureCategoriesCloseStyles();

      if (isCategoriesMenuOpen()) {
        return closeCategoriesMenu();
      }

      closeOpenOverlays('categories');

      var trigger =
        document.querySelector('.veloura-menu-trigger-mobile[href="#mobile-menu"]') ||
        document.querySelector('a.mburger[href="#mobile-menu"]') ||
        document.querySelector('a[href="#mobile-menu"]');

      if (!trigger) {
        return false;
      }

      nativeClick(trigger);
      scheduleFloatingMenuSync();

      return true;
    }

    function openLoginModal() {
      closeOpenOverlays('login');

      var opened = clickFirst([
        '#mobile-nav .mob-login a',
        '.mobile-nav .mob-login a',
        '.mob-login .mobile-nav--item',
        '[data-login]',
        '[data-open-login]',
        '[data-login-open]',
        '.s-login-modal-trigger',
        '.login-trigger',
        '.s-user-menu-trigger',
        'button[aria-label*="تسجيل"]',
        'button[aria-label*="دخول"]',
        'button[aria-label*="login"]',
        'a[href*="/login"]',
        'a[href*="/account"]'
      ]);

      if (opened) {
        return true;
      }

      if (window.salla && window.salla.event && typeof window.salla.event.dispatch === 'function') {
        try {
          window.salla.event.dispatch('login::open');
          return true;
        } catch (error) {}
      }

      var loginModal = document.querySelector('salla-login-modal');

      if (loginModal && typeof loginModal.open === 'function') {
        loginModal.open();
        return true;
      }

      window.location.href = {{ (store.url|default('') ~ '/login')|json_encode|raw }};
      return true;
    }

    document.addEventListener(
      'click',
      function (event) {
        var insideMenu = closestFromTarget(event.target, '.veloura-mobile-floating-menu');
        var closeBtn = closestFromTarget(event.target, '.close-mobile-menu');
        var backdrop = closestFromTarget(event.target, '.mm-ocd__backdrop');
        var modalClose = closestFromTarget(
          event.target,
          '.s-modal-close, .s-modal__close, .modal-close, [aria-label*="إغلاق"], [aria-label*="close"]'
        );

        if (insideMenu) {
          return;
        }

        if (closeBtn || backdrop || modalClose) {
          setTimeout(clearTransientAction, 120);
        }
      },
      true
    );

    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') {
        setTimeout(clearTransientAction, 120);
      }
    });

    window.addEventListener('popstate', function () {
      clearTransientAction();
    });

    window.addEventListener('hashchange', function () {
      clearTransientAction();
    });

    window.addEventListener('pageshow', function () {
      syncFloatingMenuActive();
    });

    document.addEventListener('visibilitychange', function () {
      if (!document.hidden) {
        syncFloatingMenuActive();
      }
    });

    try {
      ['pushState', 'replaceState'].forEach(function (methodName) {
        var original = history[methodName];

        if (typeof original !== 'function' || original.__velouraVmfmPatched) {
          return;
        }

        var patched = function () {
          var result = original.apply(this, arguments);
          scheduleFloatingMenuSync();
          return result;
        };

        patched.__velouraVmfmPatched = true;
        history[methodName] = patched;
      });
    } catch (error) {}

    syncFloatingMenuActive();

    menu.addEventListener('click', function (event) {
      var actionItem = closestFromTarget(event.target, '.veloura-mobile-floating-menu__item');

      if (!actionItem) {
        return;
      }

      var action = actionItem.getAttribute('data-vmfm-action');

      if (action === 'search') {
        event.preventDefault();
        closeOpenOverlays('search');
        setTransientAction('search', actionItem);
        openSearchFallback();
        scheduleFloatingMenuSync();
        return;
      }

      if (action === 'categories') {
        event.preventDefault();

        var didOpen = openCategoriesMenu();

        if (didOpen) {
          stopTransientWatcher();
          transientAction = '';
          activateFloatingItem(actionItem);
        } else {
          syncFloatingMenuActive();
        }

        scheduleFloatingMenuSync();
        return;
      }

      if (action === 'login') {
        event.preventDefault();
        closeOpenOverlays('login');
        setTransientAction('login', actionItem);
        openLoginModal();
        scheduleFloatingMenuSync();
        return;
      }

      closeOpenOverlays('');
      clearTransientAction();
      scheduleFloatingMenuSync();
    });
  });
</script>
{% endif %}

</body>
</html>