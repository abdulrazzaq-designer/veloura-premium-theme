      body.veloura-general-enabled {
        background-color: var(--veloura-site-bg) !important;
      }

      body.veloura-general-enabled .app-inner,
      body.veloura-general-enabled main,
      body.veloura-general-enabled .index,
      body.veloura-general-enabled .store-page,
      body.veloura-general-enabled .store-home {
        background-color: transparent !important;
      }

      body.veloura-general-enabled.veloura-site-has-bg-image {
        background-image: var(--veloura-site-bg-image) !important;
        background-size: cover !important;
        background-position: center top !important;
        background-repeat: no-repeat !important;
      }

      body.veloura-general-enabled.veloura-site-bg-fixed {
        background-attachment: fixed !important;
      }

      @media (max-width: 1023px) {
        body.veloura-general-enabled .container {
          padding-inline: var(--veloura-site-spacing) !important;
        }
      }

      @media (min-width: 1024px) {
        body.veloura-general-enabled .container {
          max-width: var(--veloura-site-container-width) !important;
        }
      }

      body.veloura-general-enabled.veloura-clean-borders .s-product-card,
      body.veloura-general-enabled.veloura-clean-borders .s-block,
      body.veloura-general-enabled.veloura-clean-borders .main-nav-container,
      body.veloura-general-enabled.veloura-clean-borders .store-footer {
        border-color: transparent !important;
        box-shadow: none !important;
      }

      body.veloura-general-enabled.veloura-glass-effect .veloura-glass,
      body.veloura-general-enabled.veloura-glass-effect .s-product-card,
      body.veloura-general-enabled.veloura-glass-effect .main-nav-container {
        background-color: rgba(255, 255, 255, .72) !important;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
      }

      {% if vpc_enabled %}
        /* ================================
           Veloura Product Card Dynamic Style
        ================================ */

        body.veloura-product-card-enabled .s-product-card-entry,
        body.veloura-product-card-enabled product-card .s-product-card-entry {
          background: var(--veloura-product-card-bg) !important;
          border-radius: var(--veloura-product-card-radius) !important;
          overflow: hidden !important;
        }

        /* صورة المنتج: المسافة يمين ويسار تصغّر الصورة من الطرفين وتبقيها بالمنتصف */
        body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image {
          margin-top: var(--veloura-product-image-padding-top) !important;
          margin-inline: auto !important;
          margin-bottom: 0 !important;
          width: calc(100% - (var(--veloura-product-image-padding-x) * 2)) !important;
          max-width: calc(100% - (var(--veloura-product-image-padding-x) * 2)) !important;
          border-radius: var(--veloura-product-image-radius) !important;
          overflow: hidden !important;
        }

        body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image a,
        body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image img,
        body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image .s-product-card-image-cover {
          border-radius: var(--veloura-product-image-radius) !important;
          overflow: hidden !important;
        }

        {% if vpc_image_aspect != 'auto' %}
          body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image {
            aspect-ratio: {{ vpc_image_aspect }} !important;
            height: auto !important;
          }

          body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image a,
          body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image img {
            width: 100% !important;
            height: 100% !important;
          }

          body.veloura-product-card-enabled .s-product-card-entry .s-product-card-image img {
            object-fit: cover !important;
