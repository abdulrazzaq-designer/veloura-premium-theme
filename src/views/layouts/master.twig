{# ############## Shared Variables in all views ################
| Variable                                           | Type     | Description                                                                                              |
|----------------------------------------------------|----------|----------------------------------------------------------------------------------------------------------|
| store                                              | Store    |                                                                                                          |
| store.id                                           | int      |                                                                                                          |
| store.name                                         | string   |                                                                                                          |
| store.username                                     | string   |                                                                                                          |
| store.description                                  | string   |                                                                                                          |
| store.slogan                                       | ?string  | * if feature in twilight.json                                                                            |
| store.logo                                         | string   |                                                                                                          |
| store.url                                          | string   |                                                                                                          |
| store.api                                          | string   | the api url for current store                                                                            |
| store.icon                                         | string   | *fav icon url                                                                                            |
| store.contacts                                     | object   | [mobile, phone, email, whatsapp, telegram], ex. store.contacts.email                                     |
| store.social                                       | object   | [instagram, snapchat, twitter, youtube, facebook, pinterest, maroof, whatsapp], ex. store.social.twitter |
| store.settings                                     | object   |                                                                                                          |
| store.settings.auth.email_allowed                  | bool     |                                                                                                          |
| store.settings.auth.mobile_allowed                 | bool     |                                                                                                          |
| store.settings.auth.is_email_required              | bool     |                                                                                                          |
| store.settings.cart.apply_coupon_enabled           | bool     | Does visitor allowed to applay coupon in cart page                                                       |
| store.settings.product.total_sold_enabled          | bool     |                                                                                                          |
| store.settings.product.fit_type                    | ?string  | null when equal product card size is off, or ['cover', 'contain']                                        |
| store.settings.category.testimonial_enabled        | bool     | Show random testimonials in category page                                                                |
| store.settings.tax.number                          | ?string  |                                                                                                          |
| store.settings.tax.certificate                     | ?string  | certificate image url                                                                                    |
| store.settings.tax.taxable_prices_enabled          | bool     | Does tax included in the prices ex product_price 100 & tax is 15, price will be 115                      |
| store.settings.rating_enabled                      | bool     | Is one of: store_enabled or shipping_enabled or products_enabled                                         |
| store.settings.arabic_numbers_enabled              | bool     | Does the merchant wants the numbers to be shown as Arabic format                                         |
| store.settings.is_multilingual                     | bool     |                                                                                                          |
| store.settings.currencies_enabled                  | bool     |     
| theme                                              | Theme    |                                                                                                          |
| theme.id                                           | int      |                                                                                                          |
| theme.name                                         | string   |                                                                                                          |
| theme.mode                                         | string   | `live`, `preview`                                                                                        |
| theme.is_rtl                                       | bool     |                                                                                                          |
| theme.translations_hash                            | int      | to be used in case merchant updated frontend store translations                                          |
| theme.color                                        | object   |                                                                                                          |
| theme.color.primary                                | string   |                                                                                                          |
| theme.color.text                                   | string   | suitable text color comparing to `theme.primary.color`, #000000, #FFFFFF                                 |
| theme.color.reverse_primary                        | string   |                                                                                                          |
| theme.color.reverse_text                           | string   | if `theme.text_color=#000000` means that `theme.reverse_text_color=#FFFFFF`                              |
| theme.color.is_dark                                | bool     | Does main store color `theme.primary.color` considered as dim color?                                     |
| theme.color.darker(float alpha, ?string hexColor)  | string   | get darker color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0             |
| theme.color.lighter(float alpha, ?string hexColor) | string   | get lighter color from `theme.primary.color` or from passed color, `alpha` range from 0.0-1.0            |
| theme.font                                         | ?object  | Salla predefined font, null when the theme doesn't have `fonts` feature                                  |
| theme.font.name                                    | string   | DINNextLTArabic-Regular, Amazon-Ember, Apple, Dubai, Estedad                                             |
| theme.font.url                                     | string   | css full url ex: 'https://my_store.test/dist/fonts/default.css'                                          |
| theme.settings                                     | object   | dynamic object with values of the `settings` in twilight.json ex. `theme.settings.topnav_is_dark`        |
| theme.settings.set(settingName, value)             | string   | set global var, then get it {{theme.settings.get('my_var','fallback') }}                                 |
| theme.settings.get(settingName, default=null)      | mixed    | get theme setting ex `theme.settings.get('my_var', 'fallback')`                                          |
#}
<!DOCTYPE html>
<html lang="{{ language.code }}" dir="{{ theme.is_rtl ? 'rtl' : 'ltr' }}">
<!-- بسم الله الرحمن الرحيم -->
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ theme.settings.set('placeholder', 'images/placeholder.png') }}

    <script defer data-cfasync="false" crossorigin="anonymous" src="{{ 'product-card.js'|asset }}"></script>
    <script defer src="{{ 'main-menu.js'|asset }}"></script>

    {% if theme.settings.get('enable_add_product_toast', true) %}
        <script defer src="{{ 'add-product-toast.js'|asset }}"></script>
    {% endif %}

    {% block head_scripts %}{% endblock %}

    <script data-cfasync="false">
        window.header_is_sticky = "{{ theme.settings.get('header_is_sticky', 'Default Value') }}"
        window.imageZoom = "{{ theme.settings.get('imageZoom') }}"
        window.can_access_wallet = {{ user.can_access_wallet | json_encode }}
        window.enable_more_menu = "{{ theme.settings.get('enable_more_menu', true) }}"
        window.enable_add_product_toast = "{{ theme.settings.get('enable_add_product_toast', true) }}"
    </script>
    {% hook 'head:start' %}
    {% hook head %}
    {% block styles %}{% endblock %}

    <link rel="stylesheet" href="{{ 'app.css' | asset }}">
    <link rel="stylesheet" href="{{ theme.font.path|cdn }}"/>
    <link rel="stylesheet" href="{{ 'fonts/sallaicons.css'|cdn }}"/>

    {# ================================
       Veloura General Settings 2026
    ================================ #}

    {% set veloura_general_enabled = true %}

    {% set veloura_site_bg = theme.settings.get('veloura_site_bg_color_2026', '#ffffff') %}
    {% if veloura_site_bg.value is defined %}
      {% set veloura_site_bg = veloura_site_bg.value %}
    {% endif %}

    {% set veloura_site_second_bg = theme.settings.get('veloura_site_second_bg_color_2026', '#f8fafc') %}
    {% if veloura_site_second_bg.value is defined %}
      {% set veloura_site_second_bg = veloura_site_second_bg.value %}
    {% endif %}

    {% set veloura_site_bg_image = theme.settings.get('veloura_site_bg_image_2026') %}
    {% set veloura_site_bg_home_only = theme.settings.get('veloura_site_bg_image_home_only_2026', false) %}
    {% set veloura_site_bg_fixed = theme.settings.get('veloura_site_bg_fixed_2026', false) %}

    {% set veloura_site_spacing = theme.settings.get('veloura_site_horizontal_spacing_2026', 12) %}
    {% if veloura_site_spacing.value is defined %}
      {% set veloura_site_spacing = veloura_site_spacing.value %}
    {% endif %}

    {% set veloura_container_value = theme.settings.get('veloura_site_container_width_2026', 180) %}
    {% if veloura_container_value.value is defined %}
      {% set veloura_container_value = veloura_container_value.value %}
    {% endif %}
    {% set veloura_container_width = 1100 + veloura_container_value %}

    {% set veloura_body_classes = theme.settings.get('veloura_body_classes_2026') %}
    {% set veloura_index_body_classes = is_page('index') ? theme.settings.get('veloura_index_body_classes_2026') : '' %}
    {% set veloura_product_body_classes = is_page('product.single') ? theme.settings.get('veloura_product_body_classes_2026') : '' %}

    {% set veloura_full_width_sections = theme.settings.get('veloura_site_sections_full_width_2026', false) %}
    {% set veloura_glass_effect = theme.settings.get('veloura_general_glass_effect_2026', false) %}
    {% set veloura_clean_borders = theme.settings.get('veloura_general_clean_borders_2026', false) %}

    {% set veloura_should_show_bg_image = veloura_site_bg_image and (not veloura_site_bg_home_only or is_page('index')) %}

    {# ================================
       Veloura Product Card Settings 2026
       يقرأ إعدادات بطاقة المنتج العامة من twilight.json
    ================================ #}

    {% set vpc_enabled_raw = theme.settings.get('veloura_product_card_enabled_2026', false) %}
    {% if vpc_enabled_raw.value is defined %}
      {% set vpc_enabled_raw = vpc_enabled_raw.value %}
    {% elseif vpc_enabled_raw.selected is defined %}
      {% set vpc_enabled_raw = vpc_enabled_raw.selected %}
    {% endif %}

    {% set vpc_enabled =
      vpc_enabled_raw == true
      or vpc_enabled_raw == 'true'
      or vpc_enabled_raw == 1
      or vpc_enabled_raw == '1'
      or vpc_enabled_raw == 'on'
    %}

    {% set vpc_radius_map = {
      'sharp': '0px',
      'soft': '8px',
      'medium': '16px',
      'large': '28px',
      'round': '999px'
    } %}

    {# لون وخلفية البطاقة #}
    {% set vpc_card_bg = theme.settings.get('veloura_product_card_bg_color_2026', '#ffffff') %}
    {% if vpc_card_bg.value is defined %}
      {% set vpc_card_bg = vpc_card_bg.value %}
    {% endif %}

    {% set vpc_card_radius_raw = theme.settings.get('veloura_product_card_radius_2026', 'medium') %}
    {% if vpc_card_radius_raw is iterable and vpc_card_radius_raw[0].value is defined %}
      {% set vpc_card_radius_key = vpc_card_radius_raw[0].value %}
    {% elseif vpc_card_radius_raw.value is defined %}
      {% set vpc_card_radius_key = vpc_card_radius_raw.value %}
    {% else %}
      {% set vpc_card_radius_key = vpc_card_radius_raw %}
    {% endif %}

    {# صورة المنتج #}
    {% set vpc_image_radius_raw = theme.settings.get('veloura_product_card_image_radius_2026', 'medium') %}
    {% if vpc_image_radius_raw is iterable and vpc_image_radius_raw[0].value is defined %}
      {% set vpc_image_radius_key = vpc_image_radius_raw[0].value %}
    {% elseif vpc_image_radius_raw.value is defined %}
      {% set vpc_image_radius_key = vpc_image_radius_raw.value %}
    {% else %}
      {% set vpc_image_radius_key = vpc_image_radius_raw %}
    {% endif %}

    {% set vpc_image_ratio_raw = theme.settings.get('veloura_product_card_image_ratio_2026', 'square') %}
    {% if vpc_image_ratio_raw is iterable and vpc_image_ratio_raw[0].value is defined %}
      {% set vpc_image_ratio = vpc_image_ratio_raw[0].value %}
    {% elseif vpc_image_ratio_raw.value is defined %}
      {% set vpc_image_ratio = vpc_image_ratio_raw.value %}
    {% else %}
      {% set vpc_image_ratio = vpc_image_ratio_raw %}
    {% endif %}

    {% if vpc_image_ratio == 'square' %}
      {% set vpc_image_aspect = '1 / 1' %}
    {% elseif vpc_image_ratio == 'portrait_3_4' %}
      {% set vpc_image_aspect = '3 / 4' %}
    {% elseif vpc_image_ratio == 'landscape_5_4' %}
      {% set vpc_image_aspect = '5 / 4' %}
    {% else %}
      {% set vpc_image_aspect = 'auto' %}
    {% endif %}

    {% set vpc_image_padding_top = theme.settings.get('veloura_product_card_image_padding_top_2026', '0') %}
    {% if vpc_image_padding_top.value is defined %}
      {% set vpc_image_padding_top = vpc_image_padding_top.value %}
    {% endif %}

    {% set vpc_image_padding_x = theme.settings.get('veloura_product_card_image_padding_x_2026', '0') %}
    {% if vpc_image_padding_x.value is defined %}
      {% set vpc_image_padding_x = vpc_image_padding_x.value %}
    {% endif %}

    {% set vpc_image_outside_raw = theme.settings.get('veloura_product_card_image_outside_2026', false) %}
    {% if vpc_image_outside_raw.value is defined %}
      {% set vpc_image_outside_raw = vpc_image_outside_raw.value %}
    {% elseif vpc_image_outside_raw.selected is defined %}
      {% set vpc_image_outside_raw = vpc_image_outside_raw.selected %}
    {% endif %}

    {% set vpc_image_outside =
      vpc_image_outside_raw == true
      or vpc_image_outside_raw == 'true'
      or vpc_image_outside_raw == 1
      or vpc_image_outside_raw == '1'
      or vpc_image_outside_raw == 'on'
    %}

    {% set vpc_image_outside_offset_raw = theme.settings.get('veloura_product_card_image_outside_offset_2026', '20') %}
    {% if vpc_image_outside_offset_raw.value is defined %}
      {% set vpc_image_outside_offset_raw = vpc_image_outside_offset_raw.value %}
    {% endif %}

    {% set vpc_image_outside_offset_value = vpc_image_outside_offset_raw + 0 %}
    {% if vpc_image_outside_offset_value < 0 %}
      {% set vpc_image_outside_offset_value = 0 %}
    {% endif %}
    {% if vpc_image_outside_offset_value > 60 %}
      {% set vpc_image_outside_offset_value = 60 %}
    {% endif %}
    {% set vpc_image_outside_offset = vpc_image_outside_offset_value %}

    {# النصوص #}
    {% set vpc_center_text_raw = theme.settings.get('veloura_product_card_center_text_2026', false) %}
    {% if vpc_center_text_raw.value is defined %}
      {% set vpc_center_text_raw = vpc_center_text_raw.value %}
    {% elseif vpc_center_text_raw.selected is defined %}
      {% set vpc_center_text_raw = vpc_center_text_raw.selected %}
    {% endif %}

    {% set vpc_center_text =
      vpc_center_text_raw == true
      or vpc_center_text_raw == 'true'
      or vpc_center_text_raw == 1
      or vpc_center_text_raw == '1'
      or vpc_center_text_raw == 'on'
    %}

    {% set vpc_title_size_map = {
      'xs': '12px',
      'small': '13px',
      'medium': '15px',
      'large': '17px',
      'xl': '19px'
    } %}

    {% set vpc_price_size_map = {
      'small': '13px',
      'normal': '15px',
      'medium': '17px',
      'large': '19px',
      'xl': '22px'
    } %}

    {% set vpc_title_size_raw = theme.settings.get('veloura_product_card_title_size_2026', 'medium') %}
    {% if vpc_title_size_raw is iterable and vpc_title_size_raw[0].value is defined %}
      {% set vpc_title_size_key = vpc_title_size_raw[0].value %}
    {% elseif vpc_title_size_raw.value is defined %}
      {% set vpc_title_size_key = vpc_title_size_raw.value %}
    {% else %}
      {% set vpc_title_size_key = vpc_title_size_raw %}
    {% endif %}

    {% set vpc_price_size_raw = theme.settings.get('veloura_product_card_price_size_2026', 'normal') %}
    {% if vpc_price_size_raw is iterable and vpc_price_size_raw[0].value is defined %}
      {% set vpc_price_size_key = vpc_price_size_raw[0].value %}
    {% elseif vpc_price_size_raw.value is defined %}
      {% set vpc_price_size_key = vpc_price_size_raw.value %}
    {% else %}
      {% set vpc_price_size_key = vpc_price_size_raw %}
    {% endif %}

    {% set vpc_title_one_line_raw = theme.settings.get('veloura_product_card_title_one_line_2026', false) %}
    {% if vpc_title_one_line_raw.value is defined %}
      {% set vpc_title_one_line_raw = vpc_title_one_line_raw.value %}
    {% elseif vpc_title_one_line_raw.selected is defined %}
      {% set vpc_title_one_line_raw = vpc_title_one_line_raw.selected %}
    {% endif %}

    {% set vpc_title_one_line =
      vpc_title_one_line_raw == true
      or vpc_title_one_line_raw == 'true'
      or vpc_title_one_line_raw == 1
      or vpc_title_one_line_raw == '1'
      or vpc_title_one_line_raw == 'on'
    %}

    {% set vpc_title_two_lines_raw = theme.settings.get('veloura_product_card_title_two_lines_2026', true) %}
    {% if vpc_title_two_lines_raw.value is defined %}
      {% set vpc_title_two_lines_raw = vpc_title_two_lines_raw.value %}
    {% elseif vpc_title_two_lines_raw.selected is defined %}
      {% set vpc_title_two_lines_raw = vpc_title_two_lines_raw.selected %}
    {% endif %}

    {% set vpc_title_two_lines =
      vpc_title_two_lines_raw == true
      or vpc_title_two_lines_raw == 'true'
      or vpc_title_two_lines_raw == 1
      or vpc_title_two_lines_raw == '1'
      or vpc_title_two_lines_raw == 'on'
    %}

    {# زر أضف للسلة #}
    {% set vpc_button_radius_raw = theme.settings.get('veloura_product_card_button_radius_2026', 'medium') %}
    {% if vpc_button_radius_raw is iterable and vpc_button_radius_raw[0].value is defined %}
      {% set vpc_button_radius_key = vpc_button_radius_raw[0].value %}
    {% elseif vpc_button_radius_raw.value is defined %}
      {% set vpc_button_radius_key = vpc_button_radius_raw.value %}
    {% else %}
      {% set vpc_button_radius_key = vpc_button_radius_raw %}
    {% endif %}

    {% set vpc_button_margin_x = theme.settings.get('veloura_product_card_button_margin_x_2026', '0') %}
    {% if vpc_button_margin_x.value is defined %}
      {% set vpc_button_margin_x = vpc_button_margin_x.value %}
    {% endif %}

    {% set vpc_button_margin_bottom = theme.settings.get('veloura_product_card_button_margin_bottom_2026', '0') %}
    {% if vpc_button_margin_bottom.value is defined %}
      {% set vpc_button_margin_bottom = vpc_button_margin_bottom.value %}
    {% endif %}

    {# القيمة الفعلية = 32 + قيمة السلايدر #}
    {% set vpc_button_height_raw = theme.settings.get('veloura_product_card_button_height_2026', '10') %}
    {% if vpc_button_height_raw.value is defined %}
      {% set vpc_button_height_raw = vpc_button_height_raw.value %}
    {% endif %}
    {% set vpc_button_height_value = vpc_button_height_raw + 0 %}
    {% if vpc_button_height_value < 0 %}
      {% set vpc_button_height_value = 0 %}
    {% endif %}
    {% if vpc_button_height_value > 38 %}
      {% set vpc_button_height_value = 38 %}
    {% endif %}
    {% set vpc_button_height = 32 + vpc_button_height_value %}

    {% set vpc_button_bg_color = theme.settings.get('veloura_product_card_button_bg_color_2026', '#004d65') %}
    {% if vpc_button_bg_color.value is defined %}
      {% set vpc_button_bg_color = vpc_button_bg_color.value %}
