{% if theme.settings.get('veloura_dark_toggle_enabled_2026') %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const buttons = document.querySelectorAll('.veloura-dark-toggle');
  const logos = document.querySelectorAll('.veloura-store-logo');

  function isDarkMode() {
    return document.body.classList.contains('dark');
  }

  function updateLogo() {
    logos.forEach((logo) => {
      const lightLogo = logo.dataset.lightLogo;
      const darkLogo = logo.dataset.darkLogo;

      if (isDarkMode() && darkLogo) {
        logo.src = darkLogo;
      } else if (lightLogo) {
        logo.src = lightLogo;
      }
    });
  }

  function updateDarkIcons() {
    document.querySelectorAll('.veloura-dark-toggle__icon').forEach((icon) => {
      icon.classList.remove('sicon-moon', 'sicon-sun');
      icon.classList.add(isDarkMode() ? 'sicon-sun' : 'sicon-moon');
    });
  }

  function updateDarkModeUI() {
    updateLogo();
    updateDarkIcons();
  }

  const savedMode = localStorage.getItem('veloura_dark_mode');

  if (savedMode === 'dark') {
    document.body.classList.add('dark');
  }

  if (savedMode === 'light') {
    document.body.classList.remove('dark');
  }

  updateDarkModeUI();

  buttons.forEach((btn) => {
    btn.addEventListener('click', function () {
      document.body.classList.toggle('dark');

      localStorage.setItem(
        'veloura_dark_mode',
        document.body.classList.contains('dark') ? 'dark' : 'light'
      );

      updateDarkModeUI();
    });
  });
});
</script>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', function () {
  const header = document.querySelector('.store-header');
  if (!header) return;

  let lastScroll = window.scrollY;

  window.addEventListener('scroll', function () {
    const currentScroll = window.scrollY;

    if (currentScroll > 120) {
      header.classList.add('veloura-top-scrolled');
    } else {
      header.classList.remove('veloura-top-scrolled');
    }

    if (header.classList.contains('veloura-hide-top-on-scroll')) {
      if (currentScroll > lastScroll && currentScroll > 120) {
        header.classList.add('veloura-top-hidden');
      } else {
        header.classList.remove('veloura-top-hidden');
      }
    }

    lastScroll = currentScroll;
  });
});
</script>

