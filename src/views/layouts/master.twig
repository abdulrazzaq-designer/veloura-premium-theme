    {% set vpc_button_text_color = theme.settings.get('veloura_product_card_button_text_color_2026', '#ffffff') %}
    {% if vpc_button_text_color.value is defined %}
      {% set vpc_button_text_color = vpc_button_text_color.value %}
    {% endif %}

    {# ================================
   Veloura Quick View Settings 2026
   إعدادات العرض السريع داخل بطاقة المنتج
================================ #}

