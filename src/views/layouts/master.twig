  or vqv_show_icon_raw == 'on'
%}

{% set vqv_icon_raw = theme.settings.get('veloura_quick_view_icon_2026', 'sicon-eye') %}
{% if vqv_icon_raw is iterable and vqv_icon_raw[0].value is defined %}
  {% set vqv_icon = vqv_icon_raw[0].value %}
{% elseif vqv_icon_raw.value is defined %}
  {% set vqv_icon = vqv_icon_raw.value %}
{% else %}
