<section class="container">
  <div style="background:#111;color:#fff;padding:40px">
    <h2>{{ title }}</h2>

    {% for item in items %}
      <div style="background:red;color:white;padding:20px;margin:15px 0">
        <p>TEXT: {{ item.text }}</p>
        <p>URL: {{ item.url }}</p>
      </div>
    {% endfor %}
  </div>
</section>