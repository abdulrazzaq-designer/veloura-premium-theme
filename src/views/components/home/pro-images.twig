<section class="container">
    <h2>{{ title }}</h2>

    {% for item in items %}
        <div style="background:red;color:white;padding:20px;margin:10px 0">
            TEXT: {{ item.text }}

            <br>

            IMAGE:
            {{ item.image.url }}

            <br>

            URL:
            {{ item.url }}
        </div>
    {% endfor %}
</section>