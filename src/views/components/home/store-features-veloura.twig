{% if not component.veloura_hide_section %}

<section class="s-block veloura-store-features {{ component.veloura_custom_classes ?: '' }}">

    <div class="container">

        {% if component.veloura_section_title or component.veloura_section_subtitle %}
            <div class="veloura-store-features__heading">

                {% if component.veloura_section_title %}
                    <h2>{{ component.veloura_section_title }}</h2>
                {% endif %}

                {% if component.veloura_section_subtitle %}
                    <p>{{ component.veloura_section_subtitle }}</p>
                {% endif %}

            </div>
        {% endif %}

        <div
            class="veloura-store-features__grid"
            style="
                --veloura-gap: {{ component.veloura_gap_between_features|default(16) }}px;
                --veloura-mobile-cols: {{ component.veloura_mobile_columns|default(2) }};
                --veloura-desktop-cols: {{ component.veloura_desktop_columns|default(4) }};
            "
        >

            {% for item in component.veloura_features_collection %}

                {% set feature_bg =
                    item.veloura_feature_background_transparent
                    ? 'transparent'
                    : item.veloura_feature_background
                %}

                {% set icon_bg =
                    item.veloura_feature_icon_background_transparent
                    ? 'transparent'
                    : item.veloura_feature_icon_background
                %}

                <div
                    class="veloura-store-features__item
                    {{ component.veloura_center_features ? 'is-centered' : '' }}
                    {{ component.veloura_icons_on_top ? 'has-floating-icon' : '' }}"
                    style="
                        background: {{ feature_bg }};
                        color: {{ item.veloura_feature_text_color }};
                    "
                >

                    <div
                        class="veloura-store-features__icon"
                        style="
                            background: {{ icon_bg }};
                            color: {{ item.veloura_feature_icon_color }};
                        "
                    >

                        {% if item.veloura_feature_image %}
                            <img
                                src="{{ item.veloura_feature_image }}"
                                alt="{{ item.veloura_feature_title }}"
                                loading="lazy"
                                width="{{ component.veloura_feature_image_width }}"
                                height="{{ component.veloura_feature_image_height }}"
                            >
                        {% elseif item.veloura_feature_icon %}
                            <i class="{{ item.veloura_feature_icon }}"></i>
                        {% endif %}

                    </div>

                    <div class="veloura-store-features__content">

                        {% if item.veloura_feature_title %}
                            <h3>
                                {{ item.veloura_feature_title }}
                            </h3>
                        {% endif %}

                        {% if item.veloura_feature_subtitle %}
                            <p>
                                {{ item.veloura_feature_subtitle }}
                            </p>
                        {% endif %}

                    </div>

                </div>

            {% endfor %}

        </div>

    </div>

</section>

{% endif %}