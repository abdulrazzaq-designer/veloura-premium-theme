<section class="s-block container animated-banners-test" style="padding:40px;background:#eee;">
  <h2>اختبار البنرات المتحركة</h2>

  {% if component.animated_banners %}
    <p>عدد البنرات موجود ✅</p>

    {% for banner in component.animated_banners %}
      <div style="margin:20px 0;padding:20px;background:#fff;">
        <p>بنر رقم {{ loop.index }}</p>

        {% set image_src = banner.banner_image %}

        {% if banner.use_image_url and banner.image_url %}
          {% set image_src = banner.image_url %}
        {% endif %}

        {% if image_src %}
          <img src="{{ image_src }}" style="max-width:100%;height:auto;display:block;">
        {% else %}
          <strong style="color:red;">لا توجد صورة لهذا البنر</strong>
        {% endif %}

        {% if banner.banner_title %}
          <h3>{{ banner.banner_title }}</h3>
        {% endif %}

        {% if banner.banner_subtitle %}
          <p>{{ banner.banner_subtitle }}</p>
        {% endif %}
      </div>
    {% endfor %}
  {% else %}
    <strong style="color:red;">لا توجد بيانات animated_banners</strong>
  {% endif %}
</section>