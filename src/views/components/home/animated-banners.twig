{% set radius_map = {
  'sharp': '0px',
  'soft': '8px',
  'medium': '16px',
  'large': '28px',
  'round': '999px'
} %}

{% set h_spacing = component.h_spacing|default(0) %}
{% if h_spacing < 12 %}
  {% set h_spacing = 12 %}
{% endif %}

{% set h_spacing = component.use_h_spacing ? component.h_spacing|default(0) : 0 %}

<section
  class="s-block animated-banners {{ not component.animated_full_width ? 'container' : '' }} {{ component.animated_full_width ? 'is-full-width-desktop' : '' }}"
  style="
    --banner-margin: {{ h_spacing }}px;
    --animated-radius: {{ radius_map[component.animated_image_radius|default('sharp')]|default('0px') }};
  "
>
  {% if component.animated_banners|length > 0 %}
   <salla-slider
  class="animated-banners__slider"
  id="animated-banners-{{ position }}"
  show-controls="false"
  {% if component.animated_autoplay %}auto-play{% endif %}
  {% if not component.animated_hide_dots %}pagination{% endif %}
  static-when-single
>

      <div slot="items">
        {% for banner in component.animated_banners %}
          {% set image_src = banner.banner_image %}
          {% if banner.use_image_url and banner.image_url %}
            {% set image_src = banner.image_url %}
          {% endif %}
          {% set mobile_image = banner.banner_image_mobile ?: image_src %}
          {% if banner.use_mobile_image_url and banner.mobile_image_url %}
            {% set mobile_image = banner.mobile_image_url %}
          {% endif %}
          {% set banner_link = banner.url ?: '#' %}

          {% if image_src %}
            <div class="swiper-slide animated-banners__slide">
              <a href="{{ banner_link }}" class="animated-banners__card">
                <picture>
                  <source media="(max-width: 767px)" srcset="{{ mobile_image }}">
                  <img src="{{ image_src }}" alt="{{ banner.banner_title ?: 'banner' }}" loading="lazy">
                </picture>

                <div class="animated-banners__content {{ banner.text_center ? 'is-center' : 'is-right' }}">
                  {% if banner.banner_title %}
                    <h2 style="color: {{ banner.banner_title_color|default('#ffffff') }};">
                      {{ banner.banner_title|raw }}
                    </h2>
                  {% endif %}
                  {% if banner.banner_subtitle %}
                    <p style="color: {{ banner.banner_subtitle_color|default('#ffffff') }};">
                      {{ banner.banner_subtitle|raw }}
                    </p>
                  {% endif %}
                  {% if banner.discount_enable and banner.discount_end_date %}
  <div class="animated-banners__countdown" data-countdown="{{ banner.discount_end_date }}">
    <div><strong data-days>0</strong><span>يوم</span></div>
    <div><strong data-hours>0</strong><span>ساعة</span></div>
    <div><strong data-minutes>0</strong><span>دقيقة</span></div>
    <div><strong data-seconds>0</strong><span>ثانية</span></div>
  </div>
{% endif %}

                  {% if banner.button_text %}
                    <span class="
                      animated-banners__button
                      {{ banner.button_no_bg ? 'is-outline' : '' }}
                      {{ banner.button_rounded ? 'is-rounded' : '' }}
                      {{ banner.button_icon_reverse ? 'is-reverse' : '' }}
                    ">
                      {% if not banner.button_hide_icon %}
                        <i class="{{ banner.button_icon|default('sicon-arrow-left') }}"></i>
                      {% endif %}
                      {{ banner.button_text }}
                    </span>
                  {% endif %}
                </div>

                {% if banner.discount.enable and banner.discount.end_date %}
                  <div class="animated-banners__discount">
                    {{ banner.discount.end_date }}
                  </div>
                {% endif %}
              </a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </salla-slider>
  {% endif %}
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('[data-countdown]').forEach(function(timer) {
    let dateString = timer.getAttribute('data-countdown').replaceAll('"', '').trim();

    let parts = dateString.split('-');

    let day = parseInt(parts[0], 10);
    let month = parseInt(parts[1], 10) - 1;
    let year = parseInt(parts[2], 10);

    let endDate = new Date(year, month, day, 23, 59, 59).getTime();

    function updateTimer() {
      let now = new Date().getTime();
      let distance = endDate - now;

      if (distance <= 0 || isNaN(distance)) {
        timer.style.display = 'none';
        return;
      }

      timer.querySelector('[data-days]').textContent = Math.floor(distance / (1000 * 60 * 60 * 24));
      timer.querySelector('[data-hours]').textContent = Math.floor((distance / (1000 * 60 * 60)) % 24);
      timer.querySelector('[data-minutes]').textContent = Math.floor((distance / (1000 * 60)) % 60);
      timer.querySelector('[data-seconds]').textContent = Math.floor((distance / 1000) % 60);
    }

    updateTimer();
    setInterval(updateTimer, 1000);
  });
});
</script>