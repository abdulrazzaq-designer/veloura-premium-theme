{% set radius_map = {
  'sharp': '0px',
  'soft': '8px',
  'medium': '16px',
  'large': '28px',
  'round': '999px'
} %}

{% set title_size_map = {
  'xs': '12px',
  'sm': '14px',
  'md': '18px',
  'lg': '22px',
  'xl': '28px',
  'xxl': '36px'
} %}

{% if not component.ultra_hide_section %}
<section
  class="s-block ultra-square-images
    {{ component.ultra_custom_classes }}
    {{ component.ultra_display_grid ? 'is-grid' : 'is-slider' }}
  "
  style="
    --ultra-gap: {{ component.ultra_images_gap|default(16) }}px;
    --ultra-radius: {{ radius_map[component.ultra_image_radius|default('medium')]|default('16px') }};
    padding-inline: {{ component.ultra_custom_horizontal_spacing ? component.ultra_horizontal_spacing|default(0) ~ 'px' : '0px' }};
  "
>
  <div class="container">
    {% if component.ultra_section_title or component.ultra_section_subtitle %}
      <div class="ultra-square-images__heading">
        {% if component.ultra_section_title %}
          <h2>{{ component.ultra_section_title }}</h2>
        {% endif %}

        {% if component.ultra_section_subtitle %}
          <p>{{ component.ultra_section_subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ultra-square-images__grid">
      {% for banner in component.ultra_banners %}
        {% set image_src = banner.image %}

        {% if banner.image_url %}
          {% set image_src = banner.image_url %}
        {% endif %}

        {% if image_src %}
          <div class="ultra-square-images__item">
            <a href="{{ banner.url ?: '#' }}" class="ultra-square-images__card">
              <img
                src="{{ image_src }}"
                alt="{{ banner.title ?: 'image' }}"
                loading="lazy"
              >

              {% if component.ultra_text_on_image and (banner.title or banner.description) %}
                <div class="ultra-square-images__content is-on-image {{ component.ultra_title_overlay ? 'has-overlay' : '' }}">
                  {% if banner.title %}
                    <h3 style="font-size: {{ title_size_map[component.ultra_title_size|default('md')]|default('18px') }};">
                      {{ banner.title|raw }}
                    </h3>
                  {% endif %}

                  {% if banner.description %}
                    <p>{{ banner.description|raw }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </a>

            {% if not component.ultra_text_on_image and (banner.title or banner.description) %}
              <div class="ultra-square-images__content is-below-image">
                {% if banner.title %}
                  <h3 style="font-size: {{ title_size_map[component.ultra_title_size|default('md')]|default('18px') }};">
                    {{ banner.title|raw }}
                  </h3>
                {% endif %}

                {% if banner.description %}
                  <p>{{ banner.description|raw }}</p>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}