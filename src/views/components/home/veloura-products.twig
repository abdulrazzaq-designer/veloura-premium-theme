{% set raw_source = component.veloura_products_source ?: 'latest' %}
{% set source_value = null %}

{% if raw_source in ['latest_products', 'latest'] %}
  {% set slider_source = 'latest_products' %}
  {% set list_source = 'latest' %}
{% elseif raw_source in ['chosen_products', 'selected'] %}
  {% set slider_source = 'selected' %}
  {% set list_source = 'selected' %}
  {% set source_value = component.veloura_products_chosen %}
{% elseif raw_source in ['category', 'categories'] %}
  {% set slider_source = 'categories' %}
  {% set list_source = 'categories' %}
  {% set source_value = component.veloura_products_category %}
{% elseif raw_source in ['most_sales', 'sales'] %}
  {% set slider_source = 'sales' %}
  {% set list_source = 'sales' %}
{% elseif raw_source == 'offers' %}
  {% set slider_source = 'offers' %}
  {% set list_source = 'offers' %}
{% else %}
  {% set slider_source = raw_source %}
  {% set list_source = raw_source %}
{% endif %}
<section
  class="s-block container veloura-products
  {{ component.veloura_products_grid_mode ? 'as-grid' : 'as-slider' }}
  {{ component.veloura_products_center_titles ? 'is-centered' : '' }}"
  style="
    --mob-products-cols: {{ component.veloura_products_mobile_cols ?: 2 }};
    --products-cols: {{ component.veloura_products_desktop_cols ?: 4 }};
  "
>

  {% if component.veloura_products_title or component.veloura_products_subtitle or component.veloura_products_show_button %}
    <div class="veloura-products__heading">
  <div class="veloura-products__heading-content">
    {% if component.veloura_products_title_icon %}
      <img src="{{ component.veloura_products_title_icon }}" class="veloura-products__icon" alt="">
    {% endif %}

    <div class="veloura-products__texts">
      {% if component.veloura_products_title %}
        <h2>{{ component.veloura_products_title }}</h2>
      {% endif %}

      {% if component.veloura_products_subtitle %}
        <p>{{ component.veloura_products_subtitle|raw }}</p>
      {% endif %}
    </div>
  </div>

  {% if component.veloura_products_show_button and component.veloura_products_button_link %}
    <a href="{{ component.veloura_products_button_link }}" class="veloura-products__button">
      {{ component.veloura_products_button_text ?: 'عرض الكل' }}
      <i class="sicon-arrow-left"></i>
    </a>
  {% endif %}
</div>
  {% endif %}

  {% if component.veloura_products_grid_mode %}
    <salla-products-list
  source="{{ list_source }}"
  limit="{{ component.veloura_products_limit ?: 10 }}"
  source-value="{{ source_value|json_encode }}"
  includes="[]"
></salla-products-list>
  {% else %}
    <salla-products-slider
  source="{{ slider_source }}"
  limit="{{ component.veloura_products_limit ?: 10 }}"
  autoplay
  source-value="{{ source_value|json_encode }}"
  display-all-url=""
  block-title=""
  block-subTitle=""
  slider-id="veloura-products-{{ position }}"
></salla-products-slider>
  {% endif %}

</section>

<pre style="direction:ltr;text-align:left;background:#fff;padding:15px">
raw_source: {{ raw_source }}
slider_source: {{ slider_source }}
list_source: {{ list_source }}
source_value: {{ source_value|json_encode }}
category: {{ component.veloura_products_category|json_encode }}
chosen: {{ component.veloura_products_chosen|json_encode }}
</pre>