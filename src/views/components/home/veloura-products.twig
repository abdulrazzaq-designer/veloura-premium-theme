{% set source_value = null %}
{% set slider_source = component.veloura_products_source ?: 'latest_products' %}
{% set list_source = slider_source == 'latest_products' ? 'latest' : slider_source %}

{% if slider_source == 'chosen_products' %}
  {% set source_value = component.veloura_products_chosen %}
{% elseif slider_source == 'category' %}
  {% set source_value = component.veloura_products_category %}
{% elseif slider_source == 'tag' %}
  {% set source_value = component.veloura_products_tag %}
{% endif %}

<section
  class="s-block container veloura-products {{ component.veloura_products_grid_mode ? 'as-grid' : 'as-slider' }}"
  style="
    --mob-products-cols: {{ component.veloura_products_mobile_cols ?: 2 }};
    --products-cols: {{ component.veloura_products_desktop_cols ?: 4 }};
  "
>

  {% if component.veloura_products_title or component.veloura_products_subtitle or component.veloura_products_show_button %}
    <div class="s-block__title veloura-products__title">

      <div class="right-side">

        {% if component.veloura_products_title_icon %}
          <img
            src="{{ component.veloura_products_title_icon }}"
            class="veloura-products__icon"
            alt=""
          >
        {% endif %}

        {% if component.veloura_products_title %}
          <h2>{{ component.veloura_products_title }}</h2>
        {% endif %}

        {% if component.veloura_products_subtitle %}
          <p>{{ component.veloura_products_subtitle|raw }}</p>
        {% endif %}

      </div>

      {% if component.veloura_products_show_button and component.veloura_products_button_link %}
        <a
          href="{{ component.veloura_products_button_link }}"
          class="s-block__display-all"
        >
          {{ component.veloura_products_button_text ?: 'عرض الكل' }}
          <i class="sicon-arrow-left"></i>
        </a>
      {% endif %}

    </div>
  {% endif %}

  {% if component.veloura_products_grid_mode %}

    <salla-products-list
      source="{{ list_source }}"
      limit="{{ component.veloura_products_limit ?: 10 }}"
      source-value="{{ source_value|json_encode }}"
      includes="[]"
    ></salla-products-list>

  {% else %}

    <salla-products-slider
      source="{{ slider_source }}"
      limit="{{ component.veloura_products_limit ?: 10 }}"
      source-value="{{ source_value|json_encode }}"
      display-all-url="{{ component.veloura_products_show_button ? component.veloura_products_button_link : '' }}"
      block-title="{{ component.veloura_products_title }}"
      block-subTitle="{{ component.veloura_products_subtitle|raw }}"
      slider-id="veloura-products-{{ position }}"
      autoplay
    ></salla-products-slider>

  {% endif %}

</section>