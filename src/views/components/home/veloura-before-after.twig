{% if not component.veloura_before_after_hide %}

  {% set radius_map = {
    'sharp': '0px',
    'soft': '8px',
    'medium': '16px',
    'large': '28px',
    'round': '40px'
  } %}

  {% set ratio_map = {
  'auto': 'auto',
  '1-1': '1 / 1',
  '4-3': '4 / 3',
  '16-9': '16 / 9',
  '21-9': '21 / 9'
} %}

  {% set before_after_radius = radius_map[component.veloura_before_after_radius|default('medium')]|default('16px') %}
  {% set before_after_ratio = ratio_map[component.veloura_before_after_ratio|default('auto')]|default('auto') %}

  {% set section_classes = [
    's-block',
    'veloura-before-after',
    component.veloura_before_after_full_width ? 'veloura-before-after--full-width' : '',
    component.veloura_before_after_shadow ? 'veloura-before-after--shadow' : '',
    component.veloura_before_after_mobile_only ? 'veloura-before-after--mobile-only' : '',
    component.veloura_before_after_desktop_only ? 'veloura-before-after--desktop-only' : '',
    component.veloura_before_after_custom_classes ?: ''
  ]|join(' ') %}

  <section
    class="{{ section_classes }}"
    style="
      --veloura-before-after-radius: {{ before_after_radius }};
      --veloura-before-after-ratio: {{ before_after_ratio }};
      --veloura-before-after-spacing: {{ component.veloura_before_after_custom_spacing ? component.veloura_before_after_spacing|default(0) : 0 }}px;
    "
  >
    <div class="{{ component.veloura_before_after_full_width ? 'veloura-before-after__container' : 'container veloura-before-after__container' }}">

      {% if component.veloura_before_after_title or component.veloura_before_after_subtitle %}
        <div class="veloura-before-after__heading">
          {% if component.veloura_before_after_title %}
            <h2>{{ component.veloura_before_after_title }}</h2>
          {% endif %}

          {% if component.veloura_before_after_subtitle %}
            <p>{{ component.veloura_before_after_subtitle }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if component.veloura_before_after_before_image and component.veloura_before_after_after_image %}
        <div
          class="veloura-before-after__compare"
          data-auto-play="{{ component.veloura_before_after_auto_play ? 'true' : 'false' }}"
          data-start="50"
        >
          <img
            class="veloura-before-after__img veloura-before-after__img--before"
            src="{{ component.veloura_before_after_before_image }}"
            alt="{{ component.veloura_before_after_before_label|default('قبل') }}"
            loading="lazy"
          >

          <div class="veloura-before-after__after-wrap">
            <img
              class="veloura-before-after__img veloura-before-after__img--after"
              src="{{ component.veloura_before_after_after_image }}"
              alt="{{ component.veloura_before_after_after_label|default('بعد') }}"
              loading="lazy"
            >
          </div>

          <input
            class="veloura-before-after__range"
            type="range"
            min="0"
            max="100"
            value="50"
            aria-label="Before after slider"
          >

          <div class="veloura-before-after__line"></div>

          <button class="veloura-before-after__handle" type="button" aria-label="Before after handle">
            <i class="sicon-keyboard_arrow_left"></i>
            <i class="sicon-keyboard_arrow_right"></i>
          </button>

          <span class="veloura-before-after__label veloura-before-after__label--before">
            {{ component.veloura_before_after_before_label|default('قبل') }}
          </span>

          <span class="veloura-before-after__label veloura-before-after__label--after">
            {{ component.veloura_before_after_after_label|default('بعد') }}
          </span>
        </div>
      {% endif %}

    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const sections = document.querySelectorAll('.veloura-before-after__compare');

      sections.forEach(function (compare) {
        const range = compare.querySelector('.veloura-before-after__range');
        const afterWrap = compare.querySelector('.veloura-before-after__after-wrap');
        const line = compare.querySelector('.veloura-before-after__line');
        const handle = compare.querySelector('.veloura-before-after__handle');

        if (!range || !afterWrap || !line || !handle) return;

        function setPosition(value) {
          afterWrap.style.clipPath = 'inset(0 0 0 ' + value + '%)';
          line.style.left = value + '%';
          handle.style.left = value + '%';
          range.value = value;
        }

        setPosition(range.value || 50);

        range.addEventListener('input', function () {
          setPosition(range.value);
        });

        const autoPlay = compare.getAttribute('data-auto-play') === 'true';

        if (autoPlay) {
          let played = false;

          const observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting && !played) {
                played = true;

                let value = 50;
                let direction = 1;

                const interval = setInterval(function () {
                  value += direction * 2;

                  if (value >= 78) {
                    direction = -1;
                  }

                  if (value <= 22) {
                    direction = 1;
                  }

                  setPosition(value);

                  if (value === 50 && direction === 1) {
                    clearInterval(interval);
                  }
                }, 24);

                observer.disconnect();
              }
            });
          }, {
            threshold: 0.35
          });

          observer.observe(compare);
        }
      });
    });
  </script>

{% endif %}