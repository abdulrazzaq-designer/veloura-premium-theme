{# ==========================================
   Veloura Cart Banners 2026 - Collection Version
   الملف: views/components/cart-banners/cart-banners.twig
   يعتمد على collection واحدة: veloura_cart_banners_collection_2026
========================================== #}

{% set vcb_enable_raw = theme.settings.get('veloura_cart_banners_enable_2026', false) %}
{% if vcb_enable_raw.value is defined %}
  {% set vcb_enable_raw = vcb_enable_raw.value %}
{% elseif vcb_enable_raw.selected is defined %}
  {% set vcb_enable_raw = vcb_enable_raw.selected %}
{% endif %}
{% set vcb_enable =
  vcb_enable_raw == true
  or vcb_enable_raw == 'true'
  or vcb_enable_raw == 1
  or vcb_enable_raw == '1'
  or vcb_enable_raw == 'on'
%}

{% set vcb_title = theme.settings.get('veloura_cart_banners_section_title_2026', 'عروض خاصة لك') %}
{% if vcb_title.value is defined %}
  {% set vcb_title = vcb_title.value %}
{% endif %}

{% set vcb_radius = theme.settings.get('veloura_cart_banners_radius_2026', 18) %}
{% if vcb_radius.value is defined %}
  {% set vcb_radius = vcb_radius.value %}
{% endif %}
{% set vcb_radius = vcb_radius + 0 %}
{% if vcb_radius < 0 %}{% set vcb_radius = 0 %}{% endif %}
{% if vcb_radius > 60 %}{% set vcb_radius = 60 %}{% endif %}

{% set vcb_gap = theme.settings.get('veloura_cart_banners_gap_2026', 14) %}
{% if vcb_gap.value is defined %}
  {% set vcb_gap = vcb_gap.value %}
{% endif %}
{% set vcb_gap = vcb_gap + 0 %}
{% if vcb_gap < 0 %}{% set vcb_gap = 0 %}{% endif %}
{% if vcb_gap > 40 %}{% set vcb_gap = 40 %}{% endif %}

{# قراءة الكولكشن بأكثر من شكل حتى لا تكسر الصفحة #}
{% set vcb_collection_raw = theme.settings.get('veloura_cart_banners_collection_2026', []) %}
{% if vcb_collection_raw.value is defined %}
  {% set vcb_collection_raw = vcb_collection_raw.value %}
{% elseif vcb_collection_raw.selected is defined %}
  {% set vcb_collection_raw = vcb_collection_raw.selected %}
{% elseif vcb_collection_raw.items is defined %}
  {% set vcb_collection_raw = vcb_collection_raw.items %}
{% elseif vcb_collection_raw.data is defined %}
  {% set vcb_collection_raw = vcb_collection_raw.data %}
{% endif %}

{% set vcb_banners = [] %}
{% if vcb_collection_raw is iterable %}
  {% for item in vcb_collection_raw %}
    {% set banner = item %}
    {% if banner.value is defined and banner.value is iterable %}
      {% set banner = banner.value %}
    {% endif %}

    {% set img = '' %}
    {% if banner.banner_image is defined %}{% set img = banner.banner_image %}{% endif %}
    {% if not img and banner.image is defined %}{% set img = banner.image %}{% endif %}
    {% if not img and banner.img is defined %}{% set img = banner.img %}{% endif %}
    {% if not img and banner.photo is defined %}{% set img = banner.photo %}{% endif %}
    {% if not img and banner.url_image is defined %}{% set img = banner.url_image %}{% endif %}

    {% if img.value is defined %}{% set img = img.value %}{% endif %}
    {% if img.url is defined %}{% set img = img.url %}{% endif %}
    {% if img.src is defined %}{% set img = img.src %}{% endif %}
    {% if img.path is defined %}{% set img = img.path %}{% endif %}
    {% if img.cdn is defined %}{% set img = img.cdn %}{% endif %}
    {% if img[0].url is defined %}{% set img = img[0].url %}{% endif %}
    {% if img[0].src is defined %}{% set img = img[0].src %}{% endif %}

    {% set link = '' %}
    {% if banner.banner_url is defined %}{% set link = banner.banner_url %}{% endif %}
    {% if not link and banner.url is defined %}{% set link = banner.url %}{% endif %}
    {% if not link and banner.link is defined %}{% set link = banner.link %}{% endif %}
    {% if not link and banner.href is defined %}{% set link = banner.href %}{% endif %}
    {% if link.value is defined %}{% set link = link.value %}{% endif %}

    {% if img %}
      {% set vcb_banners = vcb_banners|merge([{'img': img, 'link': link}]) %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if vcb_enable and vcb_banners|length %}
  <section class="veloura-cart-banners-section" aria-label="{{ vcb_title }}">
    <style>
      .veloura-cart-banners-section {
        margin: 0 0 24px;
      }

      .veloura-cart-banners-title {
        margin: 0 0 14px;
        font-size: 18px;
        line-height: 1.5;
        font-weight: 900;
        color: #111827;
      }

      .veloura-cart-banners-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: {{ vcb_gap }}px;
      }

      .veloura-cart-banner {
        display: block;
        overflow: hidden;
        border-radius: {{ vcb_radius }}px;
        background: #f8fafc;
        box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
        line-height: 0;
      }

      .veloura-cart-banner img {
        display: block;
        width: 100%;
        height: auto;
        min-height: 90px;
        object-fit: cover;
        border-radius: inherit;
      }

      @media (max-width: 767px) {
        .veloura-cart-banners-section {
          margin-bottom: 20px;
        }

        .veloura-cart-banners-title {
          font-size: 16px;
          margin-bottom: 12px;
        }

        .veloura-cart-banners-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    {% if vcb_title %}
      <h2 class="veloura-cart-banners-title">{{ vcb_title }}</h2>
    {% endif %}

    <div class="veloura-cart-banners-grid">
      {% for banner in vcb_banners %}
        {% if banner.link %}
          <a class="veloura-cart-banner" href="{{ banner.link }}">
            <img src="{{ banner.img }}" alt="{{ vcb_title }}" loading="lazy">
          </a>
        {% else %}
          <div class="veloura-cart-banner">
            <img src="{{ banner.img }}" alt="{{ vcb_title }}" loading="lazy">
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>
{% endif %}
