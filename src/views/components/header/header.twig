{% set top_enabled = true %}

{# Logo #}
{% set light_logo_url = theme.settings.get('veloura_light_logo_url_2026') %}
{% set light_logo_image = theme.settings.get('veloura_light_logo_2026') %}
{% set veloura_light_logo = light_logo_url ?: light_logo_image %}

{% set top_logo_url = theme.settings.get('veloura_top_logo_url_2026') %}
{% set top_logo_image = theme.settings.get('veloura_top_logo_image_2026') %}
{% set top_logo = top_logo_url ?: top_logo_image ?: veloura_light_logo ?: store.logo|cdn(175) %}

{% set top_logo_lower = top_logo|lower %}
{% set top_logo_is_video = top_logo_lower ends with '.webm' or top_logo_lower ends with '.mp4' %}

{# General Settings #}
{% set top_logo_center = theme.settings.get('veloura_top_logo_center_2026', true) %}
{% set top_logo_no_center_laptop = theme.settings.get('veloura_top_logo_no_center_laptop_2026', false) %}
{% set top_logo_size_value = theme.settings.get('veloura_top_logo_size_2026', 5) %}
{% if top_logo_size_value.value is defined %}
  {% set top_logo_size_value = top_logo_size_value.value %}
{% endif %}
{% set top_logo_size_px = 32 + (top_logo_size_value * 3) %}

{% set top_bg = theme.settings.get('veloura_top_bg_color_2026', '#ffffff') %}
{% if top_bg.value is defined %}{% set top_bg = top_bg.value %}{% endif %}

{% set top_text = theme.settings.get('veloura_top_text_color_2026', '#004d65') %}
{% if top_text.value is defined %}{% set top_text = top_text.value %}{% endif %}

{% set top_cart_bg = theme.settings.get('veloura_top_cart_bg_2026', '#f87171') %}
{% if top_cart_bg.value is defined %}{% set top_cart_bg = top_cart_bg.value %}{% endif %}

{% set top_border = theme.settings.get('veloura_top_border_style_2026', 'sharp') %}
{% if top_border.value is defined %}{% set top_border = top_border.value %}{% endif %}

{% set icons_size = theme.settings.get('veloura_top_icons_size_2026', 'small') %}
{% if icons_size.value is defined %}{% set icons_size = icons_size.value %}{% endif %}

{% set mobile_search = theme.settings.get('veloura_top_mobile_search_display_2026', 'icon_right') %}
{% if mobile_search.value is defined %}{% set mobile_search = mobile_search.value %}{% endif %}

{% set desktop_search = theme.settings.get('veloura_top_desktop_search_display_2026', 'bar_sticky_icon') %}
{% if desktop_search.value is defined %}{% set desktop_search = desktop_search.value %}{% endif %}

{% set desktop_menu_mode_raw = theme.settings.get('veloura_top_desktop_menu_mode_2026', 'links') %}
{% set desktop_menu_mode = desktop_menu_mode_raw %}
{% if desktop_menu_mode_raw.selected is defined and desktop_menu_mode_raw.selected[0].value is defined %}
  {% set desktop_menu_mode = desktop_menu_mode_raw.selected[0].value %}
{% elseif desktop_menu_mode_raw.value is defined %}
  {% set desktop_menu_mode = desktop_menu_mode_raw.value %}
{% elseif desktop_menu_mode_raw[0].value is defined %}
  {% set desktop_menu_mode = desktop_menu_mode_raw[0].value %}
{% endif %}

{% set show_mobile_lang = theme.settings.get('veloura_top_mobile_currency_lang_icon_2026', true) %}
{% if show_mobile_lang.value is defined %}{% set show_mobile_lang = show_mobile_lang.value %}{% endif %}

{% set hide_lang_desktop = theme.settings.get('veloura_top_hide_currency_lang_desktop_2026', false) %}
{% if hide_lang_desktop.value is defined %}{% set hide_lang_desktop = hide_lang_desktop.value %}{% endif %}

{% set hide_cart_total_mobile = theme.settings.get('veloura_top_hide_cart_total_mobile_2026', true) %}
{% if hide_cart_total_mobile.value is defined %}{% set hide_cart_total_mobile = hide_cart_total_mobile.value %}{% endif %}

{% set full_width_desktop = theme.settings.get('veloura_top_full_width_desktop_2026', true) %}
{% if full_width_desktop.value is defined %}{% set full_width_desktop = full_width_desktop.value %}{% endif %}

{% set show_wishlist = theme.settings.get('veloura_top_show_wishlist_2026', false) %}
{% if show_wishlist.value is defined %}{% set show_wishlist = show_wishlist.value %}{% endif %}

{% set dark_pos = theme.settings.get('veloura_dark_toggle_position_2026', 'left') %}
{% if dark_pos.value is defined %}{% set dark_pos = dark_pos.value %}{% endif %}

{% set top_menu_icon_raw = theme.settings.get('veloura_top_menu_icon_2026', 'sicon-menu') %}
{% set top_menu_icon = top_menu_icon_raw %}
{% if top_menu_icon_raw.selected is defined and top_menu_icon_raw.selected[0].value is defined %}
  {% set top_menu_icon = top_menu_icon_raw.selected[0].value %}
{% elseif top_menu_icon_raw.value is defined %}
  {% set top_menu_icon = top_menu_icon_raw.value %}
{% elseif top_menu_icon_raw[0].value is defined %}
  {% set top_menu_icon = top_menu_icon_raw[0].value %}
{% endif %}
{% if not top_menu_icon %}
  {% set top_menu_icon = 'sicon-menu' %}
{% endif %}

{# Side Categories Settings - التأثير يبقى ظاهر حتى لو زر الإعدادات مطفأ #}
{% set side_gap = theme.settings.get('veloura_side_categories_gap_2026', 14) %}
{% if side_gap.value is defined %}{% set side_gap = side_gap.value %}{% endif %}

{% set side_parent_action = theme.settings.get('veloura_side_categories_parent_click_action_2026', 'open_subcategories') %}
{% if side_parent_action.value is defined %}{% set side_parent_action = side_parent_action.value %}{% endif %}

{% set side_bg = theme.settings.get('veloura_side_categories_bg_color_2026', '#ffffff') %}
{% if side_bg.value is defined %}{% set side_bg = side_bg.value %}{% endif %}

{% set side_text = theme.settings.get('veloura_side_categories_text_color_2026', '#111827') %}
{% if side_text.value is defined %}{% set side_text = side_text.value %}{% endif %}

{% set side_menu_radius = theme.settings.get('veloura_side_categories_menu_radius_2026', 'soft') %}
{% if side_menu_radius.value is defined %}{% set side_menu_radius = side_menu_radius.value %}{% endif %}

{% set side_title_size = theme.settings.get('veloura_side_categories_title_size_2026', 'medium') %}
{% if side_title_size.value is defined %}{% set side_title_size = side_title_size.value %}{% endif %}

{% set side_image_radius = theme.settings.get('veloura_side_categories_image_radius_2026', 'medium') %}
{% if side_image_radius.value is defined %}{% set side_image_radius = side_image_radius.value %}{% endif %}

{% set side_image_fit = theme.settings.get('veloura_side_categories_image_fit_2026', 'cover') %}
{% if side_image_fit.value is defined %}{% set side_image_fit = side_image_fit.value %}{% endif %}

{% set side_img_w = theme.settings.get('veloura_side_cat_img_w_2026', 60) %}
{% if side_img_w.value is defined %}{% set side_img_w = side_img_w.value %}{% endif %}

{% set side_img_h = theme.settings.get('veloura_side_cat_img_h_2026', 60) %}
{% if side_img_h.value is defined %}{% set side_img_h = side_img_h.value %}{% endif %}

{% set side_radius_map = {
  'sharp': '0px',
  'soft': '10px',
  'medium': '16px',
  'large': '24px',
  'xl': '34px'
} %}

{% set side_img_radius_map = {
  'sharp': '0px',
  'soft': '8px',
  'medium': '14px',
  'large': '22px',
  'round': '999px'
} %}

{% set side_title_size_map = {
  'xs': '12px',
  'small': '13px',
  'medium': '15px',
  'large': '17px',
  'xl': '19px',
  'xxl': '22px',
  'xxxl': '26px'
} %}

<header
  class="store-header
  veloura-top-enabled
  {{ top_logo_center ? 'veloura-top-logo-centered' : '' }}
  {{ top_logo_no_center_laptop ? 'veloura-top-logo-no-center-laptop' : '' }}
  {{ full_width_desktop ? 'veloura-top-full-width-desktop' : '' }}
  {{ hide_lang_desktop ? 'veloura-top-hide-lang-desktop' : '' }}
  {{ theme.settings.get('veloura_top_hide_on_scroll_2026') ? 'veloura-hide-top-on-scroll' : '' }}

  veloura-top-border-{{ top_border }}
  veloura-top-icons-{{ icons_size }}

  veloura-mobile-search-{{ mobile_search }}
  veloura-desktop-search-{{ desktop_search }}
  veloura-desktop-menu-{{ desktop_menu_mode }}
  "
  data-veloura-side-parent-action="{{ side_parent_action }}"
  style="
    --veloura-top-bg: {{ top_bg }};
    --veloura-top-text: {{ top_text }};
    --veloura-top-cart-bg: {{ top_cart_bg }};
    --veloura-top-logo-size: {{ top_logo_size_px }}px;

    --veloura-side-cat-bg: {{ side_bg }};
    --veloura-side-cat-text: {{ side_text }};
    --veloura-side-cat-gap: {{ side_gap }}px;
    --veloura-side-cat-radius: {{ side_radius_map[side_menu_radius]|default('10px') }};
    --veloura-side-cat-title-size: {{ side_title_size_map[side_title_size]|default('15px') }};
    --veloura-side-cat-img-radius: {{ side_img_radius_map[side_image_radius]|default('14px') }};
    --veloura-side-cat-img-fit: {{ side_image_fit }};
    --veloura-side-cat-img-w: {{ side_img_w }}px;
    --veloura-side-cat-img-h: {{ side_img_h }}px;
  "
>
  <div id="mainnav" class="main-nav-container shadow-default bg-white">
    <div class="inner bg-inherit w-full">
      <div class="veloura-header-container">
        <div class="veloura-header-grid">

          {# Left Side #}
          <div class="veloura-header-side veloura-header-left">

            {% if not hide_lang_desktop %}
              <div class="veloura-lang-desktop">
                {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <salla-localization-modal show-trigger></salla-localization-modal>
                {% endif %}
              </div>
            {% endif %}

            <salla-cart-summary class="veloura-cart-summary {{ hide_cart_total_mobile ? 'veloura-cart-hide-total veloura-cart-icon-only-mobile' : '' }}">
              <span slot="icon" class="veloura-cart-custom-icon">
                <i class="{{ theme.settings.get('veloura_top_cart_icon_2026', 'sicon-shopping-bag') }}"></i>
              </span>
            </salla-cart-summary>

            <button type="button" class="veloura-header-icon veloura-login-btn" onclick="salla.event.dispatch('login::open')" aria-label="تسجيل الدخول">
              <i class="{{ theme.settings.get('veloura_top_login_icon_2026', 'sicon-user-circle') }}"></i>
            </button>

            {% if show_wishlist %}
              <a class="veloura-header-icon veloura-wishlist-btn" href="{{ store.url }}/wishlist" aria-label="المفضلة">
                <i class="sicon-heart"></i>
              </a>
            {% endif %}

            {% if theme.settings.get('veloura_dark_enabled_2026') and theme.settings.get('veloura_dark_toggle_enabled_2026') and dark_pos == 'left' %}
              <button type="button" class="veloura-header-icon veloura-dark-toggle" aria-label="تبديل الوضع الداكن">
                <i class="sicon-moon veloura-dark-toggle__icon"></i>
              </button>
            {% endif %}

            <button
              type="button"
              class="veloura-header-icon veloura-search-toggle veloura-search-toggle-left"
              onclick="salla.event.dispatch('search::open')"
              aria-label="بحث">
              <i class="sicon-search"></i>
            </button>

          </div>

          {# Logo #}
          <a class="navbar-brand veloura-header-logo" href="{{ store.url }}">
            {% if top_logo_is_video %}
              <video
                class="veloura-store-logo veloura-store-logo-video"
                src="{{ top_logo }}"
                autoplay
                muted
                loop
                playsinline
                data-light-logo="{{ top_logo }}"
                data-dark-logo="{{ theme.settings.get('veloura_dark_logo_2026') }}"
                aria-label="{{ store.name }} logo">
              </video>
            {% else %}
              <img
                fetchpriority="high"
                width="100%"
                height="100%"
                loading="eager"
                src="{{ top_logo }}"
                data-light-logo="{{ top_logo }}"
                data-dark-logo="{{ theme.settings.get('veloura_dark_logo_2026') }}"
                class="veloura-store-logo"
                alt="{{ store.name }} logo">
            {% endif %}

            {% if is_page('index') %}
              <h1 class="sr-only">{{ store.name }}</h1>
            {% else %}
              <h2 class="sr-only">{{ store.name }}</h2>
            {% endif %}
          </a>

          {# Right Side #}
          <div class="veloura-header-side veloura-header-right">

            <button
              type="button"
              class="veloura-header-icon veloura-search-toggle veloura-search-toggle-right"
              onclick="salla.event.dispatch('search::open')"
              aria-label="بحث">
              <i class="sicon-search"></i>
            </button>

            {% if theme.settings.get('veloura_dark_enabled_2026') and theme.settings.get('veloura_dark_toggle_enabled_2026') and dark_pos == 'right' %}
              <button type="button" class="veloura-header-icon veloura-dark-toggle" aria-label="تبديل الوضع الداكن">
                <i class="sicon-moon veloura-dark-toggle__icon"></i>
              </button>
            {% endif %}

            {% if show_mobile_lang %}
              <button type="button" class="veloura-header-icon veloura-lang-mobile" onclick="document.querySelector('salla-localization-modal')?.click()" aria-label="اللغة والعملة">
                <i class="sicon-earth"></i>
              </button>
            {% endif %}

            {# مصدر التصنيفات: يبقى في DOM حتى على وضع hamburger كي نستطيع بناء nav#mobile-menu على اللابتوب #}
            <div class="veloura-menu-links-wrap">
              <custom-main-menu></custom-main-menu>
            </div>

            {# زر سلة الأصلي للجوال، ونستخدمه أيضًا في اللابتوب مع بناء nav#mobile-menu إذا كان فارغًا #}
            <a
              class="veloura-header-icon veloura-menu-trigger-mobile mburger mburger--collapse"
              href="#mobile-menu"
              aria-label="فتح القائمة">
              <i class="{{ top_menu_icon }}"></i>
            </a>

          </div>

          {# Search Bars #}
          <div class="veloura-mobile-search-bar">
            <salla-search inline oval height="40"></salla-search>
          </div>

          <div class="veloura-desktop-search-bar">
            <salla-search inline oval height="40"></salla-search>
          </div>

        </div>
      </div>
    </div>
  </div>
</header>

<script data-cfasync="false">
  document.addEventListener('DOMContentLoaded', function () {
    var header = document.querySelector('.store-header.veloura-top-enabled');

    if (!header) {
      return;
    }

    function isDesktopHamburger() {
      return (
        window.matchMedia('(min-width: 1024px)').matches &&
        header.classList.contains('veloura-desktop-menu-hamburger')
      );
    }

    function getParentAction() {
      return header.getAttribute('data-veloura-side-parent-action') || 'open_subcategories';
    }

    function nativeClick(el) {
      if (!el) return false;

      try {
        el.dispatchEvent(
          new MouseEvent('click', {
            bubbles: true,
            cancelable: true,
            view: window
          })
        );

        return true;
      } catch (error) {
        if (typeof el.click === 'function') {
          el.click();
          return true;
        }
      }

      return false;
    }

    function getDrawer() {
      return document.querySelector('.mm-ocd');
    }

    function getDrawerContent() {
      var drawer = getDrawer();
      return drawer ? drawer.querySelector('.mm-ocd__content') : null;
    }

    function getDirectChildUl(li) {
      var children = li ? li.children : [];

      for (var i = 0; i < children.length; i++) {
        if (children[i].tagName && children[i].tagName.toLowerCase() === 'ul') {
          return children[i];
        }
      }

      return null;
    }

    function getMenuSourceList() {
      return (
        header.querySelector('.veloura-menu-links-wrap custom-main-menu .main-menu') ||
        header.querySelector('.veloura-menu-links-wrap .main-menu') ||
        document.querySelector('custom-main-menu .main-menu') ||
        document.querySelector('.main-menu')
      );
    }

    function makeFallbackList() {
      var links = header.querySelectorAll('.veloura-menu-links-wrap a');
      var ul = document.createElement('ul');

      ul.className = 'main-menu mm-spn--open veloura-side-built-list';

      links.forEach(function (link) {
        var text = String(link.textContent || '').replace(/\s+/g, ' ').trim();
        var href = link.getAttribute('href') || '#';

        if (!text) return;

        var li = document.createElement('li');
        var a = document.createElement('a');

        a.href = href;
        a.textContent = text;

        li.appendChild(a);
        ul.appendChild(li);
      });

      return ul.children.length ? ul : null;
    }

    function prepareMenuList(list) {
      if (!list) return null;

      list.classList.add('main-menu');
      list.classList.add('mm-spn--open');
      list.classList.add('veloura-side-built-list');

      list.querySelectorAll('script, style').forEach(function (node) {
        node.remove();
      });

      list.querySelectorAll('li').forEach(function (li) {
        var childUl = getDirectChildUl(li);
        var link = li.querySelector(':scope > a');

        if (!childUl || !link) {
          return;
        }

        li.classList.add('veloura-side-has-children');
        childUl.classList.add('veloura-side-submenu');

        if (!li.querySelector(':scope > button.veloura-side-parent-toggle')) {
          var button = document.createElement('button');

          button.type = 'button';
          button.className = 'veloura-side-parent-toggle';
          button.setAttribute('aria-label', 'فتح التصنيفات الفرعية');
          button.innerHTML = '<i class="sicon-keyboard_arrow_down" aria-hidden="true"></i>';

          link.after(button);
        }
      });

      return list;
    }

    function buildMenuList() {
      var source = getMenuSourceList();
      var clone = null;

      if (source && source.children && source.children.length) {
        clone = source.cloneNode(true);
      }

      if (!clone) {
        clone = makeFallbackList();
      }

      return prepareMenuList(clone);
    }

    function enhanceNav(nav) {
      if (!nav || nav.getAttribute('data-veloura-desktop-enhanced') === '1') {
        return;
      }

      nav.setAttribute('data-veloura-desktop-enhanced', '1');

      nav.addEventListener('click', function (event) {
        if (!isDesktopHamburger()) {
          return;
        }

        var toggle = event.target.closest('.veloura-side-parent-toggle');
        var parentLi = event.target.closest('.veloura-side-has-children');
        var parentLink = event.target.closest('.veloura-side-has-children > a');

        if (toggle) {
          event.preventDefault();
          event.stopPropagation();

          var li = toggle.closest('.veloura-side-has-children');

          if (li) {
            li.classList.toggle('is-open');
          }

          return;
        }

        if (parentLink && parentLi && getParentAction() === 'open_subcategories') {
          event.preventDefault();
          parentLi.classList.toggle('is-open');
        }
      });
    }

    function ensureDesktopNativeMenu() {
      if (!isDesktopHamburger()) {
        return false;
      }

      var drawer = getDrawer();
      var content = getDrawerContent();

      if (!drawer || !content) {
        return false;
      }

      drawer.classList.add('ocd-categs');
      drawer.classList.add('veloura-desktop-native-mobile-menu');

      var existingNav = content.querySelector('#mobile-menu');
      var hasItems = existingNav && existingNav.querySelector('.main-menu > li');

      if (hasItems) {
        enhanceNav(existingNav);
        return true;
      }

      var list = buildMenuList();

      if (!list) {
        return false;
      }

      content.innerHTML = '';

      var nav = document.createElement('nav');
      nav.id = 'mobile-menu';
      nav.className = 'mobile-menu mm-spn--light mm-spn--navbar mm-spn--main mm-spn veloura-side-native-menu';
      nav.setAttribute('data-mmenu-init', '1');
      nav.setAttribute('data-mm-spn-title', 'القائمة الرئيسية');

      var closeButton = document.createElement('button');
      closeButton.type = 'button';
      closeButton.className = 'btn--close close-mobile-menu sicon-cancel';
      closeButton.setAttribute('aria-label', 'إغلاق قائمة التنقل');

      nav.appendChild(list);
      nav.appendChild(closeButton);
      content.appendChild(nav);

      enhanceNav(nav);

      return true;
    }

    function retryEnsureDesktopNativeMenu() {
      ensureDesktopNativeMenu();
      setTimeout(ensureDesktopNativeMenu, 60);
      setTimeout(ensureDesktopNativeMenu, 180);
      setTimeout(ensureDesktopNativeMenu, 420);
      setTimeout(ensureDesktopNativeMenu, 900);
    }

    document.addEventListener(
      'click',
      function (event) {
        var trigger = event.target.closest('.veloura-menu-trigger-mobile[href="#mobile-menu"], a.mburger[href="#mobile-menu"]');

        if (trigger && isDesktopHamburger()) {
          retryEnsureDesktopNativeMenu();
          return;
        }

        var closeButton = event.target.closest('.close-mobile-menu');
        var backdrop = event.target.closest('.mm-ocd__backdrop');

        if ((closeButton || backdrop) && isDesktopHamburger()) {
          var drawer = getDrawer();

          if (drawer) {
            drawer.classList.remove('mm-ocd--open');
          }

          document.body.classList.remove('menu-opened');
          document.body.classList.remove('mm-ocd-opened');
          document.body.classList.remove('overflow-hidden');
          document.documentElement.classList.remove('mm-wrapper--opened');
        }
      },
      true
    );

    window.addEventListener('resize', function () {
      if (isDesktopHamburger()) {
        retryEnsureDesktopNativeMenu();
      }
    });

    retryEnsureDesktopNativeMenu();
  });
</script>
