{% set important_links = theme.settings.get('important_links') %}

{% set top_enabled = theme.settings.get('veloura_top_enabled_2026', false) %}
{% set top_logo = theme.settings.get('veloura_top_logo_url_2026') ?: theme.settings.get('veloura_top_logo_image_2026') ?: store.logo|cdn(175) %}
{% set top_border = theme.settings.get('veloura_top_border_style_2026', 'sharp') %}
{% set icons_size = theme.settings.get('veloura_top_icons_size_2026', 'small') %}
{% set mobile_search = theme.settings.get('veloura_top_mobile_search_display_2026', 'bar') %}
{% set desktop_search = theme.settings.get('veloura_top_desktop_search_display_2026', 'bar') %}
{% set mobile_lang = theme.settings.get('veloura_top_mobile_currency_lang_icon_2026', true) %}

<header class="store-header {{ top_enabled ? 'veloura-top-enabled' : '' }} veloura-top-border-{{ top_border }} veloura-top-icons-{{ icons_size }} veloura-mobile-search-{{ mobile_search }} veloura-desktop-search-{{ desktop_search }} {{ theme.settings.get('veloura_top_logo_center_2026') ? 'veloura-logo-center' : '' }} {{ theme.settings.get('veloura_top_hide_on_scroll_2026') ? 'veloura-hide-top-on-scroll' : '' }}">

  <div class="top-navbar">
    <div class="container flex justify-between">
      <div class="flex-1 flex items-center gap-2">
        {% if important_links %}
          <salla-menu source="footer" topnav></salla-menu>
        {% endif %}

        <div class="header-buttons veloura-top-lang-desktop">
          {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
            <salla-localization-modal show-trigger></salla-localization-modal>
          {% endif %}
        </div>

        {% if store.scope %}
          <button class="btn--rounded-gray" onclick="salla.event.dispatch('scopes::open', {'mode': 'default'})">
            <i class="sicon-location rtl:ml-1 ltr:mr-1"></i> {{ store.scope.name }}
          </button>
        {% endif %}

        <div class="header-search">
          <salla-search inline oval height="36"></salla-search>
        </div>
      </div>

      <salla-contacts is-header></salla-contacts>
    </div>
  </div>

  <div id="mainnav" class="main-nav-container shadow-default bg-white flex items-center">
    <div class="inner bg-inherit w-full">
      <div class="container">
        <div class="flex items-center justify-between relative">

          <div class="flex items-center veloura-menu-side">
            <a class="lg:hidden mburger mburger--collapse leading-none rtl:ml-4 ltr:mr-4" href="#mobile-menu" aria-label="Open-menu">
              <i class="{{ theme.settings.get('veloura_top_menu_icon_2026', 'sicon-menu') }}"></i>
            </a>

            {% if mobile_lang %}
              <button type="button" class="veloura-mobile-lang-trigger lg:hidden" onclick="document.querySelector('salla-localization-modal')?.click()" aria-label="اللغة والعملة">
                <i class="sicon-earth"></i>
              </button>
            {% endif %}
          </div>

          <a class="navbar-brand" href="{{ store.url }}">
            <img
              fetchpriority="high"
              width="100%"
              height="100%"
              loading="eager"
              src="{{ top_logo }}"
              data-light-logo="{{ top_logo }}"
              data-dark-logo="{{ theme.settings.get('veloura_dark_logo_2026') }}"
              class="veloura-store-logo"
              alt="{{ store.name }} logo">

            {% if is_page('index') %}
              <h1 class="sr-only">{{ store.name }}</h1>
            {% else %}
              <h2 class="sr-only">{{ store.name }}</h2>
            {% endif %}
          </a>

          <custom-main-menu></custom-main-menu>

          <div class="header-actions">
            {% if theme.settings.get('veloura_dark_enabled_2026') and theme.settings.get('veloura_dark_toggle_enabled_2026') %}
              <button type="button" class="veloura-header-icon veloura-dark-toggle veloura-dark-toggle--{{ theme.settings.get('veloura_dark_toggle_position_2026', 'right') }}" aria-label="تبديل الوضع الداكن">
                <i class="sicon-moon veloura-dark-toggle__moon"></i>
                <i class="sicon-sun veloura-dark-toggle__sun"></i>
              </button>
            {% endif %}

            <button type="button" class="veloura-header-icon veloura-login-btn" onclick="salla.event.dispatch('login::open')" aria-label="تسجيل الدخول">
              <i class="{{ theme.settings.get('veloura_top_login_icon_2026', 'sicon-user-circle') }}"></i>
            </button>

            <salla-cart-summary class="veloura-cart-summary {{ theme.settings.get('veloura_top_hide_cart_total_mobile_2026') ? 'veloura-cart-icon-only-mobile' : '' }}">
              <i slot="icon" class="veloura-header-icon {{ theme.settings.get('veloura_top_cart_icon_2026', 'sicon-shopping-bag') }}"></i>
            </salla-cart-summary>
          </div>

        </div>
      </div>
    </div>
  </div>
</header>