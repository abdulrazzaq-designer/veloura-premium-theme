{% set top_enabled = true %}

{# Logo #}
{% set light_logo_url = theme.settings.get('veloura_light_logo_url_2026') %}
{% set light_logo_image = theme.settings.get('veloura_light_logo_2026') %}
{% set veloura_light_logo = light_logo_url ?: light_logo_image %}

{% set top_logo_url = theme.settings.get('veloura_top_logo_url_2026') %}
{% set top_logo_image = theme.settings.get('veloura_top_logo_image_2026') %}
{% set top_logo = top_logo_url ?: top_logo_image ?: veloura_light_logo ?: store.logo|cdn(175) %}

{% set top_logo_lower = top_logo|lower %}
{% set top_logo_is_video = top_logo_lower ends with '.webm' or top_logo_lower ends with '.mp4' %}

{# General Settings #}
{% set top_logo_center = theme.settings.get('veloura_top_logo_center_2026', true) %}
{% if top_logo_center.value is defined %}{% set top_logo_center = top_logo_center.value %}{% endif %}

{% set top_logo_no_center_laptop = theme.settings.get('veloura_top_logo_no_center_laptop_2026', false) %}
{% if top_logo_no_center_laptop.value is defined %}{% set top_logo_no_center_laptop = top_logo_no_center_laptop.value %}{% endif %}

{% set top_logo_size_value = theme.settings.get('veloura_top_logo_size_2026', 5) %}
{% if top_logo_size_value.value is defined %}{% set top_logo_size_value = top_logo_size_value.value %}{% endif %}
{% set top_logo_size_px = 32 + (top_logo_size_value * 3) %}

{% set top_bg = theme.settings.get('veloura_top_bg_color_2026', '#ffffff') %}
{% if top_bg.value is defined %}{% set top_bg = top_bg.value %}{% endif %}

{% set top_text = theme.settings.get('veloura_top_text_color_2026', '#004d65') %}
{% if top_text.value is defined %}{% set top_text = top_text.value %}{% endif %}

{% set top_cart_bg = theme.settings.get('veloura_top_cart_bg_2026', '#f87171') %}
{% if top_cart_bg.value is defined %}{% set top_cart_bg = top_cart_bg.value %}{% endif %}

{% set top_border = theme.settings.get('veloura_top_border_style_2026', 'sharp') %}
{% if top_border.selected is defined and top_border.selected[0].value is defined %}
  {% set top_border = top_border.selected[0].value %}
{% elseif top_border.value is defined %}
  {% set top_border = top_border.value %}
{% elseif top_border[0].value is defined %}
  {% set top_border = top_border[0].value %}
{% endif %}

{% set icons_size = theme.settings.get('veloura_top_icons_size_2026', 'small') %}
{% if icons_size.selected is defined and icons_size.selected[0].value is defined %}
  {% set icons_size = icons_size.selected[0].value %}
{% elseif icons_size.value is defined %}
  {% set icons_size = icons_size.value %}
{% elseif icons_size[0].value is defined %}
  {% set icons_size = icons_size[0].value %}
{% endif %}

{% set mobile_search = theme.settings.get('veloura_top_mobile_search_display_2026', 'icon_right') %}
{% if mobile_search.selected is defined and mobile_search.selected[0].value is defined %}
  {% set mobile_search = mobile_search.selected[0].value %}
{% elseif mobile_search.value is defined %}
  {% set mobile_search = mobile_search.value %}
{% elseif mobile_search[0].value is defined %}
  {% set mobile_search = mobile_search[0].value %}
{% endif %}

{% set desktop_search = theme.settings.get('veloura_top_desktop_search_display_2026', 'bar_sticky_icon') %}
{% if desktop_search.selected is defined and desktop_search.selected[0].value is defined %}
  {% set desktop_search = desktop_search.selected[0].value %}
{% elseif desktop_search.value is defined %}
  {% set desktop_search = desktop_search.value %}
{% elseif desktop_search[0].value is defined %}
  {% set desktop_search = desktop_search[0].value %}
{% endif %}

{% set desktop_menu_mode = theme.settings.get('veloura_top_desktop_menu_mode_2026', 'links') %}
{% if desktop_menu_mode.selected is defined and desktop_menu_mode.selected[0].value is defined %}
  {% set desktop_menu_mode = desktop_menu_mode.selected[0].value %}
{% elseif desktop_menu_mode.value is defined %}
  {% set desktop_menu_mode = desktop_menu_mode.value %}
{% elseif desktop_menu_mode[0].value is defined %}
  {% set desktop_menu_mode = desktop_menu_mode[0].value %}
{% endif %}

{% set show_mobile_lang = theme.settings.get('veloura_top_mobile_currency_lang_icon_2026', true) %}
{% if show_mobile_lang.value is defined %}{% set show_mobile_lang = show_mobile_lang.value %}{% endif %}

{% set hide_lang_desktop = theme.settings.get('veloura_top_hide_currency_lang_desktop_2026', false) %}
{% if hide_lang_desktop.value is defined %}{% set hide_lang_desktop = hide_lang_desktop.value %}{% endif %}

{% set hide_cart_total_mobile = theme.settings.get('veloura_top_hide_cart_total_mobile_2026', true) %}
{% if hide_cart_total_mobile.value is defined %}{% set hide_cart_total_mobile = hide_cart_total_mobile.value %}{% endif %}

{% set full_width_desktop = theme.settings.get('veloura_top_full_width_desktop_2026', true) %}
{% if full_width_desktop.value is defined %}{% set full_width_desktop = full_width_desktop.value %}{% endif %}

{% set show_wishlist = theme.settings.get('veloura_top_show_wishlist_2026', false) %}
{% if show_wishlist.value is defined %}{% set show_wishlist = show_wishlist.value %}{% endif %}

{% set dark_pos = theme.settings.get('veloura_dark_toggle_position_2026', 'left') %}
{% if dark_pos.selected is defined and dark_pos.selected[0].value is defined %}
  {% set dark_pos = dark_pos.selected[0].value %}
{% elseif dark_pos.value is defined %}
  {% set dark_pos = dark_pos.value %}
{% elseif dark_pos[0].value is defined %}
  {% set dark_pos = dark_pos[0].value %}
{% endif %}

{% set top_menu_icon = theme.settings.get('veloura_top_menu_icon_2026', 'sicon-menu') %}
{% if top_menu_icon.selected is defined and top_menu_icon.selected[0].value is defined %}
  {% set top_menu_icon = top_menu_icon.selected[0].value %}
{% elseif top_menu_icon.value is defined %}
  {% set top_menu_icon = top_menu_icon.value %}
{% elseif top_menu_icon[0].value is defined %}
  {% set top_menu_icon = top_menu_icon[0].value %}
{% endif %}
{% if not top_menu_icon %}
  {% set top_menu_icon = 'sicon-menu' %}
{% endif %}

<header
  class="store-header
  veloura-top-enabled
  {{ top_logo_center ? 'veloura-top-logo-centered' : '' }}
  {{ top_logo_no_center_laptop ? 'veloura-top-logo-no-center-laptop' : '' }}
  {{ full_width_desktop ? 'veloura-top-full-width-desktop' : '' }}
  {{ hide_lang_desktop ? 'veloura-top-hide-lang-desktop' : '' }}
  {{ theme.settings.get('veloura_top_hide_on_scroll_2026') ? 'veloura-hide-top-on-scroll' : '' }}

  veloura-top-border-{{ top_border }}
  veloura-top-icons-{{ icons_size }}

  veloura-mobile-search-{{ mobile_search }}
  veloura-desktop-search-{{ desktop_search }}
  veloura-desktop-menu-{{ desktop_menu_mode }}
  "
  style="
    --veloura-top-bg: {{ top_bg }};
    --veloura-top-text: {{ top_text }};
    --veloura-top-cart-bg: {{ top_cart_bg }};
    --veloura-top-logo-size: {{ top_logo_size_px }}px;
  "
>
  <div id="mainnav" class="main-nav-container shadow-default bg-white">
    <div class="inner bg-inherit w-full">
      <div class="veloura-header-container">
        <div class="veloura-header-grid">

          {# Left Side #}
          <div class="veloura-header-side veloura-header-left">

            {% if not hide_lang_desktop %}
              <div class="veloura-lang-desktop">
                {% if store.settings.is_multilingual or store.settings.currencies_enabled %}
                  <salla-localization-modal show-trigger></salla-localization-modal>
                {% endif %}
              </div>
            {% endif %}

            <salla-cart-summary class="veloura-cart-summary {{ hide_cart_total_mobile ? 'veloura-cart-hide-total veloura-cart-icon-only-mobile' : '' }}">
              <span slot="icon" class="veloura-cart-custom-icon">
                <i class="{{ theme.settings.get('veloura_top_cart_icon_2026', 'sicon-shopping-bag') }}"></i>
              </span>
            </salla-cart-summary>

            <button type="button" class="veloura-header-icon veloura-login-btn" onclick="salla.event.dispatch('login::open')" aria-label="تسجيل الدخول">
              <i class="{{ theme.settings.get('veloura_top_login_icon_2026', 'sicon-user-circle') }}"></i>
            </button>

            {% if show_wishlist %}
              <a class="veloura-header-icon veloura-wishlist-btn" href="{{ store.url }}/wishlist" aria-label="المفضلة">
                <i class="sicon-heart"></i>
              </a>
            {% endif %}

            {% if theme.settings.get('veloura_dark_enabled_2026') and theme.settings.get('veloura_dark_toggle_enabled_2026') and dark_pos == 'left' %}
              <button type="button" class="veloura-header-icon veloura-dark-toggle" aria-label="تبديل الوضع الداكن">
                <i class="sicon-moon veloura-dark-toggle__icon"></i>
              </button>
            {% endif %}

            <button
              type="button"
              class="veloura-header-icon veloura-search-toggle veloura-search-toggle-left"
              onclick="salla.event.dispatch('search::open')"
              aria-label="بحث">
              <i class="sicon-search"></i>
            </button>

          </div>

          {# Logo #}
          <a class="navbar-brand veloura-header-logo" href="{{ store.url }}">
            {% if top_logo_is_video %}
              <video
                class="veloura-store-logo veloura-store-logo-video"
                src="{{ top_logo }}"
                autoplay
                muted
                loop
                playsinline
                data-light-logo="{{ top_logo }}"
                data-dark-logo="{{ theme.settings.get('veloura_dark_logo_2026') }}"
                aria-label="{{ store.name }} logo">
              </video>
            {% else %}
              <img
                fetchpriority="high"
                width="100%"
                height="100%"
                loading="eager"
                src="{{ top_logo }}"
                data-light-logo="{{ top_logo }}"
                data-dark-logo="{{ theme.settings.get('veloura_dark_logo_2026') }}"
                class="veloura-store-logo"
                alt="{{ store.name }} logo">
            {% endif %}

            {% if is_page('index') %}
              <h1 class="sr-only">{{ store.name }}</h1>
            {% else %}
              <h2 class="sr-only">{{ store.name }}</h2>
            {% endif %}
          </a>

          {# Right Side #}
          <div class="veloura-header-side veloura-header-right">

            <button
              type="button"
              class="veloura-header-icon veloura-search-toggle veloura-search-toggle-right"
              onclick="salla.event.dispatch('search::open')"
              aria-label="بحث">
              <i class="sicon-search"></i>
            </button>

            {% if theme.settings.get('veloura_dark_enabled_2026') and theme.settings.get('veloura_dark_toggle_enabled_2026') and dark_pos == 'right' %}
              <button type="button" class="veloura-header-icon veloura-dark-toggle" aria-label="تبديل الوضع الداكن">
                <i class="sicon-moon veloura-dark-toggle__icon"></i>
              </button>
            {% endif %}

            {% if show_mobile_lang %}
              <button type="button" class="veloura-header-icon veloura-lang-mobile" onclick="document.querySelector('salla-localization-modal')?.click()" aria-label="اللغة والعملة">
                <i class="sicon-earth"></i>
              </button>
            {% endif %}

            {#
              custom-main-menu هو المصدر الصحيح في ثيمك، وليس aali-main-menu.
              في وضع links يظهر كروابط.
              في وضع hamburger نخفيه بصريًا فقط، ونتركه يهيئ nav#mobile-menu الأصلي.
            #}
            <div class="veloura-menu-links-wrap">
              <custom-main-menu></custom-main-menu>
            </div>

            {# زر سلة الأصلي؛ لا تغيّر href ولا mburger #}
            <a
              class="veloura-header-icon veloura-menu-trigger-mobile mburger mburger--collapse"
              href="#mobile-menu"
              aria-label="فتح القائمة">
              <i class="{{ top_menu_icon }}"></i>
            </a>

          </div>

          {# Search Bars #}
          <div class="veloura-mobile-search-bar">
            <salla-search inline oval height="40"></salla-search>
          </div>

          <div class="veloura-desktop-search-bar">
            <salla-search inline oval height="40"></salla-search>
          </div>

        </div>
      </div>
    </div>
  </div>
</header>

<script data-cfasync="false">
  document.addEventListener('DOMContentLoaded', function () {
    var header = document.querySelector('.store-header.veloura-top-enabled');

    if (!header) {
      return;
    }

    function isDesktopHamburger() {
      return (
        window.matchMedia('(min-width: 1024px)').matches &&
        header.classList.contains('veloura-desktop-menu-hamburger')
      );
    }

    function getDrawer() {
      return document.querySelector('.mm-ocd');
    }

    function getContent() {
      var drawer = getDrawer();
      return drawer ? drawer.querySelector('.mm-ocd__content') : null;
    }

    function getCustomNativeNav() {
      return (
        header.querySelector('.veloura-menu-links-wrap nav#mobile-menu') ||
        header.querySelector('.veloura-menu-links-wrap #mobile-menu') ||
        header.querySelector('.veloura-menu-links-wrap custom-main-menu nav#mobile-menu') ||
        header.querySelector('.veloura-menu-links-wrap custom-main-menu #mobile-menu')
      );
    }

    function getCustomCloseButton() {
      return header.querySelector('.veloura-menu-links-wrap .close-mobile-menu');
    }

    function moveCustomMenuIntoDrawer() {
      if (!isDesktopHamburger()) {
        return false;
      }

      var content = getContent();
      var nativeNav = getCustomNativeNav();

      if (!content || !nativeNav) {
        return false;
      }

      var drawer = getDrawer();

      if (drawer) {
        drawer.classList.add('ocd-categs');
        drawer.classList.add('veloura-desktop-custom-native');
      }

      if (nativeNav.closest('.mm-ocd__content')) {
        return true;
      }

      content.innerHTML = '';
      content.appendChild(nativeNav);

      var closeButton = getCustomCloseButton();

      if (closeButton && !closeButton.closest('.mm-ocd__content')) {
        nativeNav.appendChild(closeButton);
      }

      return true;
    }

    function retryMoveCustomMenu() {
      moveCustomMenuIntoDrawer();
      setTimeout(moveCustomMenuIntoDrawer, 80);
      setTimeout(moveCustomMenuIntoDrawer, 220);
      setTimeout(moveCustomMenuIntoDrawer, 520);
      setTimeout(moveCustomMenuIntoDrawer, 1000);
    }

    document.addEventListener(
      'click',
      function (event) {
        var trigger = event.target.closest('.veloura-menu-trigger-mobile[href="#mobile-menu"], a.mburger[href="#mobile-menu"]');

        if (trigger && isDesktopHamburger()) {
          retryMoveCustomMenu();
        }
      },
      true
    );

    window.addEventListener('resize', retryMoveCustomMenu);

    retryMoveCustomMenu();
  });
</script>


<script data-cfasync="false">
  document.addEventListener('DOMContentLoaded', function () {
    var header = document.querySelector('.store-header.veloura-top-enabled');

    if (!header) return;

    function isDesktopHamburger() {
      return window.matchMedia('(min-width: 1024px)').matches &&
        header.classList.contains('veloura-desktop-menu-hamburger');
    }

    function enhanceDesktopCustomMenu() {
      if (!isDesktopHamburger()) return;

      var drawer = document.querySelector('.mm-ocd');
      var menu = drawer ? drawer.querySelector('.main-menu') : null;

      if (!drawer || !menu) return;

      drawer.classList.add('veloura-desktop-custom-native');
      menu.classList.add('veloura-desktop-custom-native__menu');

      menu.querySelectorAll('li').forEach(function (li) {
        var directSubmenu = null;
        var children = li.children || [];

        for (var i = 0; i < children.length; i++) {
          if (children[i].tagName && children[i].tagName.toLowerCase() === 'ul') {
            directSubmenu = children[i];
            break;
          }
        }

        if (!directSubmenu) return;

        li.classList.add('veloura-side-has-children');
        directSubmenu.classList.add('veloura-side-submenu');

        if (!li.querySelector(':scope > button.veloura-side-parent-toggle')) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'veloura-side-parent-toggle';
          btn.setAttribute('aria-label', 'فتح التصنيفات الفرعية');
          btn.innerHTML = '<i class="sicon-keyboard_arrow_down" aria-hidden="true"></i>';

          var firstLink = li.querySelector(':scope > a');

          if (firstLink) {
            firstLink.after(btn);
          } else {
            li.insertBefore(btn, directSubmenu);
          }
        }
      });
    }

    function scheduleEnhance() {
      enhanceDesktopCustomMenu();
      setTimeout(enhanceDesktopCustomMenu, 80);
      setTimeout(enhanceDesktopCustomMenu, 240);
      setTimeout(enhanceDesktopCustomMenu, 600);
      setTimeout(enhanceDesktopCustomMenu, 1200);
    }

    document.addEventListener('click', function (event) {
      if (!isDesktopHamburger()) return;

      var trigger = event.target.closest('.veloura-menu-trigger-mobile[href="#mobile-menu"], a.mburger[href="#mobile-menu"]');

      if (trigger) {
        scheduleEnhance();
        return;
      }

      var toggle = event.target.closest('.mm-ocd.veloura-desktop-custom-native .veloura-side-parent-toggle');
      var parentLink = event.target.closest('.mm-ocd.veloura-desktop-custom-native .veloura-side-has-children > a');

      if (toggle) {
        event.preventDefault();
        event.stopPropagation();

        var toggleLi = toggle.closest('.veloura-side-has-children');

        if (toggleLi) toggleLi.classList.toggle('is-open');

        return;
      }

      if (parentLink) {
        event.preventDefault();

        var li = parentLink.closest('.veloura-side-has-children');

        if (li) li.classList.toggle('is-open');
      }
    }, true);

    window.addEventListener('resize', scheduleEnhance);
    scheduleEnhance();
  });
</script>

