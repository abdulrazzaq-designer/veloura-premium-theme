{% set footer_enabled = true %}

{% set light_logo_url = theme.settings.get('veloura_light_logo_url_2026') %}
{% set light_logo_image = theme.settings.get('veloura_light_logo_2026') %}
{% set veloura_light_logo = light_logo_url ?: light_logo_image %}

{% set footer_logo_url = theme.settings.get('veloura_footer_logo_url_2026') %}
{% set footer_logo_image = theme.settings.get('veloura_footer_logo_image_2026') %}
{% set footer_logo = footer_logo_url ?: footer_logo_image ?: veloura_light_logo ?: store.logo|cdn(175) %}

{% set footer_logo_lower = footer_logo|lower %}
{% set footer_logo_is_video = footer_logo_lower ends with '.webm' or footer_logo_lower ends with '.mp4' %}

{% set footer_hide_logo = theme.settings.get('veloura_footer_hide_logo_2026', false) %}
{% set footer_logo_size_value = theme.settings.get('veloura_footer_logo_size_2026', 8) %}
{% set footer_logo_size_px = 44 + (footer_logo_size_value * 4) %}

{% set footer_bg = theme.settings.get('veloura_footer_bg_color_2026', '#f8fafc') %}
{% set footer_text = theme.settings.get('veloura_footer_text_color_2026', '#0f172a') %}
{% set footer_title_color = theme.settings.get('veloura_footer_title_color_2026', '#0f172a') %}
{% set footer_link_color = theme.settings.get('veloura_footer_link_color_2026', '#334155') %}
{% set footer_icon_bg = theme.settings.get('veloura_footer_icon_bg_color_2026', '#ffffff') %}
{% set footer_bottom_bg = theme.settings.get('veloura_footer_bottom_bg_2026', '#ffffff') %}
{% set footer_bottom_text_color = theme.settings.get('veloura_footer_bottom_text_color_2026', '#334155') %}

{% set footer_title_size_value = theme.settings.get('veloura_footer_title_size_2026', 4) %}
{% set footer_text_size_value = theme.settings.get('veloura_footer_text_size_2026', 3) %}

{% set footer_title_size = 12 + footer_title_size_value %}
{% set footer_text_size = 11 + footer_text_size_value %}

{% set footer_bg_image = theme.settings.get('veloura_footer_bg_image_2026') %}
{% set footer_transparent_home = theme.settings.get('veloura_footer_transparent_home_2026', false) %}
{% set footer_compact = theme.settings.get('veloura_footer_compact_2026', false) %}
{% set footer_radius = theme.settings.get('veloura_footer_radius_2026', 'medium') %}
{% set footer_center_mobile = theme.settings.get('veloura_footer_center_mobile_2026', true) %}
{% set footer_columns = theme.settings.get('veloura_footer_columns_desktop_2026', '4') %}

{% set footer_store_title = theme.settings.get('veloura_footer_store_title_2026') ?: store.name %}
{% set footer_store_description = theme.settings.get('veloura_footer_store_description_2026') ?: store.description %}
{% set footer_links_title = theme.settings.get('veloura_footer_links_title_2026') ?: trans('blocks.footer.pages_links') %}
{% set footer_contact_title = theme.settings.get('veloura_footer_contact_title_2026') ?: 'تواصل معنا' %}
{% set footer_apps_title = theme.settings.get('veloura_footer_apps_title_2026') ?: 'تحميل تطبيق الجوال' %}
{% set footer_social_title = theme.settings.get('veloura_footer_social_title_2026') ?: 'تابعنا' %}
{% set footer_bottom_text = theme.settings.get('veloura_footer_bottom_text_2026') %}

{% set footer_hide_apps = theme.settings.get('veloura_footer_hide_apps_2026', false) %}
{% set footer_hide_links = theme.settings.get('veloura_footer_hide_links_2026', false) %}
{% set footer_hide_payments = theme.settings.get('veloura_footer_hide_payments_2026', false) %}
{% set footer_show_social_title = theme.settings.get('veloura_footer_show_social_title_2026', true) %}
{% set footer_social_under_store = theme.settings.get('veloura_footer_social_under_store_2026', true) %}
{% set footer_social_under_contact = theme.settings.get('veloura_footer_social_under_contact_2026', false) %}

{% set footer_contact_display = theme.settings.get('veloura_footer_contact_display_2026', 'modern') %}
{% set footer_contact_center = theme.settings.get('veloura_footer_contact_center_2026', false) %}
{% set footer_social_center = theme.settings.get('veloura_footer_social_center_2026', false) %}
{% set footer_contact_inline_silver = theme.settings.get('veloura_footer_contact_inline_silver_2026', false) %}
{% if footer_contact_inline_silver.value is defined %}{% set footer_contact_inline_silver = footer_contact_inline_silver.value %}{% endif %}
{% set footer_apps_center = theme.settings.get('veloura_footer_apps_center_2026', true) %}
{% set footer_hide_apps_title = theme.settings.get('veloura_footer_hide_apps_title_2026', false) %}
{% set footer_apps_badge_size_value = theme.settings.get('veloura_footer_apps_badge_size_2026', 4) %}
{% set footer_apps_badge_height = 34 + (footer_apps_badge_size_value * 3) %}

<footer
  class="store-footer
  veloura-footer-enabled
  {{ footer_compact ? 'veloura-footer-compact' : '' }}
  {{ footer_center_mobile ? 'veloura-footer-center-mobile' : '' }}
  {{ footer_transparent_home and is_page('index') ? 'veloura-footer-transparent-home' : '' }}
  veloura-footer-contact-display-{{ footer_contact_display }}
{{ footer_contact_center ? 'veloura-footer-contact-center' : '' }}
{{ footer_contact_inline_silver ? 'veloura-footer-contact-inline-silver' : '' }}
{{ footer_social_center ? 'veloura-footer-social-center' : '' }}
{{ footer_apps_center ? 'veloura-footer-apps-center' : '' }}
{{ footer_hide_apps_title ? 'veloura-footer-hide-apps-title' : '' }}
  veloura-footer-radius-{{ footer_radius }}
  veloura-footer-cols-{{ footer_columns }}
  "
  style="
    --veloura-footer-bg: {{ footer_bg }};
    --veloura-footer-text: {{ footer_text }};
    --veloura-footer-title: {{ footer_title_color }};
    --veloura-footer-link: {{ footer_link_color }};
    --veloura-footer-icon-bg: {{ footer_icon_bg }};
    --veloura-footer-bottom-bg: {{ footer_bottom_bg }};
    --veloura-footer-bottom-text: {{ footer_bottom_text_color }};
    --veloura-footer-title-size: {{ footer_title_size }}px;
    --veloura-footer-text-size: {{ footer_text_size }}px;
    --veloura-footer-logo-size: {{ footer_logo_size_px }}px;
	--veloura-footer-app-badge-height: {{ footer_apps_badge_height }}px;
    {% if footer_bg_image %}
      --veloura-footer-bg-image: url('{{ footer_bg_image }}');
    {% endif %}
  "
>
  <div aria-label="footer" class="store-footer__inner veloura-footer-main">
    <div class="veloura-footer-container">
      <div class="veloura-footer-grid">

        {# Store Info #}
        <div class="veloura-footer-block veloura-footer-store">
          {% if not footer_hide_logo %}
            <a href="{{ link('/') }}" class="veloura-footer-logo" aria-label="{{ store.name }}">
              {% if footer_logo_is_video %}
                <video
                  class="veloura-footer-logo__media"
                  src="{{ footer_logo }}"
                  autoplay
                  muted
                  loop
                  playsinline>
                </video>
              {% else %}
                <img
                  class="veloura-footer-logo__media"
                  src="{{ footer_logo }}"
                  loading="lazy"
                  alt="{{ store.name }}">
              {% endif %}
            </a>
          {% endif %}

          <h3 class="veloura-footer-title">{{ footer_store_title }}</h3>

          {% if footer_store_description %}
            <div class="veloura-footer-description">
              {{ footer_store_description|raw }}
            </div>
          {% endif %}

          {% if footer_social_under_store %}
            <div class="veloura-footer-social veloura-footer-social-store">
              {% if footer_show_social_title %}
                <h4 class="veloura-footer-social-title">{{ footer_social_title }}</h4>
              {% endif %}
              <salla-social></salla-social>
            </div>
          {% endif %}

          <div class="veloura-footer-trust">
            <salla-trust-badges {% if theme.settings.get('footer_is_dark') %} dark {% endif %}></salla-trust-badges>

            {% if store.settings.tax.number %}
              <div class="veloura-footer-tax">
                {% if store.settings.tax.certificate %}
                  <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                    <img width="40" height="50" src="{{ 'images/tax.png' | cdn(70,70) }}" loading="lazy" alt="value added tax">
                  </a>
                {% endif %}

                <div>
                  <p>{{ trans('common.elements.tax_number') }}</p>
                  <b>{{ store.settings.tax.number }}</b>
                </div>
              </div>

              {% if store.settings.tax.certificate %}
                <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                  <div class="flex justify-center max-w-full">
                    <img class="w-full" loading="lazy" data-src="{{ store.settings.tax.certificate }}" alt="{{ store.settings.tax.number }}"/>
                  </div>
                </salla-modal>
              {% endif %}
            {% endif %}
          </div>
        </div>

        {# Footer Links #}
        {% if not footer_hide_links %}
          <div class="veloura-footer-block veloura-footer-links">
            <h3 class="veloura-footer-title">{{ footer_links_title }}</h3>
            <salla-menu source="footer" with-cookie-preferences></salla-menu>
          </div>
        {% endif %}

        {# Contacts #}
        <div class="veloura-footer-block veloura-footer-contact">
          <h3 class="veloura-footer-title">{{ footer_contact_title }}</h3>

          <div class="veloura-footer-contact-list" data-veloura-footer-contacts>
            <salla-contacts></salla-contacts>
          </div>

          {% if footer_social_under_contact %}
            <div class="veloura-footer-social veloura-footer-social-contact">
              {% if footer_show_social_title %}
                <h4 class="veloura-footer-social-title">{{ footer_social_title }}</h4>
              {% endif %}
              <salla-social></salla-social>
            </div>
          {% endif %}
        </div>

        {# Apps #}
        {% if not footer_hide_apps %}
  <div class="veloura-footer-block veloura-footer-apps">
    {% if not footer_hide_apps_title %}
      <h3 class="veloura-footer-title">{{ footer_apps_title }}</h3>
    {% endif %}
    <salla-apps-icons></salla-apps-icons>
  </div>
{% endif %}

      </div>
    </div>
  </div>

  <div class="veloura-footer-bottom">
    <div class="veloura-footer-container veloura-footer-bottom__inner">
      <span class="veloura-footer-copyright">
        {% if footer_bottom_text %}
          {{ footer_bottom_text }}
        {% else %}
          {% hook copyright %}
        {% endif %}
      </span>

      {% if not footer_hide_payments %}
        <salla-payments></salla-payments>
      {% endif %}
    </div>
  </div>



<script>
(function () {
  const labelMap = {
    phone: 'الهاتف',
    whatsapp: 'واتساب',
    email: 'البريد الإلكتروني',
    telegram: 'تلجرام',
    website: 'الموقع',
    contact: 'تواصل'
  };

  const iconMap = {
    phone: 'sicon-phone',
    whatsapp: 'sicon-whatsapp',
    email: 'sicon-mail',
    telegram: 'sicon-telegram',
    website: 'sicon-globe',
    contact: 'sicon-phone'
  };

  function velouraFooterDetectKind(link) {
    const href = (link.getAttribute('href') || '').toLowerCase();
    const text = (link.textContent || '').toLowerCase();
    const classes = Array.from(link.querySelectorAll('[class]'))
      .map(function (el) { return String(el.className || ''); })
      .join(' ')
      .toLowerCase();

    const source = href + ' ' + text + ' ' + classes;

    if (/wa\.me|whatsapp|sicon-whatsapp/.test(source)) return 'whatsapp';
    if (/mailto:|mail|email|envelope|sicon-mail/.test(source)) return 'email';
    if (/t\.me|telegram|paper-plane|sicon-telegram/.test(source)) return 'telegram';
    if (/tel:|phone|mobile|call|sicon-phone/.test(source)) return 'phone';
    if (/https?:\/\//.test(source)) return 'website';

    return 'contact';
  }

  function velouraFooterExtractValue(link, kind) {
    const href = (link.getAttribute('href') || '').trim();

    if (kind === 'email' && href.toLowerCase().startsWith('mailto:')) {
      return href.replace(/^mailto:/i, '').split('?')[0];
    }

    if ((kind === 'phone' || kind === 'whatsapp') && href.toLowerCase().startsWith('tel:')) {
      return href.replace(/^tel:/i, '');
    }

    if (kind === 'whatsapp') {
      const wa = href.match(/(?:wa\.me\/|phone=)([0-9+]+)/i);
      if (wa && wa[1]) return wa[1];
    }

    if (kind === 'telegram') {
      const tg = href.match(/t\.me\/([^/?#]+)/i);
      if (tg && tg[1]) return '@' + tg[1];
    }

    return (link.textContent || '').replace(/\s+/g, ' ').trim();
  }

  function velouraFooterBuildContact(link) {
    if (!link || link.dataset.velouraContactReady === '1') return;

    const kind = velouraFooterDetectKind(link);
    const label = labelMap[kind] || labelMap.contact;
    const value = velouraFooterExtractValue(link, kind);
    const oldIcon = link.querySelector('i, svg, img, [class*="sicon-"]');

    const iconWrap = document.createElement('span');
    iconWrap.className = 'veloura-contact-icon';

    if (oldIcon) {
      iconWrap.appendChild(oldIcon.cloneNode(true));
    } else {
      const icon = document.createElement('i');
      icon.className = iconMap[kind] || iconMap.contact;
      iconWrap.appendChild(icon);
    }

    const texts = document.createElement('span');
    texts.className = 'veloura-contact-texts';

    const labelEl = document.createElement('span');
    labelEl.className = 'veloura-contact-label';
    labelEl.textContent = label;
    texts.appendChild(labelEl);

    if (value) {
      const valueEl = document.createElement('span');
      valueEl.className = 'veloura-contact-value';
      valueEl.textContent = value;
      texts.appendChild(valueEl);
    }

    link.innerHTML = '';
    link.classList.add('veloura-contact-item', 'veloura-contact--' + kind);
    link.appendChild(iconWrap);
    link.appendChild(texts);
    link.dataset.velouraContactReady = '1';
  }

  function velouraFooterContactsInit() {
    document.querySelectorAll('.veloura-footer-contact-list salla-contacts').forEach(function (root) {
      root.querySelectorAll('a[href]').forEach(velouraFooterBuildContact);
    });
  }

  document.addEventListener('DOMContentLoaded', velouraFooterContactsInit);
  document.addEventListener('theme::ready', velouraFooterContactsInit);
  window.addEventListener('load', velouraFooterContactsInit);
  setTimeout(velouraFooterContactsInit, 400);
  setTimeout(velouraFooterContactsInit, 1200);
  setTimeout(velouraFooterContactsInit, 2400);

  const observer = new MutationObserver(velouraFooterContactsInit);
  observer.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>

  <span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
</footer>