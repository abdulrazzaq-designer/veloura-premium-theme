        contact: '<svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm0 2c-4 0-7 2-7 4.6V20h14v-1.4C19 16 16 14 12 14Z"/></svg>',
        apple: '<svg class="veloura-footer-app-svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M16.7 13.1c0-2.1 1.7-3.1 1.8-3.2-1-.1-2-.6-2.6-1.4-1.1-.9-2.4-.7-3-.4-.6.3-1.2.4-1.8.4s-1.3-.4-2.1-.4c-1.1 0-2.1.6-2.7 1.5-1.2 2.1-.3 5.2.8 6.9.6.8 1.3 1.8 2.2 1.7.9 0 1.2-.6 2.2-.6s1.3.6 2.2.6 1.5-.8 2.1-1.7c.7-1 1-2 1-2.1 0 0-2.1-.8-2.1-3.8ZM14.2 7c.5-.6.9-1.5.8-2.3-.8 0-1.7.5-2.2 1.1-.5.6-.9 1.4-.8 2.2.8.1 1.7-.4 2.2-1Z"/></svg>',
        google: '<svg class="veloura-footer-app-svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M5.5 3.4c-.3.2-.5.6-.5 1v15.2c0 .4.2.8.5 1l8.7-8.6-8.7-8.6Zm9.8 7.5 2.1-2.1L7.8 3.3l7.5 7.6Zm0 2.2-7.5 7.6 9.6-5.5-2.1-2.1Zm.9-1.1 2.6 2.6c.5-.4.5-1.2 0-1.5L16.2 12Z"/></svg>'
      };

      const labelMap = {
        phone: 'جوال',
        whatsapp: 'واتساب',
        email: 'إيميل',
        telegram: 'تلجرام',
        instagram: 'انستغرام',
        twitter: 'إكس',
        youtube: 'يوتيوب',
        snapchat: 'سناب',
        tiktok: 'تيك توك',
        facebook: 'فيسبوك',
        website: 'الموقع',
        contact: 'تواصل'
      };

      function cleanText(el) {
        return (el.textContent || '').replace(/\s+/g, ' ').trim();
      }

      function detectKind(link, sourceType) {
        const href = (link.getAttribute('href') || '').toLowerCase();
        const aria = (link.getAttribute('aria-label') || '').toLowerCase();
        const title = (link.getAttribute('title') || '').toLowerCase();
        const classes = Array.from(link.querySelectorAll('[class]')).map(el => el.className).join(' ').toLowerCase();
        const text = cleanText(link).toLowerCase();
        const source = `${href} ${aria} ${title} ${classes} ${text}`;

        if (/wa\.me|whatsapp|واتساب/.test(source)) return 'whatsapp';
        if (/mailto:|email|mail|إيميل|بريد|envelope/.test(source)) return 'email';
        if (/t\.me|telegram|تلجرام|paper-plane/.test(source)) return 'telegram';
        if (/instagram|انستغرام/.test(source)) return 'instagram';
        if (/twitter|x\.com|إكس/.test(source)) return 'twitter';
        if (/youtube|youtu\.be|يوتيوب/.test(source)) return 'youtube';
        if (/snapchat|snap|سناب/.test(source)) return 'snapchat';
        if (/tiktok|تيك/.test(source)) return 'tiktok';
        if (/facebook|فيسبوك/.test(source)) return 'facebook';
        if (/tel:|phone|mobile|call|هاتف|جوال/.test(source)) return 'phone';
        if (sourceType === 'social') return 'website';
        if (/https?:\/\//.test(source)) return 'website';
        return 'contact';
      }

      function normalizeLink(link, sourceType) {
        if (!link || link.dataset.velouraFooterReady === '1') return;

        const kind = detectKind(link, sourceType);
        const label = labelMap[kind] || labelMap.contact;
        const icon = SVG[kind] || SVG.contact;

        link.classList.add('veloura-footer-contact-card', 'veloura-footer-contact-kind-' + kind);
        link.dataset.velouraFooterReady = '1';

        link.innerHTML =
          '<span class="veloura-footer-contact-card__icon" aria-hidden="true">' + icon + '</span>' +
          '<span class="veloura-footer-contact-card__text">' + label + '</span>';
      }

      function dedupeLinks(root) {
        const seen = new Set();

        root.querySelectorAll('a[href], button').forEach(function (link) {
          const href = (link.getAttribute('href') || '').trim().toLowerCase();
          const aria = (link.getAttribute('aria-label') || '').trim().toLowerCase();
          const text = cleanText(link).toLowerCase();
          const key = href || aria || text;

          if (!key) return;

          if (seen.has(key)) {
            const parent = link.closest('li, div') || link;
            parent.style.display = 'none';
            parent.setAttribute('data-veloura-hidden-duplicate', '1');
            return;
          }

          seen.add(key);
        });
      }

      function initContacts() {
        document.querySelectorAll('.store-footer.veloura-footer-enabled').forEach(function (footer) {
          footer.querySelectorAll('[data-veloura-footer-contacts] a[href]').forEach(function (link) {
            normalizeLink(link, 'contact');
          });

          footer.querySelectorAll('[data-veloura-footer-social] a[href], [data-veloura-footer-social] button').forEach(function (link) {
            normalizeLink(link, 'social');
          });

          footer.querySelectorAll('[data-veloura-footer-contacts], [data-veloura-footer-social]').forEach(function (root) {
            dedupeLinks(root);
          });
        });
      }

      function restoreFooterImages(root) {
        if (!root) return;

        root.querySelectorAll('img').forEach(function (img) {
          const dataSrc = img.getAttribute('data-src');
          const dataSrcset = img.getAttribute('data-srcset');

          if ((!img.getAttribute('src') || img.getAttribute('src') === '') && dataSrc) {
            img.setAttribute('src', dataSrc);
          }

          if ((!img.getAttribute('srcset') || img.getAttribute('srcset') === '') && dataSrcset) {
            img.setAttribute('srcset', dataSrcset);
          }

          img.hidden = false;
          img.style.removeProperty('display');
          img.style.removeProperty('visibility');
          img.style.removeProperty('opacity');
        });
      }

      function resolveAppsLayout(footer, forceFinal) {
        if (!footer) return;

        const appsBlock = footer.querySelector('[data-veloura-footer-apps]');

        if (!appsBlock) {
          footer.classList.remove('veloura-footer-has-apps', 'veloura-footer-layout-detecting');
          footer.classList.add('veloura-footer-no-apps');
          return;
        }

        const component = appsBlock.querySelector('salla-apps-icons');
        restoreFooterImages(appsBlock);

        const hasApps = !!appsBlock.querySelector(
          'a[href], .veloura-footer-app-button, img[src]:not([src=""]), img[data-src]'
        );

        const componentReady = !component ||
          component.classList.contains('hydrated') ||
          component.hasAttribute('hydrated');

        /* Never hide the Salla component before it hydrates, otherwise its images may never load. */
        if (!hasApps && !componentReady && !forceFinal) {
          appsBlock.hidden = false;
          appsBlock.setAttribute('aria-hidden', 'false');
          footer.classList.remove('veloura-footer-has-apps', 'veloura-footer-no-apps');
          footer.classList.add('veloura-footer-layout-detecting');
          return;
        }

        footer.classList.toggle('veloura-footer-has-apps', hasApps);
        footer.classList.toggle('veloura-footer-no-apps', !hasApps);
        footer.classList.remove('veloura-footer-layout-detecting');

        appsBlock.hidden = !hasApps;
        appsBlock.setAttribute('aria-hidden', hasApps ? 'false' : 'true');
      }

      function watchAppsLayout(footer) {
        const appsBlock = footer.querySelector('[data-veloura-footer-apps]');
        if (!appsBlock || appsBlock.dataset.velouraLayoutObserver === '1') return;

        appsBlock.dataset.velouraLayoutObserver = '1';

        const observer = new MutationObserver(function () {
          restoreFooterImages(appsBlock);
          resolveAppsLayout(footer, false);
        });

        /* childList only: observing attributes caused a loop when hidden/aria-hidden changed. */
        observer.observe(appsBlock, { childList: true, subtree: true });

        const component = appsBlock.querySelector('salla-apps-icons');
        if (component && typeof component.componentOnReady === 'function') {
          component.componentOnReady().then(function () {
            restoreFooterImages(appsBlock);
            resolveAppsLayout(footer, true);
          });
        } else if (window.customElements && customElements.whenDefined) {
          customElements.whenDefined('salla-apps-icons').then(function () {
            window.setTimeout(function () {
              restoreFooterImages(appsBlock);
              resolveAppsLayout(footer, true);
            }, 0);
          });
        }
      }

      function initVelouraFooter() {
        initContacts();
        document.querySelectorAll('.store-footer.veloura-footer-enabled').forEach(function (footer) {
          restoreFooterImages(footer);
          resolveAppsLayout(footer, false);
          watchAppsLayout(footer);
        });
      }

      document.addEventListener('DOMContentLoaded', initVelouraFooter);
      document.addEventListener('theme::ready', initVelouraFooter);
      setTimeout(initVelouraFooter, 300);
      setTimeout(initVelouraFooter, 900);
      setTimeout(initVelouraFooter, 1800);
      setTimeout(function () {
        document.querySelectorAll('.store-footer.veloura-footer-enabled').forEach(function (footer) {
          restoreFooterImages(footer);
          resolveAppsLayout(footer, true);
        });
      }, 4500);
    })();
  </script>

  <span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
</footer>
