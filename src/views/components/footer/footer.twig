{% set footer_enabled = true %}

{% macro veloura_select_value(raw, fallback) %}
  {% if raw.selected is defined and raw.selected[0].value is defined %}
    {{ raw.selected[0].value }}
  {% elseif raw.value is defined %}
    {{ raw.value }}
  {% elseif raw is iterable and raw[0].value is defined %}
    {{ raw[0].value }}
  {% elseif raw %}
    {{ raw }}
  {% else %}
    {{ fallback }}
  {% endif %}
{% endmacro %}

{% set light_logo_url = theme.settings.get('veloura_light_logo_url_2026') %}
{% set light_logo_image = theme.settings.get('veloura_light_logo_2026') %}
{% set veloura_light_logo = light_logo_url ?: light_logo_image %}

{% set footer_logo_url = theme.settings.get('veloura_footer_logo_url_2026') %}
{% set footer_logo_image = theme.settings.get('veloura_footer_logo_image_2026') %}
{% set footer_logo = footer_logo_url ?: footer_logo_image ?: veloura_light_logo ?: store.logo|cdn(175) %}
{% set footer_logo_lower = footer_logo|lower %}
{% set footer_logo_is_video = footer_logo_lower ends with '.webm' or footer_logo_lower ends with '.mp4' %}

{# Colors #}
{% set footer_bg = theme.settings.get('veloura_footer_bg_color_2026', '#f8fafc') %}
{% if footer_bg.value is defined %}{% set footer_bg = footer_bg.value %}{% endif %}

{% set footer_text = theme.settings.get('veloura_footer_text_color_2026', '#0f172a') %}
{% if footer_text.value is defined %}{% set footer_text = footer_text.value %}{% endif %}

{% set footer_title_color = theme.settings.get('veloura_footer_title_color_2026', '#0f172a') %}
{% if footer_title_color.value is defined %}{% set footer_title_color = footer_title_color.value %}{% endif %}

{% set footer_link_color = theme.settings.get('veloura_footer_link_color_2026', '#334155') %}
{% if footer_link_color.value is defined %}{% set footer_link_color = footer_link_color.value %}{% endif %}

{% set footer_icon_bg = theme.settings.get('veloura_footer_icon_bg_color_2026', '#ffffff') %}
{% if footer_icon_bg.value is defined %}{% set footer_icon_bg = footer_icon_bg.value %}{% endif %}

{% set footer_icon_color = theme.settings.get('veloura_footer_icon_color_2026', '#26265c') %}
{% if footer_icon_color.value is defined %}{% set footer_icon_color = footer_icon_color.value %}{% endif %}

{% set footer_contact_border = theme.settings.get('veloura_footer_contact_border_color_2026', '#26265c') %}
{% if footer_contact_border.value is defined %}{% set footer_contact_border = footer_contact_border.value %}{% endif %}

{% set footer_bottom_bg = theme.settings.get('veloura_footer_bottom_bg_2026', '#ffffff') %}
{% if footer_bottom_bg.value is defined %}{% set footer_bottom_bg = footer_bottom_bg.value %}{% endif %}

{% set footer_bottom_text_color = theme.settings.get('veloura_footer_bottom_text_color_2026', '#334155') %}
{% if footer_bottom_text_color.value is defined %}{% set footer_bottom_text_color = footer_bottom_text_color.value %}{% endif %}

{# Dropdowns #}
{% set footer_radius = _self.veloura_select_value(theme.settings.get('veloura_footer_radius_2026', 'medium'), 'medium')|trim %}
{% set footer_columns = _self.veloura_select_value(theme.settings.get('veloura_footer_columns_desktop_2026', '4'), '4')|trim %}
{% set footer_contact_display = _self.veloura_select_value(theme.settings.get('veloura_footer_contact_display_2026', 'icon_text'), 'icon_text')|trim %}
{% set footer_title_size_key = _self.veloura_select_value(theme.settings.get('veloura_footer_title_size_2026', 'large'), 'large')|trim %}
{% set footer_text_size_key = _self.veloura_select_value(theme.settings.get('veloura_footer_text_size_2026', 'medium'), 'medium')|trim %}
{% set footer_logo_size_key = _self.veloura_select_value(theme.settings.get('veloura_footer_logo_size_2026', 'medium'), 'medium')|trim %}

{% if footer_contact_display not in ['icons_only', 'icon_text'] %}
  {% set footer_contact_display = 'icon_text' %}
{% endif %}

{% set title_size_map = {'small':'16px','medium':'20px','large':'24px','xlarge':'30px'} %}
{% set text_size_map = {'small':'13px','medium':'15px','large':'17px'} %}
{% set logo_size_map = {'small':'64px','medium':'84px','large':'108px'} %}

{% set footer_title_size = title_size_map[footer_title_size_key]|default('24px') %}
{% set footer_text_size = text_size_map[footer_text_size_key]|default('15px') %}
{% set footer_logo_size = logo_size_map[footer_logo_size_key]|default('84px') %}

{# Switches #}
{% set footer_center_all = theme.settings.get('veloura_footer_center_all_2026', false) %}
{% if footer_center_all.value is defined %}{% set footer_center_all = footer_center_all.value %}{% endif %}

{% set footer_hide_logo = theme.settings.get('veloura_footer_hide_logo_2026', false) %}
{% if footer_hide_logo.value is defined %}{% set footer_hide_logo = footer_hide_logo.value %}{% endif %}

{% set footer_hide_apps = theme.settings.get('veloura_footer_hide_apps_2026', false) %}
{% if footer_hide_apps.value is defined %}{% set footer_hide_apps = footer_hide_apps.value %}{% endif %}

{% set footer_hide_apps_title = theme.settings.get('veloura_footer_hide_apps_title_2026', false) %}
{% if footer_hide_apps_title.value is defined %}{% set footer_hide_apps_title = footer_hide_apps_title.value %}{% endif %}

{% set footer_featured_apps = theme.settings.get('veloura_footer_featured_apps_2026', false) %}
{% if footer_featured_apps.value is defined %}{% set footer_featured_apps = footer_featured_apps.value %}{% endif %}

{% set footer_hide_links = theme.settings.get('veloura_footer_hide_links_2026', false) %}
{% if footer_hide_links.value is defined %}{% set footer_hide_links = footer_hide_links.value %}{% endif %}

{% set footer_hide_payments = theme.settings.get('veloura_footer_hide_payments_2026', false) %}
{% if footer_hide_payments.value is defined %}{% set footer_hide_payments = footer_hide_payments.value %}{% endif %}

{% set footer_merge_social = theme.settings.get('veloura_footer_merge_social_with_contacts_2026', false) %}
{% if footer_merge_social.value is defined %}{% set footer_merge_social = footer_merge_social.value %}{% endif %}

{# Texts #}
{% set footer_store_title = theme.settings.get('veloura_footer_store_title_2026') ?: store.name %}
{% set footer_store_description = theme.settings.get('veloura_footer_store_description_2026') ?: store.description %}
{% set footer_links_title = theme.settings.get('veloura_footer_links_title_2026') ?: trans('blocks.footer.pages_links') %}
{% set footer_contact_title = theme.settings.get('veloura_footer_contact_title_2026') ?: 'تواصل معنا' %}
{% set footer_apps_title = theme.settings.get('veloura_footer_apps_title_2026') ?: 'تحميل تطبيق الجوال' %}
{% set footer_bottom_text = theme.settings.get('veloura_footer_bottom_text_2026') %}

{% set footer_bg_image = theme.settings.get('veloura_footer_bg_image_2026') %}
{% if footer_bg_image.value is defined %}{% set footer_bg_image = footer_bg_image.value %}{% endif %}

<footer
  class="store-footer
  veloura-footer-enabled
  {{ footer_center_all ? 'veloura-footer-center-all' : 'veloura-footer-align-default' }}
  {{ footer_merge_social ? 'veloura-footer-merge-social' : '' }}
  {{ footer_featured_apps ? 'veloura-footer-featured-apps' : '' }}
  {{ footer_hide_apps_title ? 'veloura-footer-hide-apps-title' : '' }}
  veloura-footer-radius-{{ footer_radius }}
  veloura-footer-cols-{{ footer_columns }}
  veloura-footer-contact-display-{{ footer_contact_display }}
  "
  style="
    --veloura-footer-bg: {{ footer_bg }};
    --veloura-footer-text: {{ footer_text }};
    --veloura-footer-title: {{ footer_title_color }};
    --veloura-footer-link: {{ footer_link_color }};
    --veloura-footer-icon-bg: {{ footer_icon_bg }};
    --veloura-footer-icon-color: {{ footer_icon_color }};
    --veloura-footer-contact-border: {{ footer_contact_border }};
    --veloura-footer-bottom-bg: {{ footer_bottom_bg }};
    --veloura-footer-bottom-text: {{ footer_bottom_text_color }};
    --veloura-footer-title-size: {{ footer_title_size }};
    --veloura-footer-text-size: {{ footer_text_size }};
    --veloura-footer-logo-size: {{ footer_logo_size }};
    {% if footer_bg_image %}
      --veloura-footer-bg-image: url('{{ footer_bg_image }}');
    {% endif %}
  "
>
  <div aria-label="footer" class="store-footer__inner veloura-footer-main">
    <div class="veloura-footer-container">
      <div class="veloura-footer-grid">

        <div class="veloura-footer-block veloura-footer-store">
          {% if not footer_hide_logo %}
            <a href="{{ link('/') }}" class="veloura-footer-logo" aria-label="{{ store.name }}">
              {% if footer_logo_is_video %}
                <video class="veloura-footer-logo__media" src="{{ footer_logo }}" autoplay muted loop playsinline></video>
              {% else %}
                <img class="veloura-footer-logo__media" src="{{ footer_logo }}" loading="lazy" alt="{{ store.name }}">
              {% endif %}
            </a>
          {% endif %}

          <h3 class="veloura-footer-title">{{ footer_store_title }}</h3>

          {% if footer_store_description %}
            <div class="veloura-footer-description">
              {{ footer_store_description|raw }}
            </div>
          {% endif %}

          {% if not footer_merge_social %}
            <div class="veloura-footer-social veloura-footer-social-store" data-veloura-footer-social>
              <salla-social></salla-social>
            </div>
          {% endif %}

          <div class="veloura-footer-trust">
            <salla-trust-badges {% if theme.settings.get('footer_is_dark') %} dark {% endif %}></salla-trust-badges>

            {% if store.settings.tax.number %}
              <div class="veloura-footer-tax">
                {% if store.settings.tax.certificate %}
                  <a class="load-img-onclick" data-modal-id="modal-value-tax" href="#/" alt="{{ store.settings.tax.number }}">
                    <img width="40" height="50" src="{{ 'images/tax.png' | cdn(70,70) }}" loading="lazy" alt="value added tax">
                  </a>
                {% endif %}

                <div>
                  <p>{{ trans('common.elements.tax_number') }}</p>
                  <b>{{ store.settings.tax.number }}</b>
                </div>
              </div>

              {% if store.settings.tax.certificate %}
                <salla-modal sub-title-first sub-title="{{ trans('common.elements.tax_number') }}" modal-title="{{ store.settings.tax.number }}" id="modal-value-tax">
                  <div class="flex justify-center max-w-full">
                    <img class="w-full" loading="lazy" data-src="{{ store.settings.tax.certificate }}" alt="{{ store.settings.tax.number }}"/>
                  </div>
                </salla-modal>
              {% endif %}
            {% endif %}
          </div>
        </div>

        {% if not footer_hide_links %}
          <div class="veloura-footer-block veloura-footer-links">
            <h3 class="veloura-footer-title">{{ footer_links_title }}</h3>
            <salla-menu source="footer" with-cookie-preferences></salla-menu>
          </div>
        {% endif %}

        <div class="veloura-footer-block veloura-footer-contact">
          <h3 class="veloura-footer-title">{{ footer_contact_title }}</h3>

          <div class="veloura-footer-contact-wrap">
            <div class="veloura-footer-contact-native" data-veloura-footer-contacts>
              <salla-contacts></salla-contacts>
            </div>

            {% if footer_merge_social %}
              <div class="veloura-footer-social veloura-footer-social-contact veloura-footer-social-merged" data-veloura-footer-social>
                <salla-social></salla-social>
              </div>
            {% endif %}
          </div>
        </div>

        {% if not footer_hide_apps %}
          <div class="veloura-footer-block veloura-footer-apps">
            {% if not footer_hide_apps_title %}
              <h3 class="veloura-footer-title">{{ footer_apps_title }}</h3>
            {% endif %}
            <salla-apps-icons></salla-apps-icons>
          </div>
        {% endif %}

      </div>
    </div>
  </div>

  <div class="veloura-footer-bottom">
    <div class="veloura-footer-container veloura-footer-bottom__inner">
      <span class="veloura-footer-copyright">
        {% if footer_bottom_text %}
          {{ footer_bottom_text }}
        {% else %}
          {% hook copyright %}
        {% endif %}
      </span>

      {% if not footer_hide_payments %}
        <salla-payments></salla-payments>
      {% endif %}
    </div>
  </div>

  <script>
    (function () {
      const labelMap = {
        phone: 'جوال',
        whatsapp: 'واتساب',
        email: 'إيميل',
        telegram: 'تلجرام',
        instagram: 'انستغرام',
        twitter: 'إكس',
        youtube: 'يوتيوب',
        snapchat: 'سناب',
        tiktok: 'تيك توك',
        facebook: 'فيسبوك',
        website: 'الموقع',
        contact: 'تواصل'
      };

      const iconMap = {
        phone: 'sicon-phone',
        whatsapp: 'sicon-whatsapp',
        email: 'sicon-mail',
        telegram: 'sicon-telegram',
        instagram: 'sicon-instagram',
        twitter: 'sicon-twitter',
        youtube: 'sicon-youtube',
        snapchat: 'sicon-snapchat',
        tiktok: 'sicon-tiktok',
        facebook: 'sicon-facebook',
        website: 'sicon-globe',
        contact: 'sicon-phone'
      };

      function cleanText(el) {
        return (el.textContent || '').replace(/\s+/g, ' ').trim();
      }

      function detectKind(link, sourceType) {
        const href = (link.getAttribute('href') || '').toLowerCase();
        const aria = (link.getAttribute('aria-label') || '').toLowerCase();
        const title = (link.getAttribute('title') || '').toLowerCase();
        const classes = Array.from(link.querySelectorAll('[class]')).map(el => el.className).join(' ').toLowerCase();
        const text = cleanText(link).toLowerCase();
        const source = `${href} ${aria} ${title} ${classes} ${text}`;

        if (/wa\.me|whatsapp|واتساب|sicon-whatsapp/.test(source)) return 'whatsapp';
        if (/mailto:|email|mail|إيميل|بريد|envelope|sicon-mail/.test(source)) return 'email';
        if (/t\.me|telegram|تلجرام|paper-plane|sicon-telegram/.test(source)) return 'telegram';
        if (/instagram|انستغرام|sicon-instagram/.test(source)) return 'instagram';
        if (/twitter|x\.com|إكس|sicon-twitter/.test(source)) return 'twitter';
        if (/youtube|youtu\.be|يوتيوب|sicon-youtube/.test(source)) return 'youtube';
        if (/snapchat|snap|سناب|sicon-snapchat/.test(source)) return 'snapchat';
        if (/tiktok|تيك|sicon-tiktok/.test(source)) return 'tiktok';
        if (/facebook|فيسبوك|sicon-facebook/.test(source)) return 'facebook';
        if (/tel:|phone|mobile|call|هاتف|جوال|sicon-phone/.test(source)) return 'phone';
        if (sourceType === 'social') return 'website';
        if (/https?:\/\//.test(source)) return 'website';
        return 'contact';
      }

      function getValue(link, kind, sourceType) {
        if (sourceType === 'social') return '';
        const href = (link.getAttribute('href') || '').trim();

        if (kind === 'email' && href.indexOf('mailto:') === 0) {
          return href.replace(/^mailto:/i, '').split('?')[0];
        }

        if ((kind === 'phone' || kind === 'whatsapp') && href.indexOf('tel:') === 0) {
          return href.replace(/^tel:/i, '');
        }

        if (kind === 'telegram') {
          const match = href.match(/t\.me\/([^/?#]+)/i);
          if (match) return '@' + match[1];
        }

        const clone = link.cloneNode(true);
        clone.querySelectorAll('i, svg, img').forEach(el => el.remove());
        return cleanText(clone);
      }

      function getBestIcon(link, kind) {
        const oldIcon = link.querySelector('i[class], svg, img');
        if (oldIcon && oldIcon.tagName && oldIcon.tagName.toLowerCase() === 'i' && oldIcon.className) {
          return '<i class="' + oldIcon.className + '"></i>';
        }
        return '<i class="' + (iconMap[kind] || iconMap.contact) + '"></i>';
      }

      function normalizeLink(link, sourceType) {
        if (!link || link.dataset.velouraFooterReady === '1') return;

        const kind = detectKind(link, sourceType);
        const label = labelMap[kind] || labelMap.contact;
        const value = getValue(link, kind, sourceType);
        const icon = getBestIcon(link, kind);

        link.classList.add('veloura-footer-contact-card', 'veloura-footer-contact-kind-' + kind);
        link.dataset.velouraFooterKind = kind;
        link.dataset.velouraFooterReady = '1';

        link.innerHTML =
          '<span class="veloura-footer-contact-card__icon" aria-hidden="true">' + icon + '</span>' +
          '<span class="veloura-footer-contact-card__texts">' +
            '<span class="veloura-footer-contact-card__label">' + label + '</span>' +
            (value ? '<span class="veloura-footer-contact-card__value">' + value + '</span>' : '') +
          '</span>';
      }

      function initFooterContacts() {
        document.querySelectorAll('.store-footer.veloura-footer-enabled').forEach(function (footer) {
          const merged = footer.classList.contains('veloura-footer-merge-social');

          footer.querySelectorAll('[data-veloura-footer-contacts] a[href]').forEach(function (link) {
            normalizeLink(link, 'contact');
          });

          if (merged) {
            footer.querySelectorAll('[data-veloura-footer-social] a[href], [data-veloura-footer-social] button').forEach(function (link) {
              normalizeLink(link, 'social');
            });
          }
        });
      }

      function initFeaturedApps() {
        document.querySelectorAll('.store-footer.veloura-footer-featured-apps .veloura-footer-apps salla-apps-icons a[href]').forEach(function (link) {
          if (link.dataset.velouraAppReady === '1') return;

          const source = ((link.getAttribute('href') || '') + ' ' + cleanText(link) + ' ' + Array.from(link.querySelectorAll('img')).map(img => ((img.getAttribute('alt') || '') + ' ' + (img.getAttribute('src') || ''))).join(' ')).toLowerCase();

          const isApple = /apple|app store|ios/.test(source);
          const label = isApple ? 'App Store' : 'Google Play';

          const svg = isApple
            ? '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M16.7 13.1c0-2.1 1.7-3.1 1.8-3.2-1-.1-2-.6-2.6-1.4-1.1-.9-2.4-.7-3-.4-.6.3-1.2.4-1.8.4s-1.3-.4-2.1-.4c-1.1 0-2.1.6-2.7 1.5-1.2 2.1-.3 5.2.8 6.9.6.8 1.3 1.8 2.2 1.7.9 0 1.2-.6 2.2-.6s1.3.6 2.2.6 1.5-.8 2.1-1.7c.7-1 1-2 1-2.1 0 0-2.1-.8-2.1-3.8ZM14.2 7c.5-.6.9-1.5.8-2.3-.8 0-1.7.5-2.2 1.1-.5.6-.9 1.4-.8 2.2.8.1 1.7-.4 2.2-1Z"/></svg>'
            : '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M5 3.8v16.4c0 .6.7.9 1.2.6l9.1-8.2c.3-.3.3-.8 0-1.1L6.2 3.2C5.7 2.9 5 3.2 5 3.8Zm11.5 7.1 2.1-1.2c.6-.4.6-1.2 0-1.5L8.3 2.4l8.2 8.5Zm0 2.2-8.2 8.5 10.3-5.8c.6-.3.6-1.2 0-1.5l-2.1-1.2Z"/></svg>';

          link.classList.add('veloura-footer-app-button');
          link.innerHTML =
            '<span class="veloura-footer-app-button__icon">' + svg + '</span>' +
            '<span class="veloura-footer-app-button__text">' + label + '</span>';

          link.dataset.velouraAppReady = '1';
        });
      }

      function initVelouraFooter() {
        initFooterContacts();
        initFeaturedApps();
      }

      document.addEventListener('DOMContentLoaded', initVelouraFooter);
      document.addEventListener('theme::ready', initVelouraFooter);
      setTimeout(initVelouraFooter, 300);
      setTimeout(initVelouraFooter, 900);
      setTimeout(initVelouraFooter, 1800);
      setTimeout(initVelouraFooter, 3000);
    })();
  </script>

  <span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
</footer>
