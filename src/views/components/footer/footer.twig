      const labelMap = {
        phone: 'جوال',
        whatsapp: 'واتساب',
        email: 'إيميل',
        telegram: 'تلجرام',
        instagram: 'انستغرام',
        twitter: 'إكس',
        youtube: 'يوتيوب',
        snapchat: 'سناب',
        tiktok: 'تيك توك',
        facebook: 'فيسبوك',
        website: 'الموقع',
        contact: 'تواصل'
      };

      const iconMap = {
        phone: 'sicon-phone',
        whatsapp: 'sicon-whatsapp',
        email: 'sicon-mail',
        telegram: 'sicon-telegram',
        instagram: 'sicon-instagram',
        twitter: 'sicon-twitter',
        youtube: 'sicon-youtube',
        snapchat: 'sicon-snapchat',
        tiktok: 'sicon-tiktok',
        facebook: 'sicon-facebook',
        website: 'sicon-globe',
        contact: 'sicon-phone'
      };

      function cleanText(el) {
        return (el.textContent || '').replace(/\s+/g, ' ').trim();
      }

      function detectKind(link, sourceType) {
        const href = (link.getAttribute('href') || '').toLowerCase();
        const aria = (link.getAttribute('aria-label') || '').toLowerCase();
        const title = (link.getAttribute('title') || '').toLowerCase();
        const classes = Array.from(link.querySelectorAll('[class]')).map(el => el.className).join(' ').toLowerCase();
        const text = cleanText(link).toLowerCase();
        const source = `${href} ${aria} ${title} ${classes} ${text}`;

        if (/wa\.me|whatsapp|واتساب|sicon-whatsapp/.test(source)) return 'whatsapp';
        if (/mailto:|email|mail|إيميل|بريد|envelope|sicon-mail/.test(source)) return 'email';
        if (/t\.me|telegram|تلجرام|paper-plane|sicon-telegram/.test(source)) return 'telegram';
        if (/instagram|انستغرام|sicon-instagram/.test(source)) return 'instagram';
        if (/twitter|x\.com|إكس|sicon-twitter/.test(source)) return 'twitter';
        if (/youtube|youtu\.be|يوتيوب|sicon-youtube/.test(source)) return 'youtube';
        if (/snapchat|snap|سناب|sicon-snapchat/.test(source)) return 'snapchat';
        if (/tiktok|تيك|sicon-tiktok/.test(source)) return 'tiktok';
        if (/facebook|فيسبوك|sicon-facebook/.test(source)) return 'facebook';
        if (/tel:|phone|mobile|call|هاتف|جوال|sicon-phone/.test(source)) return 'phone';
        if (sourceType === 'social') return 'website';
        if (/https?:\/\//.test(source)) return 'website';
        return 'contact';
      }

      function getBestIcon(link, kind) {
        const oldIcon = link.querySelector('i[class], svg, img');
        if (oldIcon && oldIcon.tagName && oldIcon.tagName.toLowerCase() === 'i' && oldIcon.className) {
          return '<i class="' + oldIcon.className + '"></i>';
        }
        return '<i class="' + (iconMap[kind] || iconMap.contact) + '"></i>';
      }

      function normalizeLink(link, sourceType) {
        if (!link || link.dataset.velouraFooterReady === '1') return;

        const kind = detectKind(link, sourceType);
        const label = labelMap[kind] || labelMap.contact;

        link.classList.add('veloura-footer-contact-card', 'veloura-footer-contact-kind-' + kind);
        link.dataset.velouraFooterReady = '1';

        link.innerHTML =
          '<span class="veloura-footer-contact-card__icon" aria-hidden="true">' + getBestIcon(link, kind) + '</span>' +
          '<span class="veloura-footer-contact-card__text">' + label + '</span>';
      }

      function initContacts() {
        document.querySelectorAll('.store-footer.veloura-footer-enabled').forEach(function (footer) {
          const merged = footer.classList.contains('veloura-footer-merge-social');

          footer.querySelectorAll('[data-veloura-footer-contacts] a[href]').forEach(function (link) {
            normalizeLink(link, 'contact');
          });

          if (merged) {
            footer.querySelectorAll('[data-veloura-footer-social] a[href], [data-veloura-footer-social] button').forEach(function (link) {
              normalizeLink(link, 'social');
            });
          }
        });
      }

      function initFeaturedApps() {
        document.querySelectorAll('.store-footer.veloura-footer-featured-apps .veloura-footer-apps salla-apps-icons a[href]').forEach(function (link) {
          if (link.dataset.velouraAppReady === '1') return;

          const source = (
            (link.getAttribute('href') || '') + ' ' +
            cleanText(link) + ' ' +
            Array.from(link.querySelectorAll('img')).map(function (img) {
              return (img.getAttribute('alt') || '') + ' ' + (img.getAttribute('src') || '');
            }).join(' ')
          ).toLowerCase();

          const isApple = /apple|app store|ios/.test(source);
          const label = isApple ? 'App Store' : 'Google Play';
          const svg = isApple ? APP_STORE_SVG : GOOGLE_PLAY_SVG;

          link.classList.add('veloura-footer-app-button');
          link.innerHTML =
            '<span class="veloura-footer-app-button__icon">' + svg + '</span>' +
            '<span class="veloura-footer-app-button__text">' + label + '</span>';

          link.dataset.velouraAppReady = '1';
        });
      }

      function initVelouraFooter() {
        initContacts();
        initFeaturedApps();
      }

      document.addEventListener('DOMContentLoaded', initVelouraFooter);
      document.addEventListener('theme::ready', initVelouraFooter);
      setTimeout(initVelouraFooter, 300);
      setTimeout(initVelouraFooter, 900);
      setTimeout(initVelouraFooter, 1800);
      setTimeout(initVelouraFooter, 3000);
    })();
  </script>

  <span class="hidden bottom-2 rtl:pl-24 ltr:pr-24 md:grid-cols-3 opacity-40"></span>
</footer>
