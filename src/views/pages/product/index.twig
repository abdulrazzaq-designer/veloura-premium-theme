{#
| Variable                   | Type        | Description                                                          |
|----------------------------|-------------|----------------------------------------------------------------------|
| page                       | object      |                                                                      |
| page.title                 | string      | *could be html                                                       |
| page.slug                  | string      | ex: "cat.show"                                                       |
| category                   | ?Category   |                                                                      |
| category.name              | string      |                                                                      |
| category.url               | string      |                                                                      |
| category.sub_categories    | ?Category[] |                                                                      |
| category.image             | ?string     |                                                                      |
| filters                    | bool        | is filters allowed here or not                                       |
| sort_options[]             | SortList[]  |                                                                      |
| sort_options[].id          | string      | ourSuggest, bestSell, topRated, priceFromTopToLow, priceFromLowToTop |
| sort_options[].name        | string      |                                                                      |
| sort_options[].is_selected | bool        | Is current page sorted by it                                         |
| search_query               | ?string     |                                                                      |
#}

{% extends "layouts.master" %}

{% block content %}

  {% set veloura_show_breadcrumb = theme.settings.get('veloura_category_show_breadcrumb_2026', true) %}
  {% if veloura_show_breadcrumb.value is defined %}
    {% set veloura_show_breadcrumb = veloura_show_breadcrumb.value %}
  {% endif %}

  {% set veloura_hide_product_count = theme.settings.get('veloura_category_hide_product_count_2026', false) %}
  {% if veloura_hide_product_count.value is defined %}
    {% set veloura_hide_product_count = veloura_hide_product_count.value %}
  {% endif %}

  {# إخفاء المنتجات عند وجود تصنيفات فرعية #}
  {% set veloura_hide_products_if_children_raw = theme.settings.get('veloura_category_hide_products_if_children_2026', false) %}
  {% if veloura_hide_products_if_children_raw.value is defined %}
    {% set veloura_hide_products_if_children_raw = veloura_hide_products_if_children_raw.value %}
  {% elseif veloura_hide_products_if_children_raw.selected is defined %}
    {% set veloura_hide_products_if_children_raw = veloura_hide_products_if_children_raw.selected %}
  {% endif %}

  {% set veloura_hide_products_if_children =
    veloura_hide_products_if_children_raw == true
    or veloura_hide_products_if_children_raw == 'true'
    or veloura_hide_products_if_children_raw == 1
    or veloura_hide_products_if_children_raw == '1'
    or veloura_hide_products_if_children_raw == 'on'
  %}

  {# إظهار / إخفاء صور التصنيفات #}
  {% set veloura_show_images_raw = theme.settings.get('veloura_category_show_images_2026', true) %}
  {% if veloura_show_images_raw.selected is defined %}
    {% set veloura_show_images_raw = veloura_show_images_raw.selected %}
  {% elseif veloura_show_images_raw.value is defined %}
    {% set veloura_show_images_raw = veloura_show_images_raw.value %}
  {% endif %}

  {% set veloura_show_images =
    veloura_show_images_raw == true
    or veloura_show_images_raw == 'true'
    or veloura_show_images_raw == 1
    or veloura_show_images_raw == '1'
    or veloura_show_images_raw == 'on'
  %}

  {# سلايدر / شبكة #}
  {% set veloura_images_slider_raw = theme.settings.get('veloura_category_images_slider_2026', false) %}
  {% if veloura_images_slider_raw.value is defined %}
    {% set veloura_images_slider_raw = veloura_images_slider_raw.value %}
  {% elseif veloura_images_slider_raw.selected is defined %}
    {% set veloura_images_slider_raw = veloura_images_slider_raw.selected %}
  {% endif %}

  {% set veloura_images_slider =
    veloura_images_slider_raw == true
    or veloura_images_slider_raw == 'true'
    or veloura_images_slider_raw == 1
    or veloura_images_slider_raw == '1'
    or veloura_images_slider_raw == 'on'
  %}

  {# خلفية الصور شفافة #}
  {% set veloura_images_transparent_raw = theme.settings.get('veloura_category_images_transparent_bg_2026', false) %}
  {% if veloura_images_transparent_raw.value is defined %}
    {% set veloura_images_transparent_raw = veloura_images_transparent_raw.value %}
  {% elseif veloura_images_transparent_raw.selected is defined %}
    {% set veloura_images_transparent_raw = veloura_images_transparent_raw.selected %}
  {% endif %}

  {% set veloura_images_transparent =
    veloura_images_transparent_raw == true
    or veloura_images_transparent_raw == 'true'
    or veloura_images_transparent_raw == 1
    or veloura_images_transparent_raw == '1'
    or veloura_images_transparent_raw == 'on'
  %}

  {# الأعمدة #}
  {% set veloura_mobile_cols_raw = theme.settings.get('veloura_category_mobile_cols_2026', '4') %}
  {% set veloura_desktop_cols_raw = theme.settings.get('veloura_category_desktop_cols_2026', '8') %}

  {% if veloura_mobile_cols_raw.value is defined %}
    {% set veloura_mobile_cols_raw = veloura_mobile_cols_raw.value %}
  {% endif %}

  {% if veloura_desktop_cols_raw.value is defined %}
    {% set veloura_desktop_cols_raw = veloura_desktop_cols_raw.value %}
  {% endif %}

  {% set veloura_mobile_cols = veloura_mobile_cols_raw + 0 %}
  {% set veloura_desktop_cols = veloura_desktop_cols_raw + 0 %}

  {% if veloura_mobile_cols < 2 %}
    {% set veloura_mobile_cols = 2 %}
  {% endif %}

  {% if veloura_mobile_cols > 6 %}
    {% set veloura_mobile_cols = 6 %}
  {% endif %}

  {% if veloura_desktop_cols < 3 %}
    {% set veloura_desktop_cols = 3 %}
  {% endif %}

  {% if veloura_desktop_cols > 8 %}
    {% set veloura_desktop_cols = 8 %}
  {% endif %}

  {# مثل slidesPerView: 4.35 بدون padding وبدون فراغ يمين #}
  {% set veloura_mobile_slides = veloura_mobile_cols + 0.35 %}
  {% set veloura_desktop_slides = veloura_desktop_cols + 0.35 %}

  {# خيارات الشكل #}
  {% set veloura_title_size = theme.settings.get('veloura_category_title_size_2026', 'medium') %}
  {% if veloura_title_size.value is defined %}
    {% set veloura_title_size = veloura_title_size.value %}
  {% endif %}

  {% set veloura_image_radius = theme.settings.get('veloura_category_image_radius_2026', 'round') %}
  {% if veloura_image_radius.value is defined %}
    {% set veloura_image_radius = veloura_image_radius.value %}
  {% endif %}

  {% set veloura_image_shape = theme.settings.get('veloura_category_image_shape_2026', 'square') %}
  {% if veloura_image_shape.value is defined %}
    {% set veloura_image_shape = veloura_image_shape.value %}
  {% endif %}

  {% set veloura_image_fit = theme.settings.get('veloura_category_image_fit_2026', 'cover') %}
  {% if veloura_image_fit.value is defined %}
    {% set veloura_image_fit = veloura_image_fit.value %}
  {% endif %}

  {% set veloura_image_position = theme.settings.get('veloura_category_image_position_2026', 'top') %}
  {% if veloura_image_position.value is defined %}
    {% set veloura_image_position = veloura_image_position.value %}
  {% endif %}

  {# الصور المخصصة #}
  {% set veloura_use_custom_images_raw = theme.settings.get('veloura_category_use_custom_images_2026', false) %}
  {% if veloura_use_custom_images_raw.value is defined %}
    {% set veloura_use_custom_images_raw = veloura_use_custom_images_raw.value %}
  {% elseif veloura_use_custom_images_raw.selected is defined %}
    {% set veloura_use_custom_images_raw = veloura_use_custom_images_raw.selected %}
  {% endif %}

  {% set veloura_use_custom_images =
    veloura_use_custom_images_raw == true
    or veloura_use_custom_images_raw == 'true'
    or veloura_use_custom_images_raw == 1
    or veloura_use_custom_images_raw == '1'
    or veloura_use_custom_images_raw == 'on'
  %}

  {% set veloura_linked_images = theme.settings.get('veloura_category_images_map_v7_2026') ?: [] %}

  {% set has_sub_categories = category and category.sub_categories and category.sub_categories|length %}


  {# ================================
     Veloura Simple Category Banners 2026
     صورة + تصنيف + رابط + ترتيب + حواف فقط
  ================================ #}

  {% set veloura_cat_banner_items = theme.settings.get('veloura_cat_banner_map_2026') ?: [] %}

  {% set veloura_cat_banner_layout_raw = theme.settings.get('veloura_cat_banner_layout_2026', 'normal') %}
  {% if veloura_cat_banner_layout_raw.selected is defined and veloura_cat_banner_layout_raw.selected[0].value is defined %}
    {% set veloura_cat_banner_layout = veloura_cat_banner_layout_raw.selected[0].value %}
  {% elseif veloura_cat_banner_layout_raw is iterable and veloura_cat_banner_layout_raw[0].value is defined %}
    {% set veloura_cat_banner_layout = veloura_cat_banner_layout_raw[0].value %}
  {% elseif veloura_cat_banner_layout_raw.value is defined %}
    {% set veloura_cat_banner_layout = veloura_cat_banner_layout_raw.value %}
  {% else %}
    {% set veloura_cat_banner_layout = veloura_cat_banner_layout_raw %}
  {% endif %}

  {% if veloura_cat_banner_layout != 'centered' %}
    {% set veloura_cat_banner_layout = 'normal' %}
  {% endif %}

  {% set veloura_cat_banner_radius_raw = theme.settings.get('veloura_cat_banner_radius_2026', 'medium') %}
  {% if veloura_cat_banner_radius_raw.selected is defined and veloura_cat_banner_radius_raw.selected[0].value is defined %}
    {% set veloura_cat_banner_radius_key = veloura_cat_banner_radius_raw.selected[0].value %}
  {% elseif veloura_cat_banner_radius_raw is iterable and veloura_cat_banner_radius_raw[0].value is defined %}
    {% set veloura_cat_banner_radius_key = veloura_cat_banner_radius_raw[0].value %}
  {% elseif veloura_cat_banner_radius_raw.value is defined %}
    {% set veloura_cat_banner_radius_key = veloura_cat_banner_radius_raw.value %}
  {% else %}
    {% set veloura_cat_banner_radius_key = veloura_cat_banner_radius_raw %}
  {% endif %}

  {% set veloura_cat_banner_radius_map = {
    'sharp': '0px',
    'soft': '8px',
    'medium': '16px',
    'large': '28px',
    'round': '999px'
  } %}

  {% set veloura_cat_banner_radius = veloura_cat_banner_radius_map[veloura_cat_banner_radius_key]|default('16px') %}

  <div
    class="
      veloura-category-page
      veloura-cat-banner-layout-{{ veloura_cat_banner_layout }}
      {{ veloura_hide_product_count ? 'veloura-category-hide-count' : '' }}
      {{ veloura_images_transparent ? 'veloura-category-images-transparent' : '' }}
      {{ veloura_show_images ? 'veloura-category-show-images' : 'veloura-category-hide-images' }}
      {{ veloura_hide_products_if_children and has_sub_categories ? 'veloura-category-products-hidden' : '' }}
      veloura-category-mobile-cols-{{ veloura_mobile_cols }}
      veloura-category-desktop-cols-{{ veloura_desktop_cols }}
      veloura-category-title-{{ veloura_title_size }}
      veloura-category-radius-{{ veloura_image_radius }}
      veloura-category-shape-{{ veloura_image_shape }}
      veloura-category-fit-{{ veloura_image_fit }}
      {% if veloura_image_position == 'right' %}
        veloura-category-image-position-right
      {% else %}
        veloura-category-image-position-top
      {% endif %}
    "
  >
    <div class="container px-2.5 ms:px-5 mb-10">

      {% if veloura_show_breadcrumb %}
        <nav class="breadcrumbs w-full py-5 veloura-category-breadcrumb">
          <salla-breadcrumb></salla-breadcrumb>
        </nav>
      {% endif %}

      <div class="flex items-start flex-col md:flex-row">

        {% if filters %}
          <button class="btn--close-sm close-filters sicon-cancel hidden"></button>
          <salla-filters class="md:w-72 lg:sticky lg:top-20 flex-none" id="filters-menu"></salla-filters>
        {% endif %}

        <div class="main-content flex-1 w-full {{ filters ? 'ltr:lg:ml-8 rtl:lg:mr-8' : '' }}">

          <div class="mb-4 sm:mb-6 flex justify-between items-center veloura-category-head">
            <h1 class="font-bold text-xl rtl:pl-3 ltr:pr-3 veloura-category-main-title" id="page-main-title">
              {{ page.title|raw }}
            </h1>

            <div class="flex items-center space-x-2 rtl:space-x-reverse">

              {% if filters %}
                <a href="#filters-menu" class="filters-trigger bg-border-color text-primary lg:hidden mt-2">
                  <i class="sicon-filter text-gray-text text-2xl me-2.5"></i>
                </a>
              {% endif %}

              {% if sort_options|length %}
                <div class="flex items-center veloura-category-sort">
                  <label class="hidden sm:block rtl:ml-3 ltr:mr-3 whitespace-nowrap" for="product-filter">
                    {{ trans('pages.categories.sorting') }}
                  </label>

                  <select id="product-filter" class="form-input pt-0 pb-1 rtl:md:pl-10 ltr:md:pr-10">
                    {% for sort in sort_options %}
                      <option value="{{ sort.id }}" {{ sort.is_selected ? 'selected' : '' }}>
                        {{ sort.name }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endif %}

            </div>
          </div>

          <div
            id="veloura-category-banner-root"
            class="veloura-category-banner-root"
            data-current-id="{{ page.id|default(category.id|default(''))|e('html_attr') }}"
            data-current-category-id="{{ category.id|default(page.id|default(''))|e('html_attr') }}"
            data-current-name="{{ category.name|default(page.title)|striptags|e('html_attr') }}"
            data-current-title="{{ page.title|striptags|e('html_attr') }}"
            data-current-url="{{ category.url|default('')|e('html_attr') }}"
            data-current-slug="{{ page.slug|default('')|e('html_attr') }}"
            style="--veloura-cat-banner-radius: {{ veloura_cat_banner_radius }};"
          ></div>

          <style>
            .veloura-category-banner-root {
              width: 100%;
              margin: 0 0 22px;
            }

            .veloura-category-banner-root:empty {
              display: none;
            }

            .veloura-category-banner-link,
            .veloura-category-banner-box {
              display: block;
              width: 100%;
              overflow: hidden;
              border-radius: var(--veloura-cat-banner-radius, 16px);
              background: #f8fafc;
              box-shadow: 0 14px 34px rgba(15, 23, 42, .08);
            }

            .veloura-category-banner-img {
              display: block;
              width: 100%;
              height: auto;
              border-radius: inherit;
            }

            .veloura-cat-banner-layout-centered .veloura-category-breadcrumb {
              text-align: center;
            }

            .veloura-cat-banner-layout-centered .veloura-category-head {
              justify-content: center;
              text-align: center;
              flex-direction: column;
              gap: 12px;
            }

            .veloura-cat-banner-layout-centered .veloura-category-main-title {
              padding-left: 0 !important;
              padding-right: 0 !important;
            }
          </style>

          {% if has_sub_categories %}
            <section class="veloura-category-children">
              <div class="veloura-category-sticky-wrap">
                <div
                  class="veloura-category-cards {{ veloura_images_slider ? 'is-slider' : 'is-grid' }}"
                  style="
                    --veloura-category-mobile-cols: {{ veloura_mobile_cols }};
                    --veloura-category-desktop-cols: {{ veloura_desktop_cols }};
                    --veloura-category-mobile-slides: {{ veloura_mobile_slides }};
                    --veloura-category-desktop-slides: {{ veloura_desktop_slides }};
                  "
                >

                  <a
                    href="{{ category.url }}"
                    class="veloura-category-card veloura-category-card--all is-active"
                    data-veloura-category-filter="all"
                    data-veloura-category-id="{{ page.id|default(category.id) }}"
                    data-veloura-category-url="{{ category.url|e('html_attr') }}"
                    data-veloura-category-title="{{ category.name|default(page.title)|striptags|e('html_attr') }}"
                  >
                    {% if veloura_show_images %}
                      <span class="veloura-category-card__image veloura-category-card__image--all">
                        <i class="sicon-grid"></i>
                      </span>
                    {% endif %}

                    <span class="veloura-category-card__title">الكل</span>
                  </a>

                  {% for child in category.sub_categories %}
                    {% set child_img = '' %}

                    {% if child.image %}
                      {% set child_img = child.image.url|default(child.image) %}
                    {% endif %}

                    {% if not child_img and child.thumbnail %}
                      {% set child_img = child.thumbnail.url|default(child.thumbnail) %}
                    {% endif %}

                    {% if not child_img and child.cover %}
                      {% set child_img = child.cover.url|default(child.cover) %}
                    {% endif %}

                    {% set render_img = child_img ?: ('images/placeholder.png' | asset) %}

                    <a
                      href="{{ child.url }}"
                      class="veloura-category-card {{ child_img ? 'has-image' : 'has-placeholder' }}"
                      data-veloura-category-filter="child"
                      data-veloura-category-id="{{ child.id }}"
                      data-veloura-category-url="{{ child.url|e('html_attr') }}"
                      data-veloura-category-title="{{ child.name|e('html_attr') }}"
                      data-veloura-child-id="{{ child.id }}"
                      data-veloura-child-name="{{ child.name|e('html_attr') }}"
                      data-veloura-child-url="{{ child.url|e('html_attr') }}"
                      data-veloura-child-slug="{{ child.slug|default('')|e('html_attr') }}"
                    >
                      {% if veloura_show_images %}
                        <span class="veloura-category-card__image">
                          <img
                            class="veloura-category-card__img"
                            src="{{ render_img }}"
                            loading="lazy"
                            alt="{{ child.name|e('html_attr') }}"
                          >
                        </span>
                      {% endif %}

                      <span class="veloura-category-card__title">{{ child.name }}</span>
                    </a>
                  {% endfor %}

                </div>
              </div>
            </section>
          {% endif %}

          {% if not (veloura_hide_products_if_children and has_sub_categories) %}

            {% hook 'product:index.items.start' %}

            <div class="flex min-h-screen veloura-category-products-wrap" id="veloura-category-products-wrap">
              <salla-products-list
                id="veloura-category-products-list"
                class="flex-1 min-w-0 overflow-auto veloura-category-products-list"
                source="{{ page.slug }}"
                source-value="{{ page.id }}"
                {{ filters ? 'filters-Results' : '' }}>
              </salla-products-list>
            </div>

            {% hook 'product:index.items.end' %}

          {% endif %}

        </div>
      </div>
    </div>
  </div>

  {% if store.settings.category.testimonial_enabled %}
    {% component 'home.testimonials' %}
  {% endif %}

{% endblock %}

{% block scripts %}

  <script defer src="{{ 'product.js' | asset }}"></script>


  {% if veloura_cat_banner_items|length %}
    <script type="application/json" id="veloura-category-banners-json">
      {{ veloura_cat_banner_items|json_encode|raw }}
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const root = document.getElementById('veloura-category-banner-root');
        const jsonEl = document.getElementById('veloura-category-banners-json');

        if (!root || !jsonEl) return;

        function parseMaybe(value) {
          if (typeof value !== 'string') return value;

          const text = value.trim();

          if (
            (text.startsWith('{') && text.endsWith('}')) ||
            (text.startsWith('[') && text.endsWith(']'))
          ) {
            try {
              return JSON.parse(text);
            } catch (e) {
              return value;
            }
          }

          return value;
        }

        function normalize(value) {
          return String(value || '')
            .trim()
            .toLowerCase()
            .split('?')[0]
            .replace(/\/+$/g, '');
        }

        function unwrap(item) {
          item = parseMaybe(item);

          if (!item || typeof item !== 'object') return item;

          if (item.value && typeof item.value === 'object' && !Array.isArray(item.value)) {
            return Object.assign({}, item, item.value);
          }

          return item;
        }

        function collectAllValues(value, result) {
          value = parseMaybe(value);

          if (value === null || value === undefined) return;

          if (typeof value === 'string' || typeof value === 'number') {
            result.push(String(value));
            return;
          }

          if (Array.isArray(value)) {
            value.forEach(function (item) {
              collectAllValues(item, result);
            });
            return;
          }

          if (typeof value === 'object') {
            Object.keys(value).forEach(function (key) {
              collectAllValues(value[key], result);
            });
          }
        }

        function getImageUrl(item) {
          item = unwrap(item);
          if (!item) return '';

          const image =
            item.veloura_cat_banner_image ||
            item['veloura_cat_banner_image'] ||
            item.image ||
            item['image'] ||
            '';

          const parsedImage = parseMaybe(image);

          if (!parsedImage) return '';

          if (typeof parsedImage === 'string') {
            return parsedImage;
          }

          if (Array.isArray(parsedImage)) {
            for (let i = 0; i < parsedImage.length; i++) {
              const url = getImageUrl({ veloura_cat_banner_image: parsedImage[i] });
              if (url) return url;
            }
          }

          if (typeof parsedImage === 'object') {
            return parsedImage.url ||
              parsedImage.src ||
              parsedImage.original ||
              parsedImage.large ||
              parsedImage.medium ||
              parsedImage.thumbnail ||
              parsedImage.path ||
              '';
          }

          return '';
        }

        function getBannerUrl(item) {
          item = unwrap(item);
          if (!item) return '';

          let url = item.veloura_cat_banner_url || item['veloura_cat_banner_url'] || item.url || '';
          url = parseMaybe(url);

          if (!url) return '';

          if (typeof url === 'string') return url.trim();
          if (typeof url === 'object') return String(url.value || url.url || '').trim();

          return '';
        }

        function getCategoryTokens(item) {
          item = unwrap(item);

          const tokens = [];

          if (!item) return tokens;

          const categories =
            item.veloura_cat_banner_categories ||
            item['veloura_cat_banner_categories'] ||
            item.category ||
            item.categories ||
            item.selected_categories ||
            item.value ||
            [];

          collectAllValues(categories, tokens);

          return tokens.map(normalize).filter(Boolean);
        }

        const currentTokens = [
          root.getAttribute('data-current-id'),
          root.getAttribute('data-current-category-id'),
          root.getAttribute('data-current-name'),
          root.getAttribute('data-current-title'),
          root.getAttribute('data-current-url'),
          root.getAttribute('data-current-slug')
        ].map(normalize).filter(Boolean);

        if (!currentTokens.length) return;

        let items = [];

        try {
          items = JSON.parse(jsonEl.textContent || '[]');
        } catch (error) {
          items = [];
        }

        if (!Array.isArray(items) && typeof items === 'object') {
          items = Object.values(items);
        }

        const prepared = items
          .map(function (item) {
            item = unwrap(item);

            return {
              image: getImageUrl(item),
              url: getBannerUrl(item),
              tokens: getCategoryTokens(item)
            };
          })
          .filter(function (item) {
            return item.image && item.tokens.length;
          });

        const match = prepared.find(function (item) {
          const exact = currentTokens.some(function (currentToken) {
            return item.tokens.some(function (token) {
              return token === currentToken;
            });
          });

          if (exact) return true;

          return currentTokens.some(function (currentToken) {
            return item.tokens.some(function (token) {
              return token.includes(currentToken) || currentToken.includes(token);
            });
          });
        });

        if (!match || !match.image) return;

        const holder = document.createElement(match.url ? 'a' : 'div');
        holder.className = match.url ? 'veloura-category-banner-link' : 'veloura-category-banner-box';

        if (match.url) {
          holder.href = match.url;
        }

        const img = document.createElement('img');
        img.className = 'veloura-category-banner-img';
        img.src = match.image;
        img.alt = root.getAttribute('data-current-name') || root.getAttribute('data-current-title') || '';
        img.loading = 'lazy';

        holder.appendChild(img);
        root.appendChild(holder);
      });
    </script>
  {% endif %}

