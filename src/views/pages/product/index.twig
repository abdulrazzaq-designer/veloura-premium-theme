{#
| Variable                   | Type        | Description                                                          |
|----------------------------|-------------|----------------------------------------------------------------------|
| page                       | object      |                                                                      |
| page.title                 | string      | *could be html                                                       |
| page.slug                  | string      | ex: "cat.show"                                                       |
| category                   | ?Category   |                                                                      |
| category.name              | string      |                                                                      |
| category.url               | string      |                                                                      |
| category.sub_categories    | ?Category[] |                                                                      |
| category.image             | ?string     |                                                                      |
| filters                    | bool        | is filters allowed here or not                                       |
| sort_options[]             | SortList[]  |                                                                      |
| sort_options[].id          | string      | ourSuggest, bestSell, topRated, priceFromTopToLow, priceFromLowToTop |
| sort_options[].name        | string      |                                                                      |
| sort_options[].is_selected | bool        | Is current page sorted by it                                         |
| search_query               | ?string     |                                                                      |
#}

{% extends "layouts.master" %}

{% block content %}

  {# ================================
     Veloura Category Settings
     veloura_category_enabled_2026 فقط للوحة التحكم
  ================================ #}

  {% set veloura_show_breadcrumb = theme.settings.get('veloura_category_show_breadcrumb_2026', true) %}
  {% set veloura_hide_product_count = theme.settings.get('veloura_category_hide_product_count_2026', false) %}

  {% set veloura_images_slider = theme.settings.get('veloura_category_images_slider_2026', true) %}
  {% set veloura_images_transparent = theme.settings.get('veloura_category_images_transparent_bg_2026', false) %}
  {% set veloura_mobile_cols = theme.settings.get('veloura_category_mobile_cols_2026', '3') %}
  {% set veloura_desktop_cols = theme.settings.get('veloura_category_desktop_cols_2026', '6') %}
  {% set veloura_title_size = theme.settings.get('veloura_category_title_size_2026', 'medium') %}
  {% set veloura_image_radius = theme.settings.get('veloura_category_image_radius_2026', 'round') %}
  {% set veloura_image_shape = theme.settings.get('veloura_category_image_shape_2026', 'square') %}
  {% set veloura_image_fit = theme.settings.get('veloura_category_image_fit_2026', 'cover') %}

  {% set veloura_linked_images = theme.settings.get('veloura_category_linked_images_2026') ?: [] %}
  {% set has_sub_categories = category and category.sub_categories and category.sub_categories|length %}

  <div
    class="
      veloura-category-page
      {{ veloura_hide_product_count ? 'veloura-category-hide-count' : '' }}
      {{ veloura_images_transparent ? 'veloura-category-images-transparent' : '' }}
      veloura-category-mobile-cols-{{ veloura_mobile_cols }}
      veloura-category-desktop-cols-{{ veloura_desktop_cols }}
      veloura-category-title-{{ veloura_title_size }}
      veloura-category-radius-{{ veloura_image_radius }}
      veloura-category-shape-{{ veloura_image_shape }}
      veloura-category-fit-{{ veloura_image_fit }}
    "
  >
    <div class="container px-2.5 ms:px-5 mb-10">

      {% if veloura_show_breadcrumb %}
        <nav class="breadcrumbs w-full py-5 veloura-category-breadcrumb">
          <salla-breadcrumb></salla-breadcrumb>
        </nav>
      {% endif %}

      <div class="flex items-start flex-col md:flex-row">

        {% if filters %}
          <button class="btn--close-sm close-filters sicon-cancel hidden"></button>
          <salla-filters class="md:w-72 lg:sticky lg:top-20 flex-none" id="filters-menu"></salla-filters>
        {% endif %}

        <div class="main-content flex-1 w-full {{ filters ? 'ltr:lg:ml-8 rtl:lg:mr-8' : '' }}">

          <div class="mb-4 sm:mb-6 flex justify-between items-center veloura-category-head">
            <h1 class="font-bold text-xl rtl:pl-3 ltr:pr-3 veloura-category-main-title" id="page-main-title">
              {{ page.title|raw }}
            </h1>

            <div class="flex items-center space-x-2 rtl:space-x-reverse">

              {% if filters %}
                <a href="#filters-menu" class="filters-trigger bg-border-color text-primary lg:hidden mt-2">
                  <i class="sicon-filter text-gray-text text-2xl me-2.5"></i>
                </a>
              {% endif %}

              {% if sort_options|length %}
                <div class="flex items-center veloura-category-sort">
                  <label class="hidden sm:block rtl:ml-3 ltr:mr-3 whitespace-nowrap" for="product-filter">
                    {{ trans('pages.categories.sorting') }}
                  </label>

                  <select id="product-filter" class="form-input pt-0 pb-1 rtl:md:pl-10 ltr:md:pr-10">
                    {% for sort in sort_options %}
                      <option value="{{ sort.id }}" {{ sort.is_selected ? 'selected' : '' }}>
                        {{ sort.name }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endif %}

            </div>
          </div>

          {# ================================
             بيانات الصور المرتبطة من الإعدادات
             لا نستخدمها مباشرة داخل لوب التصنيفات حتى لا تضرب Twig
          ================================ #}

          {% if veloura_linked_images|length %}
            <div class="veloura-category-linked-data" hidden>
              {% for item in veloura_linked_images %}

                {% set linked_img = item.image.url|default(item.image|default('')) %}

                {% set linked_cat_id = item.category.value|default('') %}
                {% if not linked_cat_id %}
                  {% set linked_cat_id = item.category.id|default('') %}
                {% endif %}
                {% if not linked_cat_id %}
                  {% set linked_cat_id = item.category.key|default('') %}
                {% endif %}

                {% set linked_cat_name = item.category.label|default('') %}
                {% if not linked_cat_name %}
                  {% set linked_cat_name = item.category.name|default('') %}
                {% endif %}
                {% if not linked_cat_name %}
                  {% set linked_cat_name = item.category.title|default('') %}
                {% endif %}

                {% if linked_img %}
                  <span
                    class="veloura-linked-image-item"
                    data-cat-id="{{ linked_cat_id }}"
                    data-cat-name="{{ linked_cat_name }}"
                    data-img="{{ linked_img }}"
                  ></span>
                {% endif %}

              {% endfor %}
            </div>
          {% endif %}

          {# ================================
             التصنيفات كتبويبات ثابتة
          ================================ #}

          {% if has_sub_categories %}
            <section class="veloura-category-children veloura-category-tabs-wrap">
              <div class="veloura-category-cards {{ veloura_images_slider ? 'is-slider' : 'is-grid' }}">

                <button
                  type="button"
                  class="veloura-category-card veloura-category-tab is-active"
                  data-veloura-category-tab="parent"
                >
                  <span class="veloura-category-card__image veloura-category-card__image--all">
                    <i class="sicon-grid"></i>
                  </span>

                  <span class="veloura-category-card__title">
                    الكل
                  </span>
                </button>

                {% for child in category.sub_categories %}

                  {% set child_img = 'images/placeholder.png' | asset %}

                  {% if child.image %}
                    {% set child_img = child.image.url|default(child.image) %}
                  {% endif %}

                  {% if child.thumbnail %}
                    {% set child_img = child.thumbnail.url|default(child.thumbnail) %}
                  {% endif %}

                  {% if child.cover %}
                    {% set child_img = child.cover.url|default(child.cover) %}
                  {% endif %}

                  <button
                    type="button"
                    class="veloura-category-card veloura-category-tab"
                    data-veloura-category-tab="child-{{ child.id }}"
                    data-veloura-child-id="{{ child.id }}"
                    data-veloura-child-name="{{ child.name }}"
                  >
                    <span class="veloura-category-card__image">
                      <img
                        class="veloura-category-card__img"
                        src="{{ child_img }}"
                        loading="lazy"
                        alt="{{ child.name }}"
                      >
                    </span>

                    <span class="veloura-category-card__title">
                      {{ child.name }}
                    </span>
                  </button>

                {% endfor %}

              </div>
            </section>
          {% endif %}

          {% hook 'product:index.items.start' %}

          {# ================================
             المنتجات حسب التبويب
          ================================ #}

          <div class="veloura-category-tab-panels">

            <div
              class="veloura-category-panel is-active"
              data-veloura-category-panel="parent"
              style="display:block"
            >
              <div class="flex min-h-screen veloura-category-products-wrap">
                <salla-products-list
                  class="flex-1 min-w-0 overflow-auto veloura-category-products-list"
                  source="{{ page.slug }}"
                  source-value="{{ page.id }}"
                  {{ filters ? 'filters-Results' : '' }}>
                </salla-products-list>
              </div>
            </div>

            {% if has_sub_categories %}
              {% for child in category.sub_categories %}
                <div
                  class="veloura-category-panel"
                  data-veloura-category-panel="child-{{ child.id }}"
                  style="display:none"
                >
                  <div class="flex min-h-screen veloura-category-products-wrap">
                    <salla-products-list
                      class="flex-1 min-w-0 overflow-auto veloura-category-products-list"
                      source="{{ page.slug }}"
                      source-value="{{ child.id }}"
                      {{ filters ? 'filters-Results' : '' }}>
                    </salla-products-list>
                  </div>
                </div>
              {% endfor %}
            {% endif %}

          </div>

          {% hook 'product:index.items.end' %}

        </div>
      </div>
    </div>
  </div>

  {% if store.settings.category.testimonial_enabled %}
    {% component 'home.testimonials' %}
  {% endif %}

{% endblock %}

{% block scripts %}
  <script defer src="{{ 'product.js' | asset }}"></script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const tabs = document.querySelectorAll('[data-veloura-category-tab]');
      const panels = document.querySelectorAll('[data-veloura-category-panel]');
      const linkedItems = document.querySelectorAll('.veloura-linked-image-item');

      const normalize = function (value) {
        return String(value || '').trim().toLowerCase();
      };

      /* ربط الصور حسب ID التصنيف أو الاسم */
      if (linkedItems.length) {
        const imagesById = {};
        const imagesByName = {};

        linkedItems.forEach(function (item) {
          const catId = normalize(item.getAttribute('data-cat-id'));
          const catName = normalize(item.getAttribute('data-cat-name'));
          const img = item.getAttribute('data-img') || '';

          if (catId && img) {
            imagesById[catId] = img;
          }

          if (catName && img) {
            imagesByName[catName] = img;
          }
        });

        document.querySelectorAll('.veloura-category-tab[data-veloura-child-id]').forEach(function (tab) {
          const childId = normalize(tab.getAttribute('data-veloura-child-id'));
          const childName = normalize(tab.getAttribute('data-veloura-child-name'));
          const image = tab.querySelector('.veloura-category-card__img');

          if (!image) return;

          const linkedImage = imagesById[childId] || imagesByName[childName];

          if (linkedImage) {
            image.setAttribute('src', linkedImage);
          }
        });
      }

      /* تشغيل التبويبات */
      if (!tabs.length || !panels.length) return;

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          const target = tab.getAttribute('data-veloura-category-tab');

          tabs.forEach(function (item) {
            item.classList.remove('is-active');
          });

          panels.forEach(function (panel) {
            panel.classList.remove('is-active');
            panel.style.display = 'none';
          });

          tab.classList.add('is-active');

          const activePanel = document.querySelector('[data-veloura-category-panel="' + target + '"]');

          if (activePanel) {
            activePanel.classList.add('is-active');
            activePanel.style.display = 'block';
          }
        });
      });
    });
  </script>

  {% if veloura_hide_product_count %}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const title = document.getElementById('page-main-title');

        if (!title) return;

        title.querySelectorAll('span, small, em').forEach(function (item) {
          if (/\d+/.test(item.textContent || '')) {
            item.remove();
          }
        });

        title.innerHTML = title.innerHTML
          .replace(/\s*[\(\[]\s*\d+\s*[\)\]]\s*$/g, '')
          .replace(/\s*[-–]\s*\d+\s*$/g, '');
      });
    </script>
  {% endif %}
{% endblock %}