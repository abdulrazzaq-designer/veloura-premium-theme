{#
| Variable                   | Type        | Description                                                          |
|----------------------------|-------------|----------------------------------------------------------------------|
| page                       | object      |                                                                      |
| page.title                 | string      | *could be html                                                       |
| page.slug                  | string      | ex: "cat.show"                                                       |
| category                   | ?Category   |                                                                      |
| category.name              | string      |                                                                      |
| category.url               | string      |                                                                      |
| category.sub_categories    | ?Category[] |                                                                      |
| category.image             | ?string     |                                                                      |
| filters                    | bool        | is filters allowed here or not                                       |
| sort_options[]             | SortList[]  |                                                                      |
| sort_options[].id          | string      | ourSuggest, bestSell, topRated, priceFromTopToLow, priceFromLowToTop |
| sort_options[].name        | string      |                                                                      |
| sort_options[].is_selected | bool        | Is current page sorted by it                                         |
| search_query               | ?string     |                                                                      |
#}

{% extends "layouts.master" %}

{% block content %}

  {% set veloura_show_breadcrumb = theme.settings.get('veloura_category_show_breadcrumb_2026', true) %}
  {% set veloura_hide_product_count = theme.settings.get('veloura_category_hide_product_count_2026', false) %}

  {% set veloura_images_slider_raw = theme.settings.get('veloura_category_images_slider_2026', false) %}
{% set veloura_images_slider = veloura_images_slider_raw == true or veloura_images_slider_raw == 'true' or veloura_images_slider_raw == 1 or veloura_images_slider_raw == '1' %}

{% set veloura_images_transparent_raw = theme.settings.get('veloura_category_images_transparent_bg_2026', false) %}
{% set veloura_images_transparent = veloura_images_transparent_raw == true or veloura_images_transparent_raw == 'true' or veloura_images_transparent_raw == 1 or veloura_images_transparent_raw == '1' %}
  {% set veloura_mobile_cols = theme.settings.get('veloura_category_mobile_cols_2026', '3') %}
  {% set veloura_desktop_cols = theme.settings.get('veloura_category_desktop_cols_2026', '6') %}
  {% set veloura_title_size = theme.settings.get('veloura_category_title_size_2026', 'medium') %}
  {% set veloura_image_radius = theme.settings.get('veloura_category_image_radius_2026', 'round') %}
  {% set veloura_image_shape = theme.settings.get('veloura_category_image_shape_2026', 'square') %}
  {% set veloura_image_fit = theme.settings.get('veloura_category_image_fit_2026', 'cover') %}

  {% set veloura_use_custom_images = theme.settings.get('veloura_category_use_custom_images_2026', false) %}
  {% set veloura_linked_images = theme.settings.get('veloura_category_images_map_v7_2026') ?: [] %}

  {% set has_sub_categories = category and category.sub_categories and category.sub_categories|length %}

  <style>
    .veloura-category-page .veloura-category-children {
      position: sticky;
      top: 0;
      z-index: 60;
      background: #fff;
      padding: 10px 0 12px;
      margin-bottom: 18px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    }

    .veloura-category-page .veloura-category-sticky-wrap {
      width: 100%;
      overflow: hidden;
    }

    .veloura-category-page .veloura-category-cards {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      overflow-y: hidden;
      padding: 6px 2px 12px;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

    .veloura-category-page .veloura-category-cards::-webkit-scrollbar {
      height: 4px;
    }

    .veloura-category-page .veloura-category-cards::-webkit-scrollbar-thumb {
      background: rgba(0, 0, 0, 0.18);
      border-radius: 999px;
    }

    .veloura-category-page .veloura-category-card {
      position: relative;
      flex: 0 0 auto;
      width: 110px;
      min-height: 126px;
      padding: 8px;
      border-radius: 18px;
      background: #fff;
      border: 2px solid transparent;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
      text-align: center;
      transition: 0.25s ease;
    }

    .veloura-category-page .veloura-category-card__image {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 76px;
      border-radius: 14px;
      overflow: hidden;
      background: #f5f5f5;
    }

    .veloura-category-page .veloura-category-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .veloura-category-page .veloura-category-card__title {
      display: block;
      margin-top: 8px;
      font-size: 13px;
      font-weight: 700;
      line-height: 1.5;
      color: #222;
    }

    .veloura-category-page .veloura-category-card:hover,
    .veloura-category-page .veloura-category-card.is-active {
      border-color: var(--color-primary, #006b7a);
      box-shadow: 0 10px 26px rgba(0, 107, 122, 0.22);
      transform: translateY(-2px);
    }

    .veloura-category-page .veloura-category-card.is-active::after {
      content: "✓";
      position: absolute;
      top: 7px;
      inset-inline-end: 7px;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: var(--color-primary, #006b7a);
      color: #fff;
      font-size: 13px;
      font-weight: 900;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
    }

    .veloura-category-page .veloura-category-card--all .veloura-category-card__image--all {
      background: linear-gradient(135deg, #004d65, #00a6a6);
      color: #fff;
      font-size: 34px;
    }

    .veloura-category-page .veloura-category-products-wrap.is-loading {
      opacity: 0.45;
      pointer-events: none;
      transition: opacity 0.2s ease;
    }

    @media (max-width: 768px) {
      .veloura-category-page .veloura-category-children {
        top: 0;
        padding-top: 8px;
      }

      .veloura-category-page .veloura-category-card {
        width: 96px;
        min-height: 118px;
        border-radius: 16px;
      }

      .veloura-category-page .veloura-category-card__image {
        height: 68px;
      }

      .veloura-category-page .veloura-category-card__title {
        font-size: 12px;
      }
    }
  </style>

  <div
    class="
      veloura-category-page
      {{ veloura_hide_product_count ? 'veloura-category-hide-count' : '' }}
      {{ veloura_images_transparent ? 'veloura-category-images-transparent' : '' }}
      veloura-category-mobile-cols-{{ veloura_mobile_cols }}
      veloura-category-desktop-cols-{{ veloura_desktop_cols }}
      veloura-category-title-{{ veloura_title_size }}
      veloura-category-radius-{{ veloura_image_radius }}
      veloura-category-shape-{{ veloura_image_shape }}
      veloura-category-fit-{{ veloura_image_fit }}
    "
  >
    <div class="container px-2.5 ms:px-5 mb-10">

      {% if veloura_show_breadcrumb %}
        <nav class="breadcrumbs w-full py-5 veloura-category-breadcrumb">
          <salla-breadcrumb></salla-breadcrumb>
        </nav>
      {% endif %}

      <div class="flex items-start flex-col md:flex-row">

        {% if filters %}
          <button class="btn--close-sm close-filters sicon-cancel hidden"></button>
          <salla-filters class="md:w-72 lg:sticky lg:top-20 flex-none" id="filters-menu"></salla-filters>
        {% endif %}

        <div class="main-content flex-1 w-full {{ filters ? 'ltr:lg:ml-8 rtl:lg:mr-8' : '' }}">

          <div class="mb-4 sm:mb-6 flex justify-between items-center veloura-category-head">
            <h1 class="font-bold text-xl rtl:pl-3 ltr:pr-3 veloura-category-main-title" id="page-main-title">
              {{ page.title|raw }}
            </h1>

            <div class="flex items-center space-x-2 rtl:space-x-reverse">

              {% if filters %}
                <a href="#filters-menu" class="filters-trigger bg-border-color text-primary lg:hidden mt-2">
                  <i class="sicon-filter text-gray-text text-2xl me-2.5"></i>
                </a>
              {% endif %}

              {% if sort_options|length %}
                <div class="flex items-center veloura-category-sort">
                  <label class="hidden sm:block rtl:ml-3 ltr:mr-3 whitespace-nowrap" for="product-filter">
                    {{ trans('pages.categories.sorting') }}
                  </label>

                  <select id="product-filter" class="form-input pt-0 pb-1 rtl:md:pl-10 ltr:md:pr-10">
                    {% for sort in sort_options %}
                      <option value="{{ sort.id }}" {{ sort.is_selected ? 'selected' : '' }}>
                        {{ sort.name }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endif %}

            </div>
          </div>

          {% if has_sub_categories %}
            <section class="veloura-category-children">
              <div class="veloura-category-sticky-wrap">
                <div
  class="veloura-category-cards {{ veloura_images_slider ? 'is-slider' : 'is-grid' }}"
  style="
    --veloura-category-mobile-cols: {{ veloura_mobile_cols }};
    --veloura-category-desktop-cols: {{ veloura_desktop_cols }};
  "
>

                  <a
                    href="{{ category.url }}"
                    class="veloura-category-card veloura-category-card--all is-active"
                    data-veloura-category-filter="all"
                    data-veloura-category-id="{{ page.id|default(category.id) }}"
                    data-veloura-category-url="{{ category.url|e('html_attr') }}"
                    data-veloura-category-title="{{ category.name|default(page.title)|striptags|e('html_attr') }}"
                  >
                    <span class="veloura-category-card__image veloura-category-card__image--all">
                      <i class="sicon-grid"></i>
                    </span>

                    <span class="veloura-category-card__title">
                      عرض الكل
                    </span>
                  </a>

                  {% for child in category.sub_categories %}
                    {% set child_img = '' %}

                    {% if child.image %}
                      {% set child_img = child.image.url|default(child.image) %}
                    {% endif %}

                    {% if not child_img and child.thumbnail %}
                      {% set child_img = child.thumbnail.url|default(child.thumbnail) %}
                    {% endif %}

                    {% if not child_img and child.cover %}
                      {% set child_img = child.cover.url|default(child.cover) %}
                    {% endif %}

                    {% set render_img = child_img ?: ('images/placeholder.png' | asset) %}

                    <a
                      href="{{ child.url }}"
                      class="veloura-category-card {{ child_img ? 'has-image' : 'has-no-image' }}"
                      data-veloura-category-filter="child"
                      data-veloura-category-id="{{ child.id }}"
                      data-veloura-category-url="{{ child.url|e('html_attr') }}"
                      data-veloura-category-title="{{ child.name|e('html_attr') }}"
                      data-veloura-child-id="{{ child.id }}"
                      data-veloura-child-name="{{ child.name|e('html_attr') }}"
                      data-veloura-child-url="{{ child.url|e('html_attr') }}"
                      data-veloura-child-slug="{{ child.slug|default('')|e('html_attr') }}"
                    >
                      <span class="veloura-category-card__image {{ child_img ? '' : 'is-empty' }}">
                        <img
                          class="veloura-category-card__img"
                          src="{{ render_img }}"
                          loading="lazy"
                          alt="{{ child.name|e('html_attr') }}"
                        >
                      </span>

                      <span class="veloura-category-card__title">
                        {{ child.name }}
                      </span>
                    </a>
                  {% endfor %}

                </div>
              </div>
            </section>
          {% endif %}

          {% hook 'product:index.items.start' %}

          <div class="flex min-h-screen veloura-category-products-wrap" id="veloura-category-products-wrap">
            <salla-products-list
              id="veloura-category-products-list"
              class="flex-1 min-w-0 overflow-auto veloura-category-products-list"
              source="{{ page.slug }}"
              source-value="{{ page.id }}"
              {{ filters ? 'filters-Results' : '' }}>
            </salla-products-list>
          </div>

          {% hook 'product:index.items.end' %}

        </div>
      </div>
    </div>
  </div>

  {% if store.settings.category.testimonial_enabled %}
    {% component 'home.testimonials' %}
  {% endif %}

{% endblock %}

{% block scripts %}

  {% set veloura_hide_product_count = theme.settings.get('veloura_category_hide_product_count_2026', false) %}
  {% set veloura_use_custom_images = theme.settings.get('veloura_category_use_custom_images_2026', false) %}
  {% set veloura_linked_images = theme.settings.get('veloura_category_images_map_v7_2026') ?: [] %}

  <script defer src="{{ 'product.js' | asset }}"></script>

  {% if veloura_use_custom_images and veloura_linked_images|length %}
    <script type="application/json" id="veloura-category-images-json">
      {{ veloura_linked_images|json_encode|raw }}
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const jsonEl = document.getElementById('veloura-category-images-json');

        if (!jsonEl) return;

        function normalize(value) {
          return String(value || '').trim().toLowerCase();
        }

        function collectAllValues(value, result) {
          if (value === null || value === undefined) return;

          if (typeof value === 'string' || typeof value === 'number') {
            result.push(String(value));
            return;
          }

          if (Array.isArray(value)) {
            value.forEach(function (item) {
              collectAllValues(item, result);
            });
            return;
          }

          if (typeof value === 'object') {
            Object.keys(value).forEach(function (key) {
              collectAllValues(value[key], result);
            });
          }
        }

        function getImageUrl(item) {
          if (!item) return '';

          const image =
            item.veloura_map_image ||
            item['veloura_map_image'] ||
            item.image ||
            item['image'] ||
            item.url ||
            '';

          if (!image) return '';

          if (typeof image === 'string') {
            return image;
          }

          if (Array.isArray(image)) {
            for (let i = 0; i < image.length; i++) {
              const url = getImageUrl({ veloura_map_image: image[i] });
              if (url) return url;
            }
          }

          return image.url ||
            image.src ||
            image.original ||
            image.large ||
            image.medium ||
            image.thumbnail ||
            image.path ||
            '';
        }

        function getCategoryTokens(item) {
          const tokens = [];

          if (!item) return tokens;

          const categories =
            item.veloura_map_categories ||
            item['veloura_map_categories'] ||
            item.category ||
            item.categories ||
            item.value ||
            [];

          collectAllValues(categories, tokens);

          return tokens.map(normalize).filter(Boolean);
        }

        let items = [];

        try {
          items = JSON.parse(jsonEl.textContent || '[]');
        } catch (error) {
          items = [];
        }

        const prepared = items
          .map(function (item) {
            return {
              image: getImageUrl(item),
              tokens: getCategoryTokens(item),
              raw: item
            };
          })
          .filter(function (item) {
            return item.image && item.tokens.length;
          });

        function applyCustomCategoryImages() {
          document.querySelectorAll('.veloura-category-card[data-veloura-child-id]').forEach(function (card) {
            const childTokens = [];

            [
              card.getAttribute('data-veloura-child-id'),
              card.getAttribute('data-veloura-child-name'),
              card.getAttribute('data-veloura-child-url'),
              card.getAttribute('data-veloura-child-slug')
            ].forEach(function (value) {
              if (value) childTokens.push(normalize(value));
            });

            const match = prepared.find(function (item) {
              return childTokens.some(function (childToken) {
                return item.tokens.some(function (token) {
                  return token === childToken ||
                    token.includes(childToken) ||
                    childToken.includes(token);
                });
              });
            });

            if (!match || !match.image) return;

            const img = card.querySelector('.veloura-category-card__img');
            const imageWrap = card.querySelector('.veloura-category-card__image');

            if (!img || !imageWrap) return;

            img.src = match.image;
            img.removeAttribute('hidden');

            imageWrap.classList.remove('is-empty');

            card.classList.remove('has-no-image');
            card.classList.add('has-image', 'has-custom-image');
          });
        }

        applyCustomCategoryImages();

        setTimeout(applyCustomCategoryImages, 500);
        setTimeout(applyCustomCategoryImages, 1200);
        setTimeout(applyCustomCategoryImages, 2500);
      });
    </script>
  {% endif %}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const cards = document.querySelectorAll('.veloura-category-card[data-veloura-category-id]');
      const productsWrap = document.getElementById('veloura-category-products-wrap');
      const pageTitle = document.getElementById('page-main-title');

      if (!cards.length || !productsWrap) return;

      const originalTitle = pageTitle ? pageTitle.innerHTML : '';
      const originalSource = '{{ page.slug }}';
      const originalSourceValue = '{{ page.id }}';
      const hasFilters = {{ filters ? 'true' : 'false' }};

      function setActiveCard(activeCard) {
        cards.forEach(function (card) {
          card.classList.remove('is-active');
        });

        activeCard.classList.add('is-active');

        if (activeCard.scrollIntoView) {
          setTimeout(function () {
            activeCard.scrollIntoView({
              behavior: 'smooth',
              inline: 'center',
              block: 'nearest'
            });
          }, 150);
        }
      }

      function rebuildProductsList(sourceValue) {
        const oldList = document.getElementById('veloura-category-products-list');

        if (!oldList) return;

        productsWrap.classList.add('is-loading');

        const newList = document.createElement('salla-products-list');

        newList.id = 'veloura-category-products-list';
        newList.className = oldList.className || 'flex-1 min-w-0 overflow-auto veloura-category-products-list';

        newList.setAttribute('source', originalSource);
        newList.setAttribute('source-value', sourceValue);

        if (hasFilters) {
          newList.setAttribute('filters-Results', '');
        }

        oldList.replaceWith(newList);

        setTimeout(function () {
          productsWrap.classList.remove('is-loading');
        }, 700);
      }

      cards.forEach(function (card) {
        card.addEventListener('click', function (event) {
          event.preventDefault();

          const type = card.getAttribute('data-veloura-category-filter');
          const categoryId = card.getAttribute('data-veloura-category-id');
          const categoryTitle = card.getAttribute('data-veloura-category-title');

          if (!categoryId) return;

          setActiveCard(card);

          if (type === 'all') {
            rebuildProductsList(originalSourceValue);

            if (pageTitle) {
              pageTitle.innerHTML = originalTitle;
            }

            return;
          }

          rebuildProductsList(categoryId);

          if (pageTitle && categoryTitle) {
            pageTitle.textContent = categoryTitle;
          }
        });
      });
    });
  </script>

  {% if veloura_hide_product_count %}
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const title = document.getElementById('page-main-title');

        if (!title) return;

        title.querySelectorAll('span, small, em').forEach(function (item) {
          if (/\d+/.test(item.textContent || '')) {
            item.remove();
          }
        });

        title.innerHTML = title.innerHTML
          .replace(/\s*[\(\[]\s*\d+\s*[\)\]]\s*$/g, '')
          .replace(/\s*[-–]\s*\d+\s*$/g, '');
      });
    </script>
  {% endif %}

{% endblock %}